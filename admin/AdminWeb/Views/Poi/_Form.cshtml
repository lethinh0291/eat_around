@model POI
@{
    var actionName = ViewData["ActionName"]?.ToString() ?? "Create";
}

<div class="form-panel p-4">
    <form asp-action="@actionName" method="post" class="admin-form">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <input asp-for="Id" type="hidden" />

        <div class="row g-3">
            <div class="col-lg-8">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" placeholder="Tên địa điểm" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>
            <div class="col-lg-4">
                <label asp-for="LanguageCode" class="form-label"></label>
                <input asp-for="LanguageCode" class="form-control" placeholder="vi" />
                <span asp-validation-for="LanguageCode" class="text-danger small"></span>
            </div>
            <div class="col-12">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="4"
                          placeholder="Mô tả ngắn về địa điểm"></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>
            <div class="col-md-6 col-lg-3">
                <label asp-for="Latitude" class="form-label"></label>
                <input asp-for="Latitude" class="form-control" type="number" step="0.000001" />
                <span asp-validation-for="Latitude" class="text-danger small"></span>
            </div>
            <div class="col-md-6 col-lg-3">
                <label asp-for="Longitude" class="form-label"></label>
                <input asp-for="Longitude" class="form-control" type="number" step="0.000001" />
                <span asp-validation-for="Longitude" class="text-danger small"></span>
            </div>
            <div class="col-12">
                <div class="p-3 rounded-4" style="border: 1px solid var(--admin-border); background: var(--admin-surface-soft);">
                    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-2">
                        <div class="fw-semibold">Chọn tọa độ trên bản đồ</div>
                        <small class="text-muted">Click bản đồ hoặc kéo marker để cập nhật Latitude/Longitude</small>
                    </div>
                    <div id="poi-form-map" class="poi-form-map"></div>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <label asp-for="Radius" class="form-label"></label>
                <input asp-for="Radius" class="form-control" type="number" step="0.1" />
                <span asp-validation-for="Radius" class="text-danger small"></span>
            </div>
            <div class="col-md-6 col-lg-3">
                <label asp-for="Priority" class="form-label"></label>
                <input asp-for="Priority" class="form-control" type="number" min="1" max="10" />
                <span asp-validation-for="Priority" class="text-danger small"></span>
            </div>
            <div class="col-lg-6">
                <label asp-for="ImageUrl" class="form-label"></label>
                <input asp-for="ImageUrl" type="hidden" />
                <div class="input-group input-group-sm mb-2">
                    <input id="poiImageFile" type="file" class="form-control" accept="image/*" />
                    <button type="button" id="uploadPoiImageButton" class="btn btn-outline-primary">Tải ảnh</button>
                </div>
                <div id="poiImageUploadStatus" class="small text-muted mb-2">Chọn ảnh từ máy để cập nhật ảnh POI.</div>
                <img id="poiImagePreview" src="@Model.ImageUrl" alt="POI preview"
                     style="@(string.IsNullOrWhiteSpace(Model.ImageUrl) ? "display:none;" : "display:block;")width:100%;max-height:220px;object-fit:cover;border-radius:10px;border:1px solid #e5e7eb;" />
                <span asp-validation-for="ImageUrl" class="text-danger small"></span>
            </div>
            <div class="col-lg-6">
                <label asp-for="AudioUrl" class="form-label"></label>
                <input asp-for="AudioUrl" type="hidden" />
                <div class="input-group input-group-sm mb-2">
                    <input id="poiAudioFile" type="file" class="form-control" accept="audio/*" />
                    <button type="button" id="uploadPoiAudioButton" class="btn btn-outline-primary">Tải audio</button>
                </div>
                <div id="poiAudioUploadStatus" class="small text-muted mb-2">Chọn audio từ máy để cập nhật file thuyết
                    minh.</div>
                    <span asp-validation-for="AudioUrl" class="text-danger small"></span>
                </div>
            </div>

            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mt-4">
                <a class="btn btn-admin btn-admin-soft" asp-action="Index">Quay lại</a>
                <button type="submit" class="btn btn-admin btn-admin-primary">Lưu POI</button>
            </div>
        </form>
    </div>

    <script>
        (function () {
            function ensureLeafletCss() {
                if (document.getElementById('leaflet-css')) {
                    return;
                }

                const css = document.createElement('link');
                css.id = 'leaflet-css';
                css.rel = 'stylesheet';
                css.href = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.css';
                css.crossOrigin = '';
                document.head.appendChild(css);
            }

            function ensureLeafletJs() {
                if (window.L) {
                    return Promise.resolve(window.L);
                }

                return new Promise((resolve, reject) => {
                    const existingScript = document.getElementById('leaflet-js');
                    if (existingScript) {
                        existingScript.addEventListener('load', () => resolve(window.L), { once: true });
                        existingScript.addEventListener('error', () => reject(new Error('Khong the tai Leaflet.')), { once: true });
                        return;
                    }

                    const script = document.createElement('script');
                    script.id = 'leaflet-js';
                    script.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
                    script.crossOrigin = '';
                    script.onload = () => resolve(window.L);
                    script.onerror = () => reject(new Error('Khong the tai Leaflet.'));
                    document.body.appendChild(script);
                });
            }

            function initializeCoordinateMap() {
                const mapElement = document.getElementById('poi-form-map');
                const latitudeInput = document.getElementById('Latitude');
                const longitudeInput = document.getElementById('Longitude');
                if (!mapElement || !latitudeInput || !longitudeInput) {
                    return;
                }

                const defaultLat = 10.7589;
                const defaultLng = 106.7072;

                const latValue = Number.parseFloat(latitudeInput.value);
                const lngValue = Number.parseFloat(longitudeInput.value);
                const initialLat = Number.isFinite(latValue) ? latValue : defaultLat;
                const initialLng = Number.isFinite(lngValue) ? lngValue : defaultLng;

                const map = L.map(mapElement).setView([initialLat, initialLng], 16);

                const mapboxToken = (window.__mapboxToken || '').toString().trim();
                if (mapboxToken) {
                    L.tileLayer('https://api.mapbox.com/styles/v1/{id}/tiles/{z}/{x}/{y}?access_token={accessToken}', {
                        id: 'mapbox/streets-v12',
                        tileSize: 512,
                        zoomOffset: -1,
                        accessToken: mapboxToken,
                        attribution: '&copy; OpenStreetMap contributors &copy; Mapbox'
                    }).addTo(map);
                } else {
                    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                        attribution: '&copy; OpenStreetMap contributors'
                    }).addTo(map);
                }

                const marker = L.marker([initialLat, initialLng], { draggable: true }).addTo(map);

                function setCoordinates(lat, lng) {
                    latitudeInput.value = lat.toFixed(6);
                    longitudeInput.value = lng.toFixed(6);
                }

                marker.on('dragend', function () {
                    const point = marker.getLatLng();
                    setCoordinates(point.lat, point.lng);
                });

                map.on('click', function (event) {
                    marker.setLatLng(event.latlng);
                    setCoordinates(event.latlng.lat, event.latlng.lng);
                });

                latitudeInput.addEventListener('change', function () {
                    const nextLat = Number.parseFloat(latitudeInput.value);
                    const nextLng = Number.parseFloat(longitudeInput.value);
                    if (!Number.isFinite(nextLat) || !Number.isFinite(nextLng)) {
                        return;
                    }

                    marker.setLatLng([nextLat, nextLng]);
                    map.panTo([nextLat, nextLng]);
                });

                longitudeInput.addEventListener('change', function () {
                    const nextLat = Number.parseFloat(latitudeInput.value);
                    const nextLng = Number.parseFloat(longitudeInput.value);
                    if (!Number.isFinite(nextLat) || !Number.isFinite(nextLng)) {
                        return;
                    }

                    marker.setLatLng([nextLat, nextLng]);
                    map.panTo([nextLat, nextLng]);
                });

                setTimeout(function () {
                    map.invalidateSize();
                }, 150);
            }

            ensureLeafletCss();
            ensureLeafletJs()
                .then(function () {
                    initializeCoordinateMap();
                })
                .catch(function () {
                });

            const cloudinaryCloudName = 'dmpaepela';
            const cloudinaryUploadPreset = 'zestour';
            const uploadButton = document.getElementById('uploadPoiImageButton');
            if (!uploadButton) {
                return;
            }

            uploadButton.addEventListener('click', async function () {
                const fileInput = document.getElementById('poiImageFile');
                const hiddenImageInput = document.getElementById('ImageUrl');
                const status = document.getElementById('poiImageUploadStatus');
                const preview = document.getElementById('poiImagePreview');
                const file = fileInput && fileInput.files ? fileInput.files[0] : null;

                if (!file) {
                    if (status) {
                        status.className = 'small text-danger mb-2';
                        status.textContent = 'Vui lòng chọn 1 ảnh trước khi tải.';
                    }
                    return;
                }

                uploadButton.setAttribute('disabled', 'disabled');
                if (status) {
                    status.className = 'small text-muted mb-2';
                    status.textContent = 'Đang tải ảnh lên Cloudinary...';
                }

                try {
                    const endpoint = `https://api.cloudinary.com/v1_1/${encodeURIComponent(cloudinaryCloudName)}/image/upload`;
                    const formData = new FormData();
                    formData.append('file', file);
                    formData.append('upload_preset', cloudinaryUploadPreset);
                    formData.append('folder', 'zestour/poi');

                    const response = await fetch(endpoint, {
                        method: 'POST',
                        body: formData
                    });
                    const payload = await response.json().catch(() => ({}));
                    if (!response.ok) {
                        const detail = payload && payload.error && payload.error.message
                            ? payload.error.message
                            : 'Không thể upload ảnh POI lên Cloudinary.';
                        throw new Error(detail);
                    }

                    const uploadedUrl = payload && payload.secure_url ? String(payload.secure_url).trim() : '';
                    if (!uploadedUrl) {
                        throw new Error('Không nhận được URL ảnh từ Cloudinary.');
                    }

                    if (hiddenImageInput) {
                        hiddenImageInput.value = uploadedUrl;
                    }
                    if (preview) {
                        preview.src = uploadedUrl;
                        preview.style.display = 'block';
                    }
                    if (fileInput) {
                        fileInput.value = '';
                    }
                    if (status) {
                        status.className = 'small text-success mb-2';
                        status.textContent = 'Đã cập nhật ảnh POI.';
                    }
                } catch (error) {
                    if (status) {
                        status.className = 'small text-danger mb-2';
                        status.textContent = error && error.message ? error.message : 'Không thể upload ảnh POI.';
                    }
                } finally {
                    uploadButton.removeAttribute('disabled');
                }
            });

            const uploadAudioButton = document.getElementById('uploadPoiAudioButton');
            if (!uploadAudioButton) {
                return;
            }

            uploadAudioButton.addEventListener('click', async function () {
                const fileInput = document.getElementById('poiAudioFile');
                const hiddenAudioInput = document.getElementById('AudioUrl');
                const status = document.getElementById('poiAudioUploadStatus');
                const file = fileInput && fileInput.files ? fileInput.files[0] : null;

                if (!file) {
                    if (status) {
                        status.className = 'small text-danger mb-2';
                        status.textContent = 'Vui lòng chọn 1 file audio trước khi tải.';
                    }
                    return;
                }

                uploadAudioButton.setAttribute('disabled', 'disabled');
                if (status) {
                    status.className = 'small text-muted mb-2';
                    status.textContent = 'Đang tải audio lên Cloudinary...';
                }

                try {
                    const endpoint = `https://api.cloudinary.com/v1_1/${encodeURIComponent(cloudinaryCloudName)}/auto/upload`;
                    const formData = new FormData();
                    formData.append('file', file);
                    formData.append('upload_preset', cloudinaryUploadPreset);
                    formData.append('folder', 'zestour/audio');

                    const response = await fetch(endpoint, {
                        method: 'POST',
                        body: formData
                    });
                    const payload = await response.json().catch(() => ({}));
                    if (!response.ok) {
                        const detail = payload && payload.error && payload.error.message
                            ? payload.error.message
                            : 'Không thể upload audio POI lên Cloudinary.';
                        throw new Error(detail);
                    }

                    const uploadedUrl = payload && payload.secure_url ? String(payload.secure_url).trim() : '';
                    if (!uploadedUrl) {
                        throw new Error('Không nhận được URL audio từ Cloudinary.');
                    }

                    if (hiddenAudioInput) {
                        hiddenAudioInput.value = uploadedUrl;
                    }
                    if (fileInput) {
                        fileInput.value = '';
                    }
                    if (status) {
                        status.className = 'small text-success mb-2';
                        status.textContent = 'Đã cập nhật audio POI.';
                    }
                } catch (error) {
                    if (status) {
                        status.className = 'small text-danger mb-2';
                        status.textContent = error && error.message ? error.message : 'Không thể upload audio POI.';
                    }
                } finally {
                    uploadAudioButton.removeAttribute('disabled');
                }
            });
        })();
    </script>
