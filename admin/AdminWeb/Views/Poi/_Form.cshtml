@model POI
@{
    var actionName = ViewData["ActionName"]?.ToString() ?? "Create";
}

<div class="form-panel p-4">
    <form asp-action="@actionName" method="post" class="admin-form">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <input asp-for="Id" type="hidden" />

        <div class="row g-3">
            <div class="col-lg-8">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" placeholder="Tên địa điểm" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>
            <div class="col-lg-4">
                <label asp-for="LanguageCode" class="form-label"></label>
                <input asp-for="LanguageCode" class="form-control" placeholder="vi" />
                <span asp-validation-for="LanguageCode" class="text-danger small"></span>
            </div>
            <div class="col-12">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="4" placeholder="Mô tả ngắn về địa điểm"></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>
            <div class="col-md-6 col-lg-3">
                <label asp-for="Latitude" class="form-label"></label>
                <input asp-for="Latitude" class="form-control" type="number" step="0.000001" />
                <span asp-validation-for="Latitude" class="text-danger small"></span>
            </div>
            <div class="col-md-6 col-lg-3">
                <label asp-for="Longitude" class="form-label"></label>
                <input asp-for="Longitude" class="form-control" type="number" step="0.000001" />
                <span asp-validation-for="Longitude" class="text-danger small"></span>
            </div>
            <div class="col-md-6 col-lg-3">
                <label asp-for="Radius" class="form-label"></label>
                <input asp-for="Radius" class="form-control" type="number" step="0.1" />
                <span asp-validation-for="Radius" class="text-danger small"></span>
            </div>
            <div class="col-md-6 col-lg-3">
                <label asp-for="Priority" class="form-label"></label>
                <input asp-for="Priority" class="form-control" type="number" min="1" max="10" />
                <span asp-validation-for="Priority" class="text-danger small"></span>
            </div>
            <div class="col-lg-6">
                <label asp-for="ImageUrl" class="form-label"></label>
                <input asp-for="ImageUrl" class="form-control" placeholder="https://..." />
                <span asp-validation-for="ImageUrl" class="text-danger small"></span>
            </div>
            <div class="col-lg-6">
                <label asp-for="AudioUrl" class="form-label"></label>
                <input asp-for="AudioUrl" class="form-control" placeholder="https://..." />
                <span asp-validation-for="AudioUrl" class="text-danger small"></span>
            </div>
        </div>

        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mt-4">
            <a class="btn btn-admin btn-admin-soft" asp-action="Index">Quay lại</a>
            <button type="submit" class="btn btn-admin btn-admin-primary">Lưu POI</button>
        </div>
    </form>
</div>
