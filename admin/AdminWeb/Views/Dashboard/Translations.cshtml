@model AdminWeb.Models.DashboardTranslationsViewModel
@{
    ViewData["Title"] = "Dashboard Translations";
}

<partial name="_Tabs" />

@if (TempData["AdminMessage"] is string message && !string.IsNullOrWhiteSpace(message))
{
    <div class="alert alert-success">@message</div>
}
@if (TempData["AdminError"] is string error && !string.IsNullOrWhiteSpace(error))
{
    <div class="alert alert-danger">@error</div>
}

<div class="row g-3">
    <div class="col-xl-4">
        <div class="dashboard-panel p-4 h-100">
            <h1 class="page-title">Tạo bản dịch mới</h1>
            <form asp-action="CreateTranslation" method="post" class="mt-3">
                <div class="mb-3">
                    <label class="form-label">POI</label>
                    <select class="form-select" name="poiId" required>
                        <option value="">Chọn POI</option>
                        @foreach (var poi in Model.Pois)
                        {
                            <option value="@poi.Id">@poi.Name</option>
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">Ngôn ngữ</label>
                    <input class="form-control" id="createTranslationLanguage" name="languageCode" placeholder="en" value="vi" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Tiêu đề</label>
                    <input class="form-control" name="title" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Nội dung</label>
                    <textarea class="form-control" id="createTranslationContent" name="contentText" rows="4" required></textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label">Audio URL</label>
                    <input class="form-control" id="createTranslationAudioUrl" name="audioUrl" placeholder="https://..." />
                    <div class="input-group input-group-sm mt-2">
                        <input id="createTranslationAudioFile" type="file" class="form-control" accept="audio/*" />
                        <button type="button" id="uploadCreateTranslationAudio" class="btn btn-outline-primary">Upload audio</button>
                    </div>
                    <div id="createTranslationAudioStatus" class="small text-muted mt-1">Bạn có thể upload MP3 hoặc nhập URL trực tiếp.</div>
                </div>
                <div class="d-flex gap-2 flex-wrap">
                    <button class="btn btn-admin btn-admin-soft" type="button" id="autoTranslateCreateBtn">Dịch tự động</button>
                    <button class="btn btn-admin btn-admin-soft" type="button" id="previewCreateTtsBtn">Nghe thử TTS</button>
                    <button class="btn btn-admin" type="submit">Thêm bản dịch</button>
                </div>
            </form>
        </div>
    </div>

    <div class="col-xl-8">
        <div class="dashboard-panel p-4 h-100">
            <h2 class="section-title">Danh sách bản dịch</h2>
            <form method="get" asp-action="Translations" class="row g-2 align-items-end mt-2 mb-3">
                <div class="col-lg-4">
                    <label class="form-label">POI</label>
                    <select class="form-select" name="poiId">
                        @if (!Model.PoiId.HasValue)
                        {
                            <option value="" selected>Tất cả POI</option>
                        }
                        else
                        {
                            <option value="">Tất cả POI</option>
                        }
                        @foreach (var poi in Model.Pois)
                        {
                            if (Model.PoiId == poi.Id)
                            {
                                <option value="@poi.Id" selected>@poi.Name</option>
                            }
                            else
                            {
                                <option value="@poi.Id">@poi.Name</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-lg-3">
                    <label class="form-label">Ngôn ngữ</label>
                    <select class="form-select" name="languageCode">
                        @if (string.IsNullOrWhiteSpace(Model.LanguageCode))
                        {
                            <option value="" selected>Tất cả</option>
                        }
                        else
                        {
                            <option value="">Tất cả</option>
                        }
                        @foreach (var language in Model.Languages)
                        {
                            if (string.Equals(Model.LanguageCode, language, StringComparison.OrdinalIgnoreCase))
                            {
                                <option value="@language" selected>@language.ToUpperInvariant()</option>
                            }
                            else
                            {
                                <option value="@language">@language.ToUpperInvariant()</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-lg-2">
                    <label class="form-label">Trạng thái</label>
                    <select class="form-select" name="status">
                        @if (string.IsNullOrWhiteSpace(Model.Status))
                        {
                            <option value="" selected>Tất cả</option>
                        }
                        else
                        {
                            <option value="">Tất cả</option>
                        }
                        @foreach (var s in new[] { "draft", "review", "published", "rejected" })
                        {
                            if (string.Equals(Model.Status, s, StringComparison.OrdinalIgnoreCase))
                            {
                                <option value="@s" selected>@s</option>
                            }
                            else
                            {
                                <option value="@s">@s</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-lg-2">
                    <label class="form-label">Từ khóa</label>
                    <input class="form-control" name="search" value="@Model.Search" placeholder="Title/Content" />
                </div>
                <div class="col-lg-1 d-grid">
                    <button class="btn btn-admin" type="submit">Lọc</button>
                </div>
            </form>

            @if (!Model.Translations.Any())
            {
                <p class="text-muted">Chưa có bản dịch.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-admin">
                        <thead>
                            <tr>
                                <th>POI</th>
                                <th>Lang</th>
                                <th>Title</th>
                                <th>Status</th>
                                <th>Audio</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var t in Model.Translations)
                            {
                                <tr>
                                    <td>@t.PoiId</td>
                                    <td>@t.LanguageCode</td>
                                    <td>@t.Title</td>
                                    <td>@t.Status</td>
                                    <td>
                                        @if (string.IsNullOrWhiteSpace(t.AudioUrl))
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                        else
                                        {
                                            <a href="@t.AudioUrl" target="_blank" rel="noopener noreferrer">Mở</a>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <button class="btn btn-sm btn-outline-primary" type="button" data-bs-toggle="collapse" data-bs-target="#edit-trans-@t.Id">Sửa</button>
                                        <form asp-action="DeleteTranslation" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@t.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger">Xóa</button>
                                        </form>
                                    </td>
                                </tr>
                                <tr class="collapse" id="edit-trans-@t.Id">
                                    <td colspan="6">
                                        <div class="row g-3">
                                            <div class="col-lg-8">
                                                <form asp-action="UpdateTranslation" method="post">
                                                    <input type="hidden" name="id" value="@t.Id" />
                                                    <div class="row g-2">
                                                        <div class="col-sm-4">
                                                            <label class="form-label">POI Id</label>
                                                            <input class="form-control" type="number" name="poiId" value="@t.PoiId" required />
                                                        </div>
                                                        <div class="col-sm-4">
                                                            <label class="form-label">Lang</label>
                                                            <input class="form-control" name="languageCode" value="@t.LanguageCode" required />
                                                        </div>
                                                        <div class="col-sm-4">
                                                            <label class="form-label">Title</label>
                                                            <input class="form-control" name="title" value="@t.Title" required />
                                                        </div>
                                                    </div>
                                                    <div class="mt-2">
                                                        <label class="form-label">Content</label>
                                                        <textarea class="form-control translation-content" name="contentText" rows="3" required>@t.ContentText</textarea>
                                                    </div>
                                                    <div class="mt-2">
                                                        <label class="form-label">Audio URL</label>
                                                        <input class="form-control translation-audio-url" name="audioUrl" value="@t.AudioUrl" />
                                                    </div>
                                                    <div class="d-flex gap-2 mt-2 flex-wrap">
                                                        <button type="button" class="btn btn-sm btn-outline-secondary translation-preview-tts" data-lang="@t.LanguageCode">Nghe thử TTS</button>
                                                    </div>
                                                    <button type="submit" class="btn btn-sm btn-admin mt-2">Lưu bản dịch</button>
                                                </form>
                                            </div>
                                            <div class="col-lg-4">
                                                <form asp-action="UpdateTranslationStatus" method="post">
                                                    <input type="hidden" name="id" value="@t.Id" />
                                                    <label class="form-label">Cập nhật status</label>
                                                    <select class="form-select" name="status" required>
                                                        @foreach (var status in new[] { "draft", "review", "published", "rejected" })
                                                        {
                                                            if (string.Equals(t.Status, status, StringComparison.OrdinalIgnoreCase))
                                                            {
                                                                <option value="@status" selected>@status</option>
                                                            }
                                                            else
                                                            {
                                                                <option value="@status">@status</option>
                                                            }
                                                        }
                                                    </select>
                                                    <button class="btn btn-sm btn-admin-soft mt-2" type="submit">Lưu status</button>
                                                </form>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const cloudinaryCloudName = 'dmpaepela';
            const cloudinaryUploadPreset = 'zestour';

            async function uploadAudio(file) {
                const endpoint = `https://api.cloudinary.com/v1_1/${encodeURIComponent(cloudinaryCloudName)}/auto/upload`;
                const formData = new FormData();
                formData.append('file', file);
                formData.append('upload_preset', cloudinaryUploadPreset);
                formData.append('folder', 'zestour/translations');

                const response = await fetch(endpoint, {
                    method: 'POST',
                    body: formData
                });

                const payload = await response.json().catch(() => ({}));
                if (!response.ok) {
                    const detail = payload && payload.error && payload.error.message
                        ? payload.error.message
                        : 'Không thể upload audio.';
                    throw new Error(detail);
                }

                const uploadedUrl = payload && payload.secure_url ? String(payload.secure_url).trim() : '';
                if (!uploadedUrl) {
                    throw new Error('Không nhận được URL audio.');
                }

                return uploadedUrl;
            }

            const uploadCreateAudioButton = document.getElementById('uploadCreateTranslationAudio');
            if (uploadCreateAudioButton) {
                uploadCreateAudioButton.addEventListener('click', async function () {
                    const fileInput = document.getElementById('createTranslationAudioFile');
                    const audioUrlInput = document.getElementById('createTranslationAudioUrl');
                    const status = document.getElementById('createTranslationAudioStatus');
                    const file = fileInput && fileInput.files ? fileInput.files[0] : null;
                    if (!file) {
                        if (status) {
                            status.className = 'small text-danger mt-1';
                            status.textContent = 'Vui lòng chọn file audio trước.';
                        }
                        return;
                    }

                    uploadCreateAudioButton.setAttribute('disabled', 'disabled');
                    if (status) {
                        status.className = 'small text-muted mt-1';
                        status.textContent = 'Đang upload audio...';
                    }

                    try {
                        const url = await uploadAudio(file);
                        if (audioUrlInput) {
                            audioUrlInput.value = url;
                        }
                        if (status) {
                            status.className = 'small text-success mt-1';
                            status.textContent = 'Đã upload audio thành công.';
                        }
                        if (fileInput) {
                            fileInput.value = '';
                        }
                    } catch (error) {
                        if (status) {
                            status.className = 'small text-danger mt-1';
                            status.textContent = error && error.message ? error.message : 'Upload audio thất bại.';
                        }
                    } finally {
                        uploadCreateAudioButton.removeAttribute('disabled');
                    }
                });
            }

            const autoTranslateButton = document.getElementById('autoTranslateCreateBtn');
            if (autoTranslateButton) {
                autoTranslateButton.addEventListener('click', async function () {
                    const contentInput = document.getElementById('createTranslationContent');
                    const languageInput = document.getElementById('createTranslationLanguage');
                    const text = contentInput && contentInput.value ? contentInput.value.trim() : '';
                    const target = languageInput && languageInput.value ? languageInput.value.trim().toLowerCase() : 'en';

                    if (!text) {
                        return;
                    }

                    autoTranslateButton.setAttribute('disabled', 'disabled');
                    try {
                        const response = await fetch('https://libretranslate.de/translate', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({
                                q: text,
                                source: 'vi',
                                target: target,
                                format: 'text'
                            })
                        });

                        const payload = await response.json().catch(() => ({}));
                        if (response.ok && payload && payload.translatedText && contentInput) {
                            contentInput.value = String(payload.translatedText);
                        }
                    } finally {
                        autoTranslateButton.removeAttribute('disabled');
                    }
                });
            }

            const createPreviewButton = document.getElementById('previewCreateTtsBtn');
            if (createPreviewButton) {
                createPreviewButton.addEventListener('click', function () {
                    const contentInput = document.getElementById('createTranslationContent');
                    const languageInput = document.getElementById('createTranslationLanguage');
                    const text = contentInput && contentInput.value ? contentInput.value.trim() : '';
                    const lang = languageInput && languageInput.value ? languageInput.value.trim() : 'vi-VN';
                    if (!text || !window.speechSynthesis) {
                        return;
                    }

                    const utterance = new SpeechSynthesisUtterance(text);
                    utterance.lang = lang.includes('-') ? lang : `${lang}-${lang.toUpperCase()}`;
                    window.speechSynthesis.cancel();
                    window.speechSynthesis.speak(utterance);
                });
            }

            for (const button of document.querySelectorAll('.translation-preview-tts')) {
                button.addEventListener('click', function () {
                    const wrapper = button.closest('form');
                    if (!wrapper) {
                        return;
                    }

                    const textarea = wrapper.querySelector('.translation-content');
                    const text = textarea && textarea.value ? textarea.value.trim() : '';
                    if (!text || !window.speechSynthesis) {
                        return;
                    }

                    const rawLanguage = button.getAttribute('data-lang') || 'vi';
                    const utterance = new SpeechSynthesisUtterance(text);
                    utterance.lang = rawLanguage.includes('-') ? rawLanguage : `${rawLanguage}-${rawLanguage.toUpperCase()}`;
                    window.speechSynthesis.cancel();
                    window.speechSynthesis.speak(utterance);
                });
            }
        })();
    </script>
}
