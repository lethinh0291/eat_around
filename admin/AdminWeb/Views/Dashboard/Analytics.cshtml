@model AdminWeb.Models.DashboardAnalyticsViewModel
@using System.Text.Json
@{
    ViewData["Title"] = "Dashboard Analytics";
    var heatmapJson = JsonSerializer.Serialize(Model.HeatmapPoints);
    var languageJson = JsonSerializer.Serialize(Model.LanguageRatios);
    var topPoiJson = JsonSerializer.Serialize(Model.TopPois);
}

<partial name="_Tabs" />

@if (TempData["AdminMessage"] is string message && !string.IsNullOrWhiteSpace(message))
{
    <div class="alert alert-success">@message</div>
}
@if (TempData["AdminError"] is string error && !string.IsNullOrWhiteSpace(error))
{
    <div class="alert alert-danger">@error</div>
}

<div class="dashboard-panel p-4 mb-4">
    <h1 class="page-title">Analytics</h1>
    <p class="page-subtitle">Heatmap và hành vi nghe tour theo dữ liệu thật.</p>

    <form method="get" asp-action="Analytics" class="row g-2 align-items-end mt-1">
        <div class="col-sm-4 col-lg-3">
            <label class="form-label">Từ ngày</label>
            <input class="form-control" type="date" name="fromUtc" value="@(Model.FromUtc?.ToString("yyyy-MM-dd"))" />
        </div>
        <div class="col-sm-4 col-lg-3">
            <label class="form-label">Đến ngày</label>
            <input class="form-control" type="date" name="toUtc" value="@(Model.ToUtc?.ToString("yyyy-MM-dd"))" />
        </div>
        <div class="col-sm-4 col-lg-3">
            <label class="form-label">POI</label>
            <select class="form-select" name="poiId">
                @if (!Model.PoiId.HasValue)
                {
                    <option value="" selected>Tất cả POI</option>
                }
                else
                {
                    <option value="">Tất cả POI</option>
                }
                @foreach (var poi in Model.Pois)
                {
                    if (Model.PoiId == poi.Id)
                    {
                        <option value="@poi.Id" selected>@poi.Name</option>
                    }
                    else
                    {
                        <option value="@poi.Id">@poi.Name</option>
                    }
                }
            </select>
        </div>
        <div class="col-sm-4 col-lg-2">
            <label class="form-label">Ngôn ngữ</label>
            <select class="form-select" name="languageCode">
                @if (string.IsNullOrWhiteSpace(Model.LanguageCode))
                {
                    <option value="" selected>Tất cả</option>
                }
                else
                {
                    <option value="">Tất cả</option>
                }
                @foreach (var language in Model.Languages)
                {
                    if (string.Equals(Model.LanguageCode, language, StringComparison.OrdinalIgnoreCase))
                    {
                        <option value="@language" selected>@language.ToUpperInvariant()</option>
                    }
                    else
                    {
                        <option value="@language">@language.ToUpperInvariant()</option>
                    }
                }
            </select>
        </div>
        <div class="col-sm-4 col-lg-1 d-grid">
            <button class="btn btn-admin" type="submit">Lọc</button>
        </div>
    </form>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-6 col-xl-3">
        <div class="metric-card metric-card-accent">
            <div class="metric-title">Listen Logs</div>
            <div class="metric-value">@Model.ListenLogs.Count</div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="metric-card metric-card-soft">
            <div class="metric-title">Heatmap Buckets</div>
            <div class="metric-value">@Model.HeatmapPoints.Count</div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="metric-card metric-card-neutral">
            <div class="metric-title">Top POI</div>
            <div class="metric-value">@Model.TopPois.Count</div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="metric-card metric-card-warm">
            <div class="metric-title">Ngôn ngữ</div>
            <div class="metric-value">@Model.LanguageRatios.Count</div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-xl-5">
        <div class="dashboard-panel p-4 h-100">
            <h2 class="section-title">Top POI theo lượt nghe</h2>
            @if (!Model.TopPois.Any())
            {
                <p class="text-muted">Chưa có dữ liệu.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-admin">
                        <thead>
                            <tr>
                                <th>POI</th>
                                <th class="text-end">Lượt nghe</th>
                                <th class="text-end">Tỷ lệ</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var poi in Model.TopPois)
                            {
                                <tr>
                                    <td>@poi.PoiName</td>
                                    <td class="text-end">@poi.Listens</td>
                                    <td class="text-end">@poi.Percent.ToString("0.##")%</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
    <div class="col-xl-7">
        <div class="dashboard-panel p-4 h-100">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-2">
                <h2 class="section-title">Heatmap (Top điểm nóng)</h2>
                <button type="button" id="exportAnalyticsCsv" class="btn btn-admin btn-admin-soft btn-sm">Xuất CSV</button>
            </div>
            @if (!Model.HeatmapPoints.Any())
            {
                <p class="text-muted">Chưa có dữ liệu heatmap.</p>
            }
            else
            {
                <div id="analytics-heatmap" class="poi-form-map mb-3" style="height:300px;"></div>
                <div class="table-responsive">
                    <table class="table table-admin">
                        <thead>
                            <tr>
                                <th>Vĩ độ</th>
                                <th>Kinh độ</th>
                                <th class="text-end">Lượt nghe</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var point in Model.HeatmapPoints)
                            {
                                <tr>
                                    <td>@point.Latitude.ToString("0.000000")</td>
                                    <td>@point.Longitude.ToString("0.000000")</td>
                                    <td class="text-end">@point.Count</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<div class="dashboard-panel p-4 mt-3">
    <h2 class="section-title">Tỷ lệ ngôn ngữ</h2>
    @if (!Model.LanguageRatios.Any())
    {
        <p class="text-muted">Chưa có dữ liệu ngôn ngữ.</p>
    }
    else
    {
        <div class="row g-3 mb-3">
            <div class="col-lg-6">
                <canvas id="languageRatioChart" height="240"></canvas>
            </div>
            <div class="col-lg-6">
                <canvas id="topPoiChart" height="240"></canvas>
            </div>
        </div>
        <div class="row g-2">
            @foreach (var ratio in Model.LanguageRatios)
            {
                <div class="col-md-6 col-xl-4">
                    <div class="helper-chip justify-content-between">
                        <span>@ratio.LanguageCode</span>
                        <strong>@ratio.Percent.ToString("0.##")%</strong>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="" />
    <script>
        (function () {
            const languageRatios = @Html.Raw(languageJson);
            const topPois = @Html.Raw(topPoiJson);
            const heatmapPoints = @Html.Raw(heatmapJson);

            const languageCanvas = document.getElementById('languageRatioChart');
            if (languageCanvas && Array.isArray(languageRatios) && languageRatios.length > 0) {
                new Chart(languageCanvas, {
                    type: 'pie',
                    data: {
                        labels: languageRatios.map(x => (x.languageCode || '').toUpperCase()),
                        datasets: [{
                            data: languageRatios.map(x => x.listens),
                            backgroundColor: ['#f97316', '#fb923c', '#fdba74', '#fed7aa', '#ea580c', '#9a3412']
                        }]
                    },
                    options: { responsive: true, maintainAspectRatio: false }
                });
            }

            const topPoiCanvas = document.getElementById('topPoiChart');
            if (topPoiCanvas && Array.isArray(topPois) && topPois.length > 0) {
                new Chart(topPoiCanvas, {
                    type: 'bar',
                    data: {
                        labels: topPois.map(x => x.poiName),
                        datasets: [{
                            label: 'Lượt nghe',
                            data: topPois.map(x => x.listens),
                            backgroundColor: '#fb923c',
                            borderRadius: 8
                        }]
                    },
                    options: {
                        indexAxis: 'y',
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { display: false } }
                    }
                });
            }

            const heatmapElement = document.getElementById('analytics-heatmap');
            if (heatmapElement && Array.isArray(heatmapPoints) && heatmapPoints.length > 0 && window.L) {
                const map = L.map(heatmapElement).setView([heatmapPoints[0].latitude, heatmapPoints[0].longitude], 14);
                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                    attribution: '&copy; OpenStreetMap contributors'
                }).addTo(map);

                const bounds = [];
                const maxCount = Math.max(...heatmapPoints.map(item => item.count));
                for (const point of heatmapPoints) {
                    const ratio = maxCount <= 0 ? 0 : point.count / maxCount;
                    const radius = 30 + Math.round(ratio * 90);
                    const opacity = 0.15 + ratio * 0.45;
                    const circle = L.circle([point.latitude, point.longitude], {
                        radius,
                        color: '#ea580c',
                        fillColor: '#f97316',
                        fillOpacity: opacity,
                        weight: 1
                    }).addTo(map);
                    circle.bindPopup(`Lượt nghe: ${point.count}`);
                    bounds.push([point.latitude, point.longitude]);
                }

                if (bounds.length > 1) {
                    map.fitBounds(bounds, { padding: [20, 20] });
                }
            }

            const exportButton = document.getElementById('exportAnalyticsCsv');
            if (exportButton) {
                exportButton.addEventListener('click', function () {
                    const rows = [['type', 'key', 'value', 'percent']];
                    for (const poi of topPois) {
                        rows.push(['top_poi', poi.poiName || `POI ${poi.poiId}`, String(poi.listens || 0), String(poi.percent || 0)]);
                    }
                    for (const language of languageRatios) {
                        rows.push(['language', (language.languageCode || '').toUpperCase(), String(language.listens || 0), String(language.percent || 0)]);
                    }
                    for (const point of heatmapPoints) {
                        rows.push(['heatmap', `${point.latitude},${point.longitude}`, String(point.count || 0), '']);
                    }

                    const csv = rows
                        .map(line => line.map(value => `"${String(value).replaceAll('"', '""')}"`).join(','))
                        .join('\n');
                    const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
                    const url = URL.createObjectURL(blob);
                    const link = document.createElement('a');
                    link.href = url;
                    link.download = 'analytics-report.csv';
                    document.body.appendChild(link);
                    link.click();
                    link.remove();
                    URL.revokeObjectURL(url);
                });
            }
        })();
    </script>
}
