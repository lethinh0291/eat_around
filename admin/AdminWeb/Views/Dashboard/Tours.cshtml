@model AdminWeb.Models.DashboardToursViewModel
@{
    ViewData["Title"] = "Dashboard Tours";
    var selectedPoiIds = Model.SelectedPoiIds;
}

<partial name="_Tabs" />

@if (TempData["AdminMessage"] is string message && !string.IsNullOrWhiteSpace(message))
{
    <div class="alert alert-success">@message</div>
}
@if (TempData["AdminError"] is string error && !string.IsNullOrWhiteSpace(error))
{
    <div class="alert alert-danger">@error</div>
}

<div class="row g-3">
    <div class="col-xl-4">
        <div class="dashboard-panel p-4 h-100">
            <h1 class="page-title">Tạo Tour mới</h1>
            <form asp-action="CreateTour" method="post" class="mt-3" id="createTourForm">
                <div class="mb-3">
                    <label class="form-label">Tên tour</label>
                    <input class="form-control" name="name" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Mô tả</label>
                    <textarea class="form-control" name="description" rows="3"></textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label">Ảnh bìa</label>
                    <input class="form-control" name="coverImageUrl" placeholder="https://..." />
                </div>
                <div class="row g-2">
                    <div class="col-md-6">
                        <label class="form-label">POI khả dụng</label>
                        <select id="createTourAvailable" class="form-select" size="7" multiple>
                            @foreach (var poi in Model.Pois)
                            {
                                <option value="@poi.Id">@poi.Name (P@poi.Priority)</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Thứ tự tham quan</label>
                        <select id="createTourSelected" class="form-select" size="7" multiple></select>
                    </div>
                </div>
                <div class="d-flex gap-2 mt-2 flex-wrap">
                    <button class="btn btn-admin btn-admin-soft btn-sm" type="button" id="createTourAddPoi">Thêm POI</button>
                    <button class="btn btn-admin btn-admin-soft btn-sm" type="button" id="createTourRemovePoi">Bỏ POI</button>
                    <button class="btn btn-admin btn-admin-soft btn-sm" type="button" id="createTourMoveUp">Lên</button>
                    <button class="btn btn-admin btn-admin-soft btn-sm" type="button" id="createTourMoveDown">Xuống</button>
                </div>
                <div id="createTourHiddenPoiIds"></div>
                <div class="form-check form-switch mb-3">
                    <input class="form-check-input" type="checkbox" name="isActive" value="true" id="tour-active-create" checked />
                    <label class="form-check-label" for="tour-active-create">Active</label>
                </div>
                <button class="btn btn-admin" type="submit">Thêm Tour</button>
            </form>
        </div>
    </div>

    <div class="col-xl-8">
        <div class="dashboard-panel p-4 h-100">
            <h2 class="section-title">Danh sách Tour</h2>
            @if (!Model.Tours.Any())
            {
                <p class="text-muted">Chưa có tour.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-admin">
                        <thead>
                            <tr>
                                <th>Tên tour</th>
                                <th>Ảnh bìa</th>
                                <th>Active</th>
                                <th class="text-end">Stops</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var tour in Model.Tours)
                            {
                                <tr>
                                    <td>@tour.Name</td>
                                    <td>@(string.IsNullOrWhiteSpace(tour.CoverImageUrl) ? "-" : "Có")</td>
                                    <td>
                                        @if (tour.IsActive)
                                        {
                                            <span class="badge bg-success">Yes</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">No</span>
                                        }
                                    </td>
                                    <td class="text-end">@tour.StopCount</td>
                                    <td class="text-end">
                                        <button class="btn btn-sm btn-outline-primary" type="button" data-bs-toggle="collapse" data-bs-target="#edit-tour-@tour.Id">Sửa</button>
                                        <button class="btn btn-sm btn-outline-secondary" type="button" onclick="downloadTourQr(@tour.Id, '@tour.Name')">QR Tour</button>
                                        <form asp-action="DeleteTour" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@tour.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger">Xóa</button>
                                        </form>
                                    </td>
                                </tr>
                                <tr class="collapse" id="edit-tour-@tour.Id">
                                    <td colspan="5">
                                        <div class="row g-3">
                                            <div class="col-lg-6">
                                                <form asp-action="UpdateTour" method="post">
                                                    <input type="hidden" name="id" value="@tour.Id" />
                                                    <div class="mb-2">
                                                        <label class="form-label">Tên tour</label>
                                                        <input class="form-control" name="name" value="@tour.Name" required />
                                                    </div>
                                                    <div class="mb-2">
                                                        <label class="form-label">Mô tả</label>
                                                        <textarea class="form-control" name="description" rows="2">@tour.Description</textarea>
                                                    </div>
                                                    <div class="mb-2">
                                                        <label class="form-label">Ảnh bìa</label>
                                                        <input class="form-control" name="coverImageUrl" value="@tour.CoverImageUrl" />
                                                    </div>
                                                    <div class="form-check form-switch mb-2">
                                                        <input class="form-check-input" type="checkbox" name="isActive" value="true" @(tour.IsActive ? "checked" : null) id="tour-active-@tour.Id" />
                                                        <label class="form-check-label" for="tour-active-@tour.Id">Active</label>
                                                    </div>
                                                    <button type="submit" class="btn btn-sm btn-admin">Lưu tour</button>
                                                </form>
                                            </div>
                                            <div class="col-lg-6">
                                                <form asp-action="SaveTourStops" method="post">
                                                    <input type="hidden" name="id" value="@tour.Id" />
                                                    <label class="form-label">Sắp xếp điểm dừng</label>
                                                    @if (Model.SelectedTour?.Id == tour.Id)
                                                    {
                                                        <div class="row g-2">
                                                            <div class="col-6">
                                                                <select class="form-select tour-available" size="7" multiple data-tour-id="@tour.Id">
                                                                    @foreach (var poi in Model.Pois.Where(p => !selectedPoiIds.Contains(p.Id)))
                                                                    {
                                                                        <option value="@poi.Id">@poi.Name (P@poi.Priority)</option>
                                                                    }
                                                                </select>
                                                            </div>
                                                            <div class="col-6">
                                                                <select class="form-select tour-selected" size="7" multiple data-tour-id="@tour.Id">
                                                                    @foreach (var stop in Model.SelectedTour.Stops.OrderBy(s => s.SortOrder))
                                                                    {
                                                                        <option value="@stop.PoiId">@stop.SortOrder. @stop.PoiName</option>
                                                                    }
                                                                </select>
                                                            </div>
                                                        </div>
                                                        <div class="d-flex gap-2 mt-2 flex-wrap">
                                                            <button type="button" class="btn btn-admin btn-admin-soft btn-sm" onclick="movePoiToSelected(@tour.Id)">Thêm</button>
                                                            <button type="button" class="btn btn-admin btn-admin-soft btn-sm" onclick="removePoiFromSelected(@tour.Id)">Bỏ</button>
                                                            <button type="button" class="btn btn-admin btn-admin-soft btn-sm" onclick="movePoiOrder(@tour.Id, -1)">Lên</button>
                                                            <button type="button" class="btn btn-admin btn-admin-soft btn-sm" onclick="movePoiOrder(@tour.Id, 1)">Xuống</button>
                                                        </div>
                                                        <div class="tour-hidden-poi-ids" data-tour-id="@tour.Id"></div>
                                                        <input type="hidden" name="stopsCsv" value="" />
                                                    }
                                                    else
                                                    {
                                                        <div class="small text-muted mb-2">Chọn tour này để chỉnh thứ tự bằng UI.</div>
                                                        <a asp-action="Tours" asp-route-selectedTourId="@tour.Id" class="btn btn-admin btn-admin-soft btn-sm">Chọn tour</a>
                                                    }
                                                    <button type="submit" class="btn btn-sm btn-admin-soft mt-2">Lưu stops</button>
                                                </form>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/qrcode@1.5.4/build/qrcode.min.js"></script>
    <script>
        (function () {
            function buildHiddenPoiInputs(container, selected) {
                container.innerHTML = '';
                for (const option of selected.options) {
                    const hidden = document.createElement('input');
                    hidden.type = 'hidden';
                    hidden.name = 'poiIds';
                    hidden.value = option.value;
                    container.appendChild(hidden);
                }
            }

            function moveSelected(source, target) {
                const selectedItems = Array.from(source.selectedOptions);
                for (const option of selectedItems) {
                    target.appendChild(option);
                }
            }

            function reorderSelected(selectElement, direction) {
                const selectedItems = Array.from(selectElement.selectedOptions);
                if (selectedItems.length !== 1) {
                    return;
                }

                const option = selectedItems[0];
                const options = Array.from(selectElement.options);
                const index = options.indexOf(option);
                const nextIndex = index + direction;
                if (nextIndex < 0 || nextIndex >= options.length) {
                    return;
                }

                if (direction < 0) {
                    selectElement.insertBefore(option, options[nextIndex]);
                } else {
                    selectElement.insertBefore(options[nextIndex], option);
                }
                option.selected = true;
            }

            const createAvailable = document.getElementById('createTourAvailable');
            const createSelected = document.getElementById('createTourSelected');
            const createHidden = document.getElementById('createTourHiddenPoiIds');
            const createForm = document.getElementById('createTourForm');

            if (createAvailable && createSelected && createHidden && createForm) {
                document.getElementById('createTourAddPoi')?.addEventListener('click', function () {
                    moveSelected(createAvailable, createSelected);
                    buildHiddenPoiInputs(createHidden, createSelected);
                });

                document.getElementById('createTourRemovePoi')?.addEventListener('click', function () {
                    moveSelected(createSelected, createAvailable);
                    buildHiddenPoiInputs(createHidden, createSelected);
                });

                document.getElementById('createTourMoveUp')?.addEventListener('click', function () {
                    reorderSelected(createSelected, -1);
                    buildHiddenPoiInputs(createHidden, createSelected);
                });

                document.getElementById('createTourMoveDown')?.addEventListener('click', function () {
                    reorderSelected(createSelected, 1);
                    buildHiddenPoiInputs(createHidden, createSelected);
                });

                createForm.addEventListener('submit', function () {
                    buildHiddenPoiInputs(createHidden, createSelected);
                });
            }

            window.movePoiToSelected = function (tourId) {
                const available = document.querySelector(`select.tour-available[data-tour-id="${tourId}"]`);
                const selected = document.querySelector(`select.tour-selected[data-tour-id="${tourId}"]`);
                const hiddenContainer = document.querySelector(`div.tour-hidden-poi-ids[data-tour-id="${tourId}"]`);
                if (!available || !selected || !hiddenContainer) {
                    return;
                }

                moveSelected(available, selected);
                buildHiddenPoiInputs(hiddenContainer, selected);
            };

            window.removePoiFromSelected = function (tourId) {
                const available = document.querySelector(`select.tour-available[data-tour-id="${tourId}"]`);
                const selected = document.querySelector(`select.tour-selected[data-tour-id="${tourId}"]`);
                const hiddenContainer = document.querySelector(`div.tour-hidden-poi-ids[data-tour-id="${tourId}"]`);
                if (!available || !selected || !hiddenContainer) {
                    return;
                }

                moveSelected(selected, available);
                buildHiddenPoiInputs(hiddenContainer, selected);
            };

            window.movePoiOrder = function (tourId, direction) {
                const selected = document.querySelector(`select.tour-selected[data-tour-id="${tourId}"]`);
                const hiddenContainer = document.querySelector(`div.tour-hidden-poi-ids[data-tour-id="${tourId}"]`);
                if (!selected || !hiddenContainer) {
                    return;
                }

                reorderSelected(selected, direction);
                buildHiddenPoiInputs(hiddenContainer, selected);
            };

            for (const hiddenContainer of document.querySelectorAll('div.tour-hidden-poi-ids')) {
                const tourId = hiddenContainer.getAttribute('data-tour-id');
                const selected = document.querySelector(`select.tour-selected[data-tour-id="${tourId}"]`);
                if (selected) {
                    buildHiddenPoiInputs(hiddenContainer, selected);
                }
            }

            window.downloadTourQr = async function (tourId, tourName) {
                const payload = JSON.stringify({
                    type: 'tour',
                    tourId: tourId,
                    deepLink: `zestour://tour/${tourId}`,
                    webLink: `${window.location.origin}/Dashboard/Tours?selectedTourId=${tourId}`
                });

                const canvas = document.createElement('canvas');
                await QRCode.toCanvas(canvas, payload, {
                    width: 360,
                    margin: 1,
                    color: {
                        dark: '#111827',
                        light: '#ffffff'
                    }
                });

                const link = document.createElement('a');
                link.href = canvas.toDataURL('image/png');
                link.download = `tour-${tourId}-${(tourName || 'tour').replaceAll(' ', '-').toLowerCase()}.png`;
                document.body.appendChild(link);
                link.click();
                link.remove();
            };
        })();
    </script>
}
