@model AdminWeb.Models.DashboardLogsViewModel
@{
    ViewData["Title"] = "Dashboard Logs";
}

<partial name="_Tabs" />

@if (TempData["AdminMessage"] is string message && !string.IsNullOrWhiteSpace(message))
{
    <div class="alert alert-success">@message</div>
}
@if (TempData["AdminError"] is string error && !string.IsNullOrWhiteSpace(error))
{
    <div class="alert alert-danger">@error</div>
}

<div class="row g-3">
    <div class="col-xl-5">
        <div class="dashboard-panel p-4 h-100">
            <h1 class="page-title">System Logs</h1>
            <p class="page-subtitle">Tạo log vận hành để theo dõi trạng thái hệ thống.</p>

            <form asp-action="CreateSystemLog" method="post" class="mt-3">
                <div class="mb-3">
                    <label class="form-label">Mức độ</label>
                    <select class="form-select" name="level" required>
                        <option value="Info">Info</option>
                        <option value="Warning">Warning</option>
                        <option value="Error">Error</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">Nguồn</label>
                    <input class="form-control" name="source" placeholder="AdminWeb" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Nội dung</label>
                    <textarea class="form-control" name="message" rows="3" required></textarea>
                </div>
                <button class="btn btn-admin" type="submit">Thêm System Log</button>
            </form>
        </div>
    </div>

    <div class="col-xl-7">
        <div class="dashboard-panel p-4 h-100">
            <h2 class="section-title">Danh sách System Logs</h2>
            @if (!Model.SystemLogs.Any())
            {
                <p class="text-muted">Chưa có system logs.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-admin">
                        <thead>
                            <tr>
                                <th>Thời gian</th>
                                <th>Level</th>
                                <th>Source</th>
                                <th>Nội dung</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var log in Model.SystemLogs)
                            {
                                <tr>
                                    <td>@log.CreatedAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                    <td><span class="badge bg-secondary">@log.Level</span></td>
                                    <td>@log.Source</td>
                                    <td>@log.Message</td>
                                    <td class="text-end">
                                        <form asp-action="DeleteSystemLog" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@log.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger">Xóa</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<div class="dashboard-panel p-4 mt-3">
    <h2 class="section-title">Listen Logs gần đây</h2>
    <form method="get" asp-action="Logs" class="row g-2 align-items-end mt-2 mb-3">
        <div class="col-lg-3">
            <label class="form-label">Tìm kiếm</label>
            <input class="form-control" name="search" value="@Model.Search" placeholder="Device, POI, language..." />
        </div>
        <div class="col-lg-3">
            <label class="form-label">POI</label>
            <select class="form-select" name="poiId">
                @if (!Model.PoiId.HasValue)
                {
                    <option value="" selected>Tất cả</option>
                }
                else
                {
                    <option value="">Tất cả</option>
                }
                @foreach (var poi in Model.Pois)
                {
                    if (Model.PoiId == poi.Id)
                    {
                        <option value="@poi.Id" selected>@poi.Name</option>
                    }
                    else
                    {
                        <option value="@poi.Id">@poi.Name</option>
                    }
                }
            </select>
        </div>
        <div class="col-lg-2">
            <label class="form-label">Ngôn ngữ</label>
            <select class="form-select" name="languageCode">
                @if (string.IsNullOrWhiteSpace(Model.LanguageCode))
                {
                    <option value="" selected>Tất cả</option>
                }
                else
                {
                    <option value="">Tất cả</option>
                }
                @foreach (var language in Model.Languages)
                {
                    if (string.Equals(Model.LanguageCode, language, StringComparison.OrdinalIgnoreCase))
                    {
                        <option value="@language" selected>@language.ToUpperInvariant()</option>
                    }
                    else
                    {
                        <option value="@language">@language.ToUpperInvariant()</option>
                    }
                }
            </select>
        </div>
        <div class="col-lg-2">
            <label class="form-label">Loại nội dung</label>
            <select class="form-select" name="contentType">
                @if (string.IsNullOrWhiteSpace(Model.ContentType))
                {
                    <option value="" selected>Tất cả</option>
                }
                else
                {
                    <option value="">Tất cả</option>
                }
                @if (string.Equals(Model.ContentType, "audio", StringComparison.OrdinalIgnoreCase))
                {
                    <option value="audio" selected>Audio</option>
                }
                else
                {
                    <option value="audio">Audio</option>
                }
                @if (string.Equals(Model.ContentType, "tts", StringComparison.OrdinalIgnoreCase))
                {
                    <option value="tts" selected>TTS</option>
                }
                else
                {
                    <option value="tts">TTS</option>
                }
            </select>
        </div>
        <div class="col-lg-2 d-flex gap-2">
            <button class="btn btn-admin" type="submit">Lọc</button>
            <button id="exportListenLogsCsv" class="btn btn-admin btn-admin-soft" type="button">CSV</button>
        </div>
    </form>

    @if (!Model.FilteredListenLogs.Any())
    {
        <p class="text-muted">Chưa có listen logs.</p>
    }
    else
    {
        <div class="table-responsive">
            <table id="listenLogsTable" class="table table-admin">
                <thead>
                    <tr>
                        <th>Thời gian</th>
                        <th>POI</th>
                        <th>Device</th>
                        <th>Ngôn ngữ</th>
                        <th>Loại</th>
                        <th>Vị trí</th>
                        <th class="text-end">Giây nghe</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.FilteredListenLogs)
                    {
                        <tr>
                            <td>@item.PlayedAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@item.PoiId</td>
                            <td>@item.DeviceId</td>
                            <td>@item.LanguageCode</td>
                            <td>@item.ContentType</td>
                            <td>@item.Latitude.ToString("0.0000"), @item.Longitude.ToString("0.0000")</td>
                            <td class="text-end">@item.DurationSeconds</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@section Scripts {
    <script>
        (function () {
            const button = document.getElementById('exportListenLogsCsv');
            if (!button) {
                return;
            }

            button.addEventListener('click', function () {
                const rows = [];
                rows.push(['played_at_local', 'poi_id', 'device_id', 'language_code', 'content_type', 'latitude', 'longitude', 'duration_seconds']);
                const bodyRows = document.querySelectorAll('#listenLogsTable tbody tr');
                for (const row of bodyRows) {
                    const cells = Array.from(row.querySelectorAll('td')).map(cell => (cell.textContent || '').trim());
                    if (cells.length >= 7) {
                        rows.push(cells);
                    }
                }

                const csv = rows
                    .map(line => line.map(value => `"${String(value).replaceAll('"', '""')}"`).join(','))
                    .join('\n');

                const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
                const url = URL.createObjectURL(blob);
                const link = document.createElement('a');
                link.href = url;
                link.download = 'listen-logs.csv';
                document.body.appendChild(link);
                link.click();
                link.remove();
                URL.revokeObjectURL(url);
            });
        })();
    </script>
}
