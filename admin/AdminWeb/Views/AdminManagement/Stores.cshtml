                                            function wireStoreRegistrationEditModal() {
                                            const modalElement = document.getElementById('editStoreRegistrationModal');
                                            if (!modalElement) {
                                            return;
                                            }

                                            modalElement.addEventListener('show.bs.modal', function (event) {
                                            const trigger = event.relatedTarget;
                                            if (!trigger) {
                                            return;
                                            }

                                            document.getElementById('editStoreId').value = trigger.getAttribute('data-store-id') || '';
                                            document.getElementById('editStoreName').value = trigger.getAttribute('data-store-name') || '';
                                            document.getElementById('editOwnerName').value = trigger.getAttribute('data-owner-name') || '';
                                            document.getElementById('editPhone').value = trigger.getAttribute('data-phone') || '';
                                            document.getElementById('editAddress').value = trigger.getAttribute('data-address') || '';
                                            document.getElementById('editCategory').value = trigger.getAttribute('data-category') || '';
                                            document.getElementById('editDescription').value = trigger.getAttribute('data-description') || '';

                                            let imageUrls = [];
                                            const imageUrlsRaw = trigger.getAttribute('data-image-urls') || '[]';
                                            const primaryImageUrl = (trigger.getAttribute('data-image-url') || '').trim();
                                            try {
                                            imageUrls = JSON.parse(imageUrlsRaw);
                                            } catch {
                                            imageUrls = [];
                                            }

                                            if (!Array.isArray(imageUrls) || imageUrls.length === 0) {
                                            const fallbackImageUrl = primaryImageUrl;
                                            imageUrls = fallbackImageUrl ? [fallbackImageUrl] : [];
                                            }

                                            setStoreRegistrationImageUrls(imageUrls);
                                            const primaryInput = document.getElementById('editStorePrimaryImageUrl');
                                            if (primaryInput) {
                                            primaryInput.value = primaryImageUrl || getStoreRegistrationPrimaryImageUrl();
                                            }
                                            updateStoreRegistrationRowStates();
                                            updateStoreRegistrationImagePreviews();

                                            const fileInput = document.getElementById('storeImageFiles');
                                            if (fileInput) {
                                            fileInput.value = '';
                                            }

                                            const status = document.getElementById('storeImageUploadStatus');
                                            if (status) {
                                            status.className = 'small text-muted mb-2';
                                            status.textContent = 'Chọn ảnh từ máy rồi bấm Tải ảnh đã chọn.';
                                            }
                                            });
                                            }

                                            wireRestaurantEditModal();
                                            wireStoreRegistrationEditModal();

                                            const uploadStoreImagesButton = document.getElementById('uploadStoreImagesButton');
                                            if (uploadStoreImagesButton) {
                                            uploadStoreImagesButton.addEventListener('click', async function () {
                                            const fileInput = document.getElementById('storeImageFiles');
                                            const status = document.getElementById('storeImageUploadStatus');
                                            const files = fileInput && fileInput.files ? Array.from(fileInput.files) : [];

                                            if (files.length === 0) {
                                            if (status) {
                                            status.className = 'small text-danger mb-2';
                                            status.textContent = 'Vui lòng chọn ít nhất 1 ảnh.';
                                            }
                                            return;
                                            }

                                            uploadStoreImagesButton.setAttribute('disabled', 'disabled');
                                            if (status) {
                                            status.className = 'small text-muted mb-2';
                                            status.textContent = 'Đang tải ảnh lên Cloudinary...';
                                            }

                                            let added = 0;
                                            try {
                                            for (const file of files) {
                                            const uploadedUrl = await uploadStoreImageToCloudinary(file);
                                            const beforeCount = getStoreRegistrationRows().length;
                                            appendStoreImageUrl(uploadedUrl);
                                            const afterCount = getStoreRegistrationRows().length;
                                            if (afterCount > beforeCount) {
                                            added += 1;
                                            }
                                            }

                                            if (fileInput) {
                                            fileInput.value = '';
                                            }

                                            if (status) {
                                            status.className = 'small text-success mb-2';
                                            status.textContent = added > 0
                                            ? `Đã thêm ${added} ảnh từ máy.`
                                            : 'Ảnh đã tồn tại trong danh sách, không thêm mới.';
                                            }
                                            } catch (error) {
                                            if (status) {
                                            status.className = 'small text-danger mb-2';
                                            status.textContent = error && error.message ? error.message : 'Không thể upload ảnh lên Cloudinary.';
                                            }
