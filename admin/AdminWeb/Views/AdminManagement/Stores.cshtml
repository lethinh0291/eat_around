                                            const uploadRestaurantAudioButton = document.getElementById('uploadRestaurantAudioButton');
                                            if (uploadRestaurantAudioButton) {
                                            uploadRestaurantAudioButton.addEventListener('click', async function () {
                                            const fileInput = document.getElementById('restaurantAudioFile');
                                            const audioInput = document.getElementById('editRestaurantAudioUrl');
                                            const status = document.getElementById('restaurantAudioUploadStatus');
                                            const file = fileInput && fileInput.files ? fileInput.files[0] : null;

                                            if (!file) {
                                            if (status) {
                                            status.className = 'small text-danger';
                                            status.textContent = 'Vui lòng chọn 1 file audio trước khi tải.';
                                            }
                                            return;
                                            }

                                            uploadRestaurantAudioButton.setAttribute('disabled', 'disabled');
                                            if (status) {
                                            status.className = 'small text-muted';
                                            status.textContent = 'Đang tải audio lên Cloudinary...';
                                            }

                                            try {
                                            const uploadedUrl = await uploadStoreAudioToCloudinary(file);
                                            if (audioInput) {
                                            audioInput.value = uploadedUrl;
                                            }
                                            if (fileInput) {
                                            fileInput.value = '';
                                            }

                                            if (status) {
                                            status.className = 'small text-success';
                                            status.textContent = 'Đã cập nhật audio.';
                                            }
                                            } catch (error) {
                                            if (status) {
                                            status.className = 'small text-danger';
                                            status.textContent = error && error.message ? error.message : 'Không thể upload audio.';
