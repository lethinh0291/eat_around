                                            const uploadRestaurantImageButton = document.getElementById('uploadRestaurantImageButton');
                                            if (uploadRestaurantImageButton) {
                                            uploadRestaurantImageButton.addEventListener('click', async function () {
                                            const fileInput = document.getElementById('restaurantImageFile');
                                            const imageInput = document.getElementById('editRestaurantImageUrl');
                                            const status = document.getElementById('restaurantImageUploadStatus');
                                            const file = fileInput && fileInput.files ? fileInput.files[0] : null;

                                            if (!file) {
                                            if (status) {
                                            status.className = 'small text-danger';
                                            status.textContent = 'Vui lòng chọn 1 ảnh trước khi tải.';
                                            }
                                            return;
                                            }

                                            uploadRestaurantImageButton.setAttribute('disabled', 'disabled');
                                            if (status) {
                                            status.className = 'small text-muted';
                                            status.textContent = 'Đang tải ảnh lên Cloudinary...';
                                            }

                                            try {
                                            const uploadedUrl = await uploadStoreImageToCloudinary(file);
                                            if (imageInput) {
                                            imageInput.value = uploadedUrl;
                                            }
                                            setRestaurantImagePreview(uploadedUrl);
                                            if (fileInput) {
                                            fileInput.value = '';
                                            }

                                            if (status) {
                                            status.className = 'small text-success';
                                            status.textContent = 'Đã cập nhật ảnh review.';
                                            }
                                            } catch (error) {
                                            if (status) {
                                            status.className = 'small text-danger';
                                            status.textContent = error && error.message ? error.message : 'Không thể upload ảnh.';
                                            }
                                            } finally {
                                            uploadRestaurantImageButton.removeAttribute('disabled');
