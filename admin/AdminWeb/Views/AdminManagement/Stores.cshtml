@model AdminWeb.Models.AdminStoresViewModel
@using System.Text.Json
@using System.Text.RegularExpressions
@using System.Linq
@{
    ViewData["Title"] = "Quản lý Quán Ăn";

    var registeredRestaurantsMapData = Model.Restaurants
        .Select(item => new
        {
            id = item.Id,
            name = string.IsNullOrWhiteSpace(item.Name) ? "Quán ăn" : item.Name,
            lat = item.Latitude,
            lng = item.Longitude,
            radius = item.Radius
        })
        .ToList();

    var registeredRestaurantsJson = JsonSerializer.Serialize(registeredRestaurantsMapData);
}

<div class="admin-card mb-4">
    <div>
        <h1 class="h4 mb-1">Quản lý quán ăn</h1>
        <p class="text-muted mb-0">Thêm, sửa, xóa quán trên map và duyệt danh sách gửi đăng ký quán ăn.</p>
    </div>
</div>

@if (TempData["AdminMessage"] is string ok)
{
    <div class="alert alert-success">@ok</div>
}

@if (TempData["AdminError"] is string err)
{
    <div class="alert alert-danger">@err</div>
}

<div class="admin-card mb-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="h5 mb-0">Quán ăn đã lên map</h2>
        <a class="btn btn-sm btn-outline-primary" asp-controller="Poi" asp-action="Create">Thêm quán mới</a>
    </div>
    <div class="table-responsive">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Tên quán</th>
                    <th>Ảnh review</th>
                    <th>Tên đường</th>
                    <th>Mô tả</th>
                    <th>Tọa độ</th>
                    <th>Bán kính / Ưu tiên</th>
                    <th class="text-end">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Restaurants.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted">Chưa có quán nào trên map.</td>
                    </tr>
                }
                else
                {
                    foreach (var restaurant in Model.Restaurants)
                    {
                        var streetName = "Chưa có";
                        var addressMatch = Regex.Match(restaurant.Description ?? string.Empty, @"Địa chỉ:\s*([^|]+)",
                RegexOptions.IgnoreCase);
                        if (addressMatch.Success)
                        {
                            streetName = addressMatch.Groups[1].Value.Trim();
                        }

                        <tr>
                            <td>@restaurant.Id</td>
                            <td>@restaurant.Name</td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(restaurant.ImageUrl))
                                {
                                    <div class="d-flex align-items-center gap-2">
                                        <img src="@restaurant.ImageUrl" alt="Ảnh quán"
                                             style="width:72px;height:54px;object-fit:cover;border-radius:8px;border:1px solid #e5e7eb;" />
                                        <a class="btn btn-sm btn-outline-secondary" href="@restaurant.ImageUrl" target="_blank"
                                           rel="noopener noreferrer">Xem</a>
                                    </div>
                                }
                                else
                                {
                                    <span class="text-muted small">Chưa có ảnh</span>
                                }
                            </td>
                            <td>
                                <span class="small text-muted">@streetName</span>
                            </td>
                            <td>
                                @if (string.IsNullOrWhiteSpace(restaurant.Description))
                                {
                                    <span class="text-muted small">Không có mô tả</span>
                                }
                                else
                                {
                                    <span>@restaurant.Description</span>
                                }
                            </td>
                            <td>
                                <div class="small">
                                    <div>Lat: @restaurant.Latitude.ToString("0.######",
                                                                                                                System.Globalization.CultureInfo.InvariantCulture)</div>
                                        <div>Lng: @restaurant.Longitude.ToString("0.######",
                                                                                                                        System.Globalization.CultureInfo.InvariantCulture)</div>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="small">
                                            <div>Bán kính: @restaurant.Radius.ToString("0.##",
                                                                                                                                System.Globalization.CultureInfo.InvariantCulture)m</div>
                                                <div>Ưu tiên: @restaurant.Priority | Ngôn ngữ: @restaurant.LanguageCode</div>
                                            </div>
                                        </td>
                                        <td class="text-end">
                                            <div class="d-flex justify-content-end gap-2">
                                                <button type="button" class="btn btn-sm btn-outline-primary" data-bs-toggle="modal"
                                                        data-bs-target="#editRestaurantModal" data-restaurant-id="@restaurant.Id"
                                                        data-name="@restaurant.Name" data-description="@restaurant.Description"
                                                        data-image-url="@restaurant.ImageUrl" data-audio-url="@restaurant.AudioUrl"
                                                        data-latitude="@restaurant.Latitude.ToString("0.######", System.Globalization.CultureInfo.InvariantCulture)"
                                                        data-longitude="@restaurant.Longitude.ToString("0.######", System.Globalization.CultureInfo.InvariantCulture)"
                                                        data-radius="@restaurant.Radius.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)"
                                                        data-priority="@restaurant.Priority" data-language-code="@restaurant.LanguageCode">
                                                    Chỉnh sửa
                                                </button>
                                                <form asp-action="DeleteRestaurant" method="post"
                                                      onsubmit="return confirm('Xóa quán này khỏi map?');">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@restaurant.Id" />
                                                    <button type="submit" class="btn btn-sm btn-outline-danger">Xóa</button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="modal fade" id="editRestaurantModal" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
                    <div class="modal-content">
                        <form asp-action="UpdateRestaurant" method="post">
                            @Html.AntiForgeryToken()
                            <div class="modal-header">
                                <h5 class="modal-title">Chỉnh sửa quán ăn trên map</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                            </div>
                            <div class="modal-body">
                                <input type="hidden" id="editRestaurantId" name="Id" />

                                <div class="mb-3">
                                    <label for="editRestaurantName" class="form-label">Tên quán</label>
                                    <input id="editRestaurantName" type="text" name="Name" class="form-control" required />
                                </div>

                                <div class="mb-3">
                                    <label for="editRestaurantDescription" class="form-label">Mô tả</label>
                                    <textarea id="editRestaurantDescription" name="Description" rows="3"
                                              class="form-control"></textarea>
                                </div>

                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label for="editRestaurantLatitude" class="form-label">Vĩ độ</label>
                                        <input id="editRestaurantLatitude" type="number" step="0.000001" name="Latitude"
                                               class="form-control" required />
                                    </div>
                                    <div class="col-md-6">
                                        <label for="editRestaurantLongitude" class="form-label">Kinh độ</label>
                                        <input id="editRestaurantLongitude" type="number" step="0.000001" name="Longitude"
                                               class="form-control" required />
                                    </div>
                                </div>

                                <div class="mt-3">
                                    <button type="button" class="btn btn-sm btn-outline-primary"
                                            onclick="openMapPicker('editRestaurantLatitude','editRestaurantLongitude')">Chọn vị trí trên
                                        map</button>
                                    </div>

                                    <div class="row g-3 mt-1">
                                        <div class="col-md-4">
                                            <label for="editRestaurantRadius" class="form-label">Bán kính (m)</label>
                                            <input id="editRestaurantRadius" type="number" step="0.1" min="1" max="1000" name="Radius"
                                                   class="form-control" required />
                                        </div>
                                        <div class="col-md-4">
                                            <label for="editRestaurantPriority" class="form-label">Ưu tiên</label>
                                            <input id="editRestaurantPriority" type="number" min="1" max="10" name="Priority"
                                                   class="form-control" required />
                                        </div>
                                        <div class="col-md-4">
                                            <label for="editRestaurantLanguageCode" class="form-label">Ngôn ngữ</label>
                                            <input id="editRestaurantLanguageCode" type="text" name="LanguageCode" class="form-control"
                                                   required />
                                        </div>
                                    </div>

                                    <div class="mt-3">
                                        <label class="form-label">Ảnh review</label>
                                        <input id="editRestaurantImageUrl" type="hidden" name="ImageUrl" />
                                        <div class="input-group input-group-sm mb-2">
                                            <input id="restaurantImageFile" type="file" class="form-control" accept="image/*" />
                                            <button type="button" id="uploadRestaurantImageButton" class="btn btn-outline-primary">Tải ảnh</button>
                                        </div>
                                        <div id="restaurantImageUploadStatus" class="small text-muted">Chọn ảnh từ máy để thay ảnh review.</div>
                                    </div>

                                    <div class="mt-3">
                                        <label class="form-label">Audio</label>
                                        <input id="editRestaurantAudioUrl" type="hidden" name="AudioUrl" />
                                        <div class="input-group input-group-sm mb-2">
                                            <input id="restaurantAudioFile" type="file" class="form-control" accept="audio/*" />
                                            <button type="button" id="uploadRestaurantAudioButton" class="btn btn-outline-primary">Tải audio</button>
                                        </div>
                                        <div id="restaurantAudioUploadStatus" class="small text-muted">Chọn file audio từ máy để cập nhật.</div>
                                    </div>

                                    <div class="mt-3">
                                        <div class="small text-muted mb-2">Xem trước ảnh review</div>
                                        <img id="editRestaurantImagePreview" src="" alt="Xem trước ảnh quán"
                                             style="width:100%;max-height:260px;object-fit:cover;border-radius:10px;border:1px solid #e5e7eb;display:none;" />
                                        <div id="editRestaurantImagePreviewEmpty" class="small text-muted">Chưa có ảnh để xem trước.
                                        </div>
                                    </div>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Hủy</button>
                                    <button type="submit" class="btn btn-primary">Lưu chỉnh sửa</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>

                <div class="admin-card">
                    <h2 class="h5 mb-3">Danh sách chờ duyệt</h2>
                    <div class="table-responsive">
                        <table class="table align-middle">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Tên quán</th>
                                    <th>Ảnh</th>
                                    <th>Chủ quán</th>
                                    <th>Liên hệ</th>
                                    <th>Loại hình</th>
                                    <th>Mô tả</th>
                                    <th>Gửi lúc (UTC)</th>
                                    <th>Duyệt lên map</th>
                                    <th class="text-end">Khác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (!Model.PendingRegistrations.Any())
                                {
                                    <tr>
                                        <td colspan="10" class="text-center text-muted">Không có đăng ký quán ăn.</td>
                                    </tr>
                                }
                                else
                                {
                                    foreach (var item in Model.PendingRegistrations)
                                    {
                                        var itemImageUrls = (item.ImageUrls?
                                            .Where(url => !string.IsNullOrWhiteSpace(url))
                                            .Select(url => url.Trim())
                                            .ToList() ?? new List<string>());

                                        if (!itemImageUrls.Any() && !string.IsNullOrWhiteSpace(item.ImageUrl))
                                        {
                                            itemImageUrls.Add(item.ImageUrl.Trim());
                                        }

                                        <tr>
                                            <td>@item.Id</td>
                                            <td>@item.StoreName</td>
                                            <td>
                                                @if (itemImageUrls.Any())
                                                {
                                                    <div class="d-flex flex-column gap-2">
                                                        <div class="d-flex flex-wrap gap-2">
                                                            @foreach (var imageUrl in itemImageUrls.Take(3))
                                                            {
                                                                <a href="@imageUrl" target="_blank" rel="noopener noreferrer">
                                                                    <img src="@imageUrl" alt="Ảnh quán"
                                                                         style="width:72px;height:54px;object-fit:cover;border-radius:8px;border:1px solid #e5e7eb;" />
                                                                </a>
                                                            }
                                                        </div>
                                                        <span class="badge text-bg-light border align-self-start">@itemImageUrls.Count ảnh</span>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <span class="text-muted small">Chưa có ảnh</span>
                                                }
                                            </td>
                                            <td>@item.OwnerName</td>
                                            <td>
                                                <div>@item.Phone</div>
                                                <small class="text-muted">@item.Address</small>
                                            </td>
                                            <td>@item.Category</td>
                                            <td>@item.Description</td>
                                            <td>@item.SubmittedAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                                            <td>
                                                <form asp-action="ApproveStore" method="post" class="d-flex flex-column gap-2">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@item.Id" />
                                                    <div class="d-flex gap-2">
                                                        <input id="lat-@item.Id" type="number" step="any" name="latitude"
                                                               class="form-control form-control-sm" placeholder="Vĩ độ" required />
                                                        <input id="lng-@item.Id" type="number" step="any" name="longitude"
                                                               class="form-control form-control-sm" placeholder="Kinh độ" required />
                                                    </div>
                                                    <div class="d-flex gap-2">
                                                        <button type="button" class="btn btn-sm btn-outline-primary"
                                                                onclick="openMapPicker('lat-@item.Id','lng-@item.Id')">Chọn trên map</button>
                                                        <button type="submit" class="btn btn-sm btn-success">Duyệt</button>
                                                    </div>
                                                </form>
                                            </td>
                                            <td class="text-end">
                                                <div class="d-flex justify-content-end gap-2">
                                                    <button type="button" class="btn btn-sm btn-outline-primary" data-bs-toggle="modal"
                                                            data-bs-target="#editStoreRegistrationModal" data-store-id="@item.Id"
                                                            data-store-name="@item.StoreName" data-owner-name="@item.OwnerName"
                                                            data-phone="@item.Phone" data-address="@item.Address" data-category="@item.Category"
                                                            data-description="@item.Description" data-image-url="@item.ImageUrl"
                                                            data-image-urls='@Html.Raw(JsonSerializer.Serialize(itemImageUrls))'>
                                                        Chỉnh sửa
                                                    </button>
                                                    <form asp-action="DeleteStore" method="post"
                                                          onsubmit="return confirm('Xóa đăng ký quán này?');">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="id" value="@item.Id" />
                                                        <button type="submit" class="btn btn-sm btn-outline-danger">Xóa</button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="modal fade" id="editStoreRegistrationModal" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
                        <div class="modal-content">
                            <form asp-action="UpdateStoreRegistration" method="post">
                                @Html.AntiForgeryToken()
                                <div class="modal-header">
                                    <h5 class="modal-title">Chỉnh sửa quán ăn đã đăng ký</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                </div>
                                <div class="modal-body">
                                    <input type="hidden" id="editStoreId" name="id" />

                                    <div class="mb-3">
                                        <label for="editStoreName" class="form-label">Tên quán</label>
                                        <input id="editStoreName" type="text" name="storeName" class="form-control" required />
                                    </div>

                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <label for="editOwnerName" class="form-label">Chủ quán</label>
                                            <input id="editOwnerName" type="text" name="ownerName" class="form-control" required />
                                        </div>
                                        <div class="col-md-6">
                                            <label for="editPhone" class="form-label">Số điện thoại</label>
                                            <input id="editPhone" type="text" name="phone" class="form-control" required />
                                        </div>
                                    </div>

                                    <div class="mt-3">
                                        <label for="editAddress" class="form-label">Địa chỉ</label>
                                        <input id="editAddress" type="text" name="address" class="form-control" required />
                                    </div>

                                    <div class="mt-3">
                                        <label for="editCategory" class="form-label">Loại hình</label>
                                        <input id="editCategory" type="text" name="category" class="form-control" />
                                    </div>

                                    <div class="mt-3">
                                        <label for="editDescription" class="form-label">Mô tả</label>
                                        <textarea id="editDescription" name="description" rows="3" class="form-control"></textarea>
                                    </div>

                                    <div class="mt-3">
                                        <div class="d-flex justify-content-between align-items-center gap-2 mb-2">
                                            <label class="form-label mb-0">Ảnh review</label>
                                            <button type="button" id="uploadStoreImagesButton"
                                                    class="btn btn-sm btn-outline-primary">Tải ảnh đã chọn</button>
                                        </div>
                                        <div class="input-group input-group-sm mb-2">
                                            <input type="file" id="storeImageFiles" class="form-control" accept="image/*" multiple />
                                        </div>
                                        <div id="storeImageUploadStatus" class="small text-muted mb-2">Chọn ảnh từ máy rồi bấm Tải ảnh đã chọn.</div>
                                        <input type="hidden" id="editStorePrimaryImageUrl" name="imageUrl" />
                                        <div id="editStoreImageUrlsContainer" class="d-grid gap-2"></div>
                                    </div>

                                    <div class="mt-3">
                                        <div class="small text-muted mb-2">Xem trước ảnh review</div>
                                        <div id="editStoreImagePreviewGrid" class="d-flex flex-wrap gap-2"></div>
                                        <div id="editStoreImagePreviewEmpty" class="small text-muted">Chưa có ảnh để xem trước.</div>
                                    </div>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Hủy</button>
                                    <button type="submit" class="btn btn-primary">Lưu chỉnh sửa</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>

                <div class="modal fade" id="mapPickerModal" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog modal-lg modal-dialog-centered">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">Chọn vị trí quán ăn trên bản đồ</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                            </div>
                            <div class="modal-body">
                                <div class="row g-2 mb-3">
                                    <div class="col-12 d-flex gap-2 flex-wrap">
                                        <input id="manualStreetInput" type="text" class="form-control form-control-sm"
                                               style="max-width: 440px;" placeholder="Nhập tên đường, ví dụ: Vĩnh Khánh, Quận 4" />
                                        <button type="button" id="manualStreetSearchButton" class="btn btn-sm btn-outline-secondary">Tìm
                                            theo tên đường</button>
                                        </div>
                                        <div class="col-md-6">
                                            <label for="manualLatInput" class="form-label mb-1">Vĩ độ</label>
                                            <input id="manualLatInput" type="number" step="0.000001" class="form-control form-control-sm"
                                                   placeholder="10.758900" />
                                        </div>
                                        <div class="col-md-6">
                                            <label for="manualLngInput" class="form-label mb-1">Kinh độ</label>
                                            <input id="manualLngInput" type="number" step="0.000001" class="form-control form-control-sm"
                                                   placeholder="106.707200" />
                                        </div>
                                        <div class="col-12 d-flex gap-2 flex-wrap">
                                            <input id="manualLatLngInput" type="text" class="form-control form-control-sm"
                                                   style="max-width: 340px;" placeholder="Hoặc nhập nhanh: 10.758900,106.707200" />
                                            <button type="button" id="manualPointButton" class="btn btn-sm btn-outline-primary">Point trên
                                                map</button>
                                            </div>
                                        </div>
                                        <div id="store-map-picker" style="height: 420px; border-radius: 12px;"></div>
                                        <small class="text-muted d-block mt-2">Nhấp vào bản đồ để gắn tọa độ cho đăng ký quán ăn.</small>
                                        <small id="mapTileWarning" class="text-danger d-none d-block mt-1">Không tải được tile bản đồ từ
                                            OpenStreetMap. Vui lòng kiểm tra mạng hoặc thử lại.</small>
                                            <small id="manualPointWarning" class="text-danger d-none d-block mt-1">Tọa độ không hợp lệ. Vui lòng
                                                nhập đúng định dạng (lat,lng).</small>
                                                <small id="manualStreetWarning" class="text-danger d-none d-block mt-1">Không tìm thấy vị trí phù hợp từ
                                                    tên đường. Vui lòng thử nhập rõ hơn.</small>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    @section Scripts {
                                        <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="" />
                                        <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
                                        <script>
                                            let pickerMap;
                                            let pickerMarker;
                                            let pickerModal;
                                            let pickerModalElement;
                                            let manualPointButton;
                                            let manualStreetInput;
                                            let manualStreetSearchButton;
                                            let manualLatInput;
                                            let manualLngInput;
                                            let manualLatLngInput;
                                            let manualPointWarning;
                                            let manualStreetWarning;
                                            const defaultCenter = [10.7589, 106.7072];
                                            const registeredRestaurants = @Html.Raw(registeredRestaurantsJson);
                                            const vinhKhanhBounds = L.latLngBounds(
                                            [10.7530, 106.6992],
                                            [10.7648, 106.7152]
                                            );
                                            let registeredRestaurantLayer;
                                            let targetLatId;
                                            let targetLngId;

                                            function createStoreImageUrlRow(value) {
                                            const row = document.createElement('div');
                                            row.className = 'd-flex align-items-center justify-content-between gap-2 border rounded p-2';

                                            const input = document.createElement('input');
                                            input.type = 'hidden';
                                            input.name = 'imageUrls';
                                            input.value = value || '';

                                            const thumbnail = document.createElement('img');
                                            thumbnail.src = input.value;
                                            thumbnail.alt = 'Ảnh quán';
                                            thumbnail.style.width = '68px';
                                            thumbnail.style.height = '52px';
                                            thumbnail.style.objectFit = 'cover';
                                            thumbnail.style.borderRadius = '8px';
                                            thumbnail.style.border = '1px solid #e5e7eb';

                                            const meta = document.createElement('div');
                                            meta.className = 'small text-muted text-truncate flex-grow-1';
                                            meta.style.maxWidth = '320px';
                                            meta.textContent = input.value;

                                            const primaryButton = document.createElement('button');
                                            primaryButton.type = 'button';
                                            primaryButton.className = 'btn btn-sm btn-outline-success';
                                            primaryButton.textContent = 'Đặt chính';
                                            primaryButton.addEventListener('click', function () {
                                            const primaryInput = document.getElementById('editStorePrimaryImageUrl');
                                            if (primaryInput) {
                                            primaryInput.value = (input.value || '').trim();
                                            }

                                            updateStoreRegistrationRowStates();
                                            updateStoreRegistrationImagePreviews();
                                            });

                                            const removeButton = document.createElement('button');
                                            removeButton.type = 'button';
                                            removeButton.className = 'btn btn-sm btn-outline-danger';
                                            removeButton.textContent = 'Xóa';
                                            removeButton.addEventListener('click', function () {
                                            row.remove();
                                            ensureStoreRegistrationPrimaryImageExists();
                                            updateStoreRegistrationRowStates();
                                            updateStoreRegistrationImagePreviews();
                                            });

                                            const actions = document.createElement('div');
                                            actions.className = 'd-flex gap-1';
                                            actions.appendChild(primaryButton);
                                            actions.appendChild(removeButton);

                                            row.appendChild(input);
                                            row.appendChild(thumbnail);
                                            row.appendChild(meta);
                                            row.appendChild(actions);
                                            row.dataset.role = 'store-image-row';
                                            row.dataset.imageUrl = input.value;
                                            primaryButton.dataset.role = 'store-primary-image-button';
                                            return row;
                                            }

                                            function getStoreRegistrationRows() {
                                            const container = document.getElementById('editStoreImageUrlsContainer');
                                            if (!container) {
                                            return [];
                                            }

                                            return Array.from(container.querySelectorAll('[data-role="store-image-row"]'));
                                            }

                                            function getStoreRegistrationPrimaryImageUrl() {
                                            const primaryInput = document.getElementById('editStorePrimaryImageUrl');
                                            const normalized = (primaryInput ? primaryInput.value : '').trim();
                                            if (normalized) {
                                            const matchingRow = getStoreRegistrationRows().find(row => ((row.querySelector('input[name="imageUrls"]')?.value || '').trim() === normalized));
                                            if (matchingRow) {
                                            return normalized;
                                            }
                                            }

                                            const firstValue = getStoreRegistrationRows()
                                            .map(row => (row.querySelector('input[name="imageUrls"]')?.value || '').trim())
                                            .find(Boolean);

                                            if (primaryInput) {
                                            primaryInput.value = firstValue || '';
                                            }

                                            return firstValue || '';
                                            }

                                            function ensureStoreRegistrationPrimaryImageExists() {
                                            const primaryInput = document.getElementById('editStorePrimaryImageUrl');
                                            if (!primaryInput) {
                                            return;
                                            }

                                            const primary = (primaryInput.value || '').trim();
                                            const rows = getStoreRegistrationRows();
                                            if (rows.length === 0) {
                                            primaryInput.value = '';
                                            return;
                                            }

                                            const hasPrimary = primary && rows.some(row => ((row.querySelector('input[name="imageUrls"]')?.value || '').trim() === primary));
                                            if (!hasPrimary) {
                                            primaryInput.value = (rows[0].querySelector('input[name="imageUrls"]')?.value || '').trim();
                                            }
                                            }

                                            function updateStoreRegistrationRowStates() {
                                            const primary = getStoreRegistrationPrimaryImageUrl();
                                            for (const row of getStoreRegistrationRows()) {
                                            const input = row.querySelector('input[name="imageUrls"]');
                                            const primaryButton = row.querySelector('[data-role="store-primary-image-button"]');
                                            const rowValue = (input ? input.value : '').trim();
                                            const isPrimary = Boolean(primary) && rowValue === primary;

                                            row.classList.toggle('border', true);
                                            row.classList.toggle('border-success', isPrimary);
                                            row.classList.toggle('bg-light', isPrimary);

                                            if (primaryButton) {
                                            primaryButton.textContent = isPrimary ? 'Ảnh chính' : 'Đặt chính';
                                            primaryButton.classList.toggle('btn-outline-success', !isPrimary);
                                            primaryButton.classList.toggle('btn-success', isPrimary);
                                            }
                                            }
                                            }

                                            function setStoreRegistrationImageUrls(urls) {
                                            const container = document.getElementById('editStoreImageUrlsContainer');
                                            if (!container) {
                                            return;
                                            }

                                            container.innerHTML = '';
                                            const normalized = Array.isArray(urls)
                                            ? Array.from(new Set(urls.map(url => (url || '').trim()).filter(Boolean)))
                                            : [];

                                            for (const url of normalized) {
                                            container.appendChild(createStoreImageUrlRow(url));
                                            }

                                            ensureStoreRegistrationPrimaryImageExists();
                                            updateStoreRegistrationRowStates();

                                            updateStoreRegistrationImagePreviews();
                                            }

                                            function updateStoreRegistrationImagePreviews() {
                                            const previewGrid = document.getElementById('editStoreImagePreviewGrid');
                                            const empty = document.getElementById('editStoreImagePreviewEmpty');
                                            const container = document.getElementById('editStoreImageUrlsContainer');
                                            const primary = getStoreRegistrationPrimaryImageUrl();

                                            if (!previewGrid || !empty || !container) {
                                            return;
                                            }

                                            const urls = Array.from(container.querySelectorAll('input[name="imageUrls"]'))
                                            .map(input => (input.value || '').trim())
                                            .filter(Boolean);

                                            previewGrid.innerHTML = '';
                                            if (urls.length === 0) {
                                            empty.classList.remove('d-none');
                                            return;
                                            }

                                            empty.classList.add('d-none');
                                            for (const url of urls) {
                                            const wrapper = document.createElement('div');
                                            wrapper.className = 'd-flex flex-column gap-1';

                                            if (primary && url === primary) {
                                            const badge = document.createElement('span');
                                            badge.className = 'badge text-bg-success align-self-start';
                                            badge.textContent = 'Ảnh chính';
                                            wrapper.appendChild(badge);
                                            }

                                            const image = document.createElement('img');
                                            image.src = url;
                                            image.alt = 'Xem trước ảnh quán';
                                            image.style.width = '110px';
                                            image.style.height = '84px';
                                            image.style.objectFit = 'cover';
                                            image.style.borderRadius = '10px';
                                            image.style.border = '1px solid #e5e7eb';

                                            const caption = document.createElement('small');
                                            caption.className = 'text-muted text-truncate';
                                            caption.style.maxWidth = '110px';
                                            caption.textContent = url;

                                            wrapper.appendChild(image);
                                            wrapper.appendChild(caption);
                                            previewGrid.appendChild(wrapper);
                                            }
                                            }

                                            const cloudinaryCloudName = 'dmpaepela';
                                            const cloudinaryUploadPreset = 'zestour';

                                            async function uploadStoreImageToCloudinary(file) {
                                            const endpoint = `https://api.cloudinary.com/v1_1/${encodeURIComponent(cloudinaryCloudName)}/image/upload`;
                                            const formData = new FormData();
                                            formData.append('file', file);
                                            formData.append('upload_preset', cloudinaryUploadPreset);
                                            formData.append('folder', 'zestour/stores');

                                            const response = await fetch(endpoint, {
                                            method: 'POST',
                                            body: formData
                                            });

                                            const payload = await response.json().catch(() => ({}));
                                            if (!response.ok) {
                                            const detail = payload && payload.error && payload.error.message
                                            ? payload.error.message
                                            : 'Không thể upload ảnh lên Cloudinary.';
                                            throw new Error(detail);
                                            }

                                            const secureUrl = payload && payload.secure_url ? String(payload.secure_url).trim() : '';
                                            if (!secureUrl) {
                                            throw new Error('Không nhận được URL ảnh từ Cloudinary.');
                                            }

                                            return secureUrl;
                                            }

                                            async function uploadStoreAudioToCloudinary(file) {
                                            const endpoint = `https://api.cloudinary.com/v1_1/${encodeURIComponent(cloudinaryCloudName)}/auto/upload`;
                                            const formData = new FormData();
                                            formData.append('file', file);
                                            formData.append('upload_preset', cloudinaryUploadPreset);
                                            formData.append('folder', 'zestour/audio');

                                            const response = await fetch(endpoint, {
                                            method: 'POST',
                                            body: formData
                                            });

                                            const payload = await response.json().catch(() => ({}));
                                            if (!response.ok) {
                                            const detail = payload && payload.error && payload.error.message
                                            ? payload.error.message
                                            : 'Không thể upload audio lên Cloudinary.';
                                            throw new Error(detail);
                                            }

                                            const secureUrl = payload && payload.secure_url ? String(payload.secure_url).trim() : '';
                                            if (!secureUrl) {
                                            throw new Error('Không nhận được URL audio từ Cloudinary.');
                                            }

                                            return secureUrl;
                                            }

                                            function appendStoreImageUrl(url) {
                                            const normalized = (url || '').trim();
                                            if (!normalized) {
                                            return;
                                            }

                                            const container = document.getElementById('editStoreImageUrlsContainer');
                                            if (!container) {
                                            return;
                                            }

                                            const exists = Array.from(container.querySelectorAll('input[name="imageUrls"]'))
                                            .some(input => (input.value || '').trim() === normalized);
                                            if (exists) {
                                            return;
                                            }

                                            container.appendChild(createStoreImageUrlRow(normalized));
                                            ensureStoreRegistrationPrimaryImageExists();
                                            updateStoreRegistrationRowStates();
                                            updateStoreRegistrationImagePreviews();
                                            }

                                            function setRestaurantImagePreview(url) {
                                            const preview = document.getElementById('editRestaurantImagePreview');
                                            const empty = document.getElementById('editRestaurantImagePreviewEmpty');
                                            const normalized = (url || '').trim();

                                            if (!preview || !empty) {
