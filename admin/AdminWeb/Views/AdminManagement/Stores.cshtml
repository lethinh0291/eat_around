                                            if (!normalized) {
                                            preview.style.display = 'none';
                                            preview.src = '';
                                            empty.classList.remove('d-none');
                                            return;
                                            }

                                            preview.src = normalized;
                                            preview.style.display = 'block';
                                            empty.classList.add('d-none');
                                            }

