@model AdminWeb.Services.AdminManagementApiClient.AdBannerUpsertDto
@{
    ViewData["Title"] = "Sửa banner";
}

<div class="d-flex align-items-end justify-content-between flex-wrap gap-3 mb-4">
    <div>
        <div class="breadcrumbs-inline mb-2">
            <a asp-controller="Home" asp-action="Index">Dashboard</a>
            <span>/</span>
            <a asp-action="Index">Banner quảng cáo</a>
            <span>/</span>
            <span>Chỉnh sửa</span>
        </div>
        <h1 class="page-title">Chỉnh sửa banner quảng cáo</h1>
        <p class="page-subtitle">Có thể giữ ảnh hiện tại hoặc chọn ảnh mới từ máy.</p>
    </div>
</div>

<div class="surface-card p-4" style="max-width:760px;">
    <form method="post" enctype="multipart/form-data" class="d-flex flex-column gap-3">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <input type="hidden" name="currentImageUrl" value="@Model.ImageUrl" />

        <div>
            <label class="form-label">Đổi ảnh banner (tùy chọn)</label>
            <input name="imageFile" type="file" class="form-control" accept="image/*" />
            <span class="form-text">Nếu không chọn ảnh mới, hệ thống giữ nguyên ảnh hiện tại.</span>
        </div>

        <div>
            <label asp-for="SortOrder" class="form-label">Thứ tự hiển thị</label>
            <input asp-for="SortOrder" type="number" class="form-control" />
        </div>

        <div class="form-check">
            <input asp-for="IsActive" class="form-check-input" />
            <label asp-for="IsActive" class="form-check-label">Hiển thị trên mobile</label>
        </div>

        <div class="pt-2">
            <div class="small text-muted mb-2">Xem trước ảnh hiện tại</div>
            <img src="@Model.ImageUrl" alt="Banner preview"
                 style="width:100%;max-width:640px;height:220px;object-fit:cover;border-radius:12px;border:1px solid #e5e7eb;" />
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-admin btn-admin-primary">Lưu thay đổi</button>
            <a class="btn btn-admin btn-admin-soft" asp-action="Index">Hủy</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
