@model List<AdminWeb.Services.AdminManagementApiClient.AdBannerDto>
@{
    ViewData["Title"] = "Banner quảng cáo";
}

<div class="d-flex align-items-end justify-content-between flex-wrap gap-3 mb-4">
    <div>
        <div class="breadcrumbs-inline mb-2">
            <a asp-controller="Home" asp-action="Index">Dashboard</a>
            <span>/</span>
            <span>Banner quảng cáo</span>
        </div>
        <h1 class="page-title">Quản lý banner quảng cáo</h1>
        <p class="page-subtitle">Banner chỉ gồm ảnh, hiển thị trên mobile phía trên khu vực Khám phá.</p>
    </div>
    <a class="btn btn-admin btn-admin-primary" asp-action="Create">+ Thêm banner</a>
</div>

@if (TempData["AdminMessage"] is string message && !string.IsNullOrWhiteSpace(message))
{
    <div class="alert alert-success border-0 shadow-sm rounded-4 mb-4">@message</div>
}

@if (TempData["AdminError"] is string error && !string.IsNullOrWhiteSpace(error))
{
    <div class="alert alert-danger border-0 shadow-sm rounded-4 mb-4">@error</div>
}

<div class="surface-card p-4">
    @if (Model.Count == 0)
    {
        <div class="empty-state">
            <div>Chưa có banner nào.</div>
            <div class="mt-3">
                <a class="btn btn-admin btn-admin-primary" asp-action="Create">Tạo banner đầu tiên</a>
            </div>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table admin-table align-middle">
                <thead>
                    <tr>
                        <th>Thứ tự</th>
                        <th>Ảnh</th>
                        <th>Trạng thái</th>
                        <th>Cập nhật</th>
                        <th class="text-end">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.SortOrder</td>
                            <td>
                                <div class="d-flex align-items-center gap-3">
                                    <img src="@item.ImageUrl" alt="Banner @item.Id"
                                         style="width:160px;height:72px;object-fit:cover;border-radius:10px;border:1px solid #e5e7eb;" />
                                    <a href="@item.ImageUrl" target="_blank" rel="noopener noreferrer"
                                       class="btn btn-admin btn-admin-soft btn-sm">Mở ảnh</a>
                                </div>
                            </td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="admin-badge admin-badge-accent">Đang hiển thị</span>
                                }
                                else
                                {
                                    <span class="admin-badge admin-badge-muted">Tạm ẩn</span>
                                }
                            </td>
                            <td>
                                <div class="poi-meta">@item.UpdatedAtUtc.ToString("yyyy-MM-dd HH:mm") UTC</div>
                            </td>
                            <td>
                                <div class="d-flex justify-content-end gap-2">
                                    <a class="btn btn-admin btn-admin-soft btn-sm" asp-action="Edit"
                                       asp-route-id="@item.Id">Sửa</a>
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post"
                                          onsubmit="return confirm('Xóa banner này?');">
                                        <button type="submit" class="btn btn-admin btn-outline-danger btn-sm">Xóa</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
