<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ZesTour Admin</title>
    <script type="importmap"></script>
    <link rel="icon" type="image/svg+xml" href="~/images/logo.svg" asp-append-version="true" />
    <link rel="shortcut icon" href="~/images/logo.svg" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AdminWeb.styles.css" asp-append-version="true" />
</head>
<body class="admin-body">
    <header class="admin-header">
        <nav class="navbar navbar-expand-lg navbar-dark admin-navbar">
            <div class="container-fluid px-4">
                <a class="navbar-brand brand-mark" asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="~/images/logo.svg" alt="ZesTour" class="brand-logo" />
                    ZesTour Admin
                </a>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#adminNav" aria-controls="adminNav"
                            aria-expanded="false" aria-label="Menu">
                        Menu
                    </button>
                    <div class="collapse navbar-collapse" id="adminNav">
                        <ul class="navbar-nav ms-auto gap-2">
                            <li class="nav-item">
                                <a class="nav-link admin-nav-link" asp-area="" asp-controller="Home" asp-action="Index">Dashboard</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link admin-nav-link" asp-area="" asp-controller="AdminManagement" asp-action="Users">Users</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link admin-nav-link" asp-area="" asp-controller="AdminManagement" asp-action="Stores">Quán ăn</a>
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                    <button type="submit" class="nav-link admin-nav-link btn btn-link p-0 border-0">Đăng xuất</button>
                                </form>
                            </li>
                        </ul>
                    </div>
                }
            </div>
        </nav>
    </header>
    <main role="main" class="admin-main">
        <div class="container-fluid px-4 py-4">
            @RenderBody()
        </div>
    </main>

    <footer class="admin-footer">
        <div class="container-fluid px-4 d-flex justify-content-between align-items-center flex-wrap gap-2">
            <span>&copy; 2026 - ZesTour Admin</span>
            <span class="admin-footer-note">Quản trị nội dung từ mobile build</span>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
