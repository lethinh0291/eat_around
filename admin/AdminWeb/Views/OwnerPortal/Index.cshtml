@model AdminWeb.Controllers.OwnerPortalController.OwnerPortalViewModel
@{
    ViewData["Title"] = "Trang chủ quán";
    var ownerName = ViewData["OwnerName"]?.ToString() ?? "Chủ quán";
    var pendingCount = (int?)ViewData["PendingCount"] ?? 0;
    var liveCount = (int?)ViewData["LiveCount"] ?? 0;
    var latestSubmit = ViewData["LatestSubmit"] as DateTime?;
}

<section class="admin-hero mb-4">
    <div class="row g-4 align-items-center">
        <div class="col-lg-8">
            <span class="eyebrow">Khu vực chủ quán</span>
            <h1 class="hero-title">Xin chào @ownerName</h1>
            <p class="hero-copy">
                Đây là trang quản lý dành riêng cho tài khoản chủ quán. Bạn có thể theo dõi trạng thái quán đã gửi duyệt
                và
                các quán đã được hiển thị trên bản đồ mobile.
            </p>
        </div>
        <div class="col-lg-4">
            <div class="row g-3">
                <div class="col-6 col-lg-12">
                    <div class="stat-card">
                        <div class="stat-label">Đang chờ duyệt</div>
                        <div class="stat-value">@pendingCount</div>
                        <div class="stat-note">Đăng ký quán chưa lên bản đồ</div>
                    </div>
                </div>
                <div class="col-6 col-lg-12">
                    <div class="stat-card">
                        <div class="stat-label">Đã hiển thị</div>
                        <div class="stat-value">@liveCount</div>
                        <div class="stat-note">Quán đang xuất hiện trên map</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@if (TempData["AdminMessage"] is string successMessage && !string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert alert-success border-0 shadow-sm">@successMessage</div>
}

@if (TempData["AdminError"] is string errorMessage && !string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger border-0 shadow-sm">@errorMessage</div>
}

<div class="row g-4">
    <div class="col-xl-6">
        <div class="surface-card p-4 h-100">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2 class="section-title">Danh sách chờ duyệt</h2>
                <span class="admin-badge admin-badge-accent">@pendingCount mục</span>
            </div>

            @if (Model.PendingStores.Count == 0)
            {
                <div class="empty-state">Bạn chưa có quán nào trong danh sách chờ duyệt.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table admin-table align-middle">
                        <thead>
                            <tr>
                                <th>Tên quán</th>
                                <th>Loại hình</th>
                                <th>Gửi lúc</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var store in Model.PendingStores)
                            {
                                <tr>
                                    <td>
                                        <div class="poi-name">@store.StoreName</div>
                                        <div class="poi-meta">@store.Address</div>
                                    </td>
                                    <td>
                                        <span class="admin-badge admin-badge-muted">@store.Category</span>
                                    </td>
                                    <td>
                                        <div class="poi-meta">@store.SubmittedAtUtc.ToString("yyyy-MM-dd HH:mm") UTC</div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <div class="col-xl-6">
        <div class="surface-card p-4 h-100">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2 class="section-title">Quán đã lên bản đồ</h2>
                <span class="admin-badge admin-badge-accent">@liveCount quán</span>
            </div>

            @if (Model.LiveRestaurants.Count == 0)
            {
                <div class="empty-state">Hiện chưa có quán của bạn xuất hiện trên bản đồ.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table admin-table align-middle">
                        <thead>
                            <tr>
                                <th>Tên quán</th>
                                <th>Ưu tiên</th>
                                <th>Bán kính</th>
                                <th style="min-width: 320px;">Mô tả thuyết minh tự động</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.EditableLiveRestaurants)
                            {
                                var restaurant = item.Poi;
                                <tr>
                                    <td>
                                        <div class="poi-name">@restaurant.Name</div>
                                        <div class="poi-meta">@restaurant.LanguageCode</div>
                                    </td>
                                    <td>
                                        <span class="admin-badge admin-badge-accent">Priority @restaurant.Priority</span>
                                    </td>
                                    <td>
                                        <span class="admin-badge admin-badge-muted">@restaurant.Radius.ToString("0.#")m</span>
                                    </td>
                                    <td>
                                        <form asp-action="UpdateNarrationDescription" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@restaurant.Id" />
                                            <div class="d-grid gap-2">
                                                <textarea name="narrationDescription" class="form-control" rows="3"
                                                          maxlength="2000"
                                                          placeholder="Nhập nội dung sẽ được app mobile đọc bằng text-to-speech khi khách đến gần quán">@item.NarrationDescription</textarea>
                                                <button type="submit" class="btn btn-sm btn-primary">Lưu mô tả</button>
                                            </div>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

            <div class="mt-3 p-3 rounded-4"
                 style="background: var(--admin-surface-soft); border: 1px solid var(--admin-border);">
                <div class="fw-bold mb-1">Ghi chú</div>
                <div class="small text-secondary-emphasis">
                    @if (latestSubmit.HasValue)
                    {
                        <text>Lần gửi đăng ký gần nhất: @latestSubmit.Value.ToString("yyyy-MM-dd HH:mm") UTC.</text>
                    }
                    else
                    {
                        <text>Bạn chưa có lịch sử gửi đăng ký quán trong hệ thống.</text>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
