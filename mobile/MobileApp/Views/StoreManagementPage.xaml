<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Name="ManagementPage"
             x:Class="ZesTour.Views.StoreManagementPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#F6F8FB">
    <Grid>
        <Border StrokeThickness="0"
                BackgroundColor="#F6F8FB"/>

        <ScrollView x:Name="ManagementScrollView">
            <VerticalStackLayout Padding="16,26,16,20"
                                 Spacing="14">
                <Grid ColumnDefinitions="Auto,*"
                      ColumnSpacing="10">
                    <Border WidthRequest="44"
                            HeightRequest="44"
                            StrokeThickness="1"
                            Stroke="#DCE4EE"
                            BackgroundColor="#FFFFFF"
                            StrokeShape="RoundRectangle 15">
                        <Label Text="←"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}"
                               HorizontalTextAlignment="Center"
                               VerticalTextAlignment="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnBackTapped"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>

                    <VerticalStackLayout Grid.Column="1"
                                         Spacing="2"
                                         VerticalOptions="Center">
                        <Label x:Name="ManagementTitleLabel"
                               Text="Quản lý cửa hàng"
                               FontSize="21"
                               FontAttributes="Bold"
                               TextColor="#0F172A"/>
                        <Label x:Name="ManagementSubtitleLabel"
                               Text="Sửa nhanh thông tin, ảnh, địa chỉ và tọa độ cho quán của bạn"
                               FontSize="12"
                               TextColor="#64748B"/>
                    </VerticalStackLayout>
                </Grid>

                <Border StrokeThickness="1"
                        Stroke="#F1D8C6"
                        BackgroundColor="#FFF8F2"
                        StrokeShape="RoundRectangle 22"
                        Padding="14">
                    <VerticalStackLayout Spacing="10">
                        <VerticalStackLayout Spacing="6">
                            <Label x:Name="EditRegistrationLabel"
                                   Text="Chỉnh sửa đăng ký"
                                   FontSize="13"
                                   TextColor="#C2410C"
                                   FontAttributes="Bold"/>
                            <Label x:Name="EditRegistrationTitleLabel"
                                   Text="Chọn một quán bên dưới rồi cập nhật từ form này."
                                   FontSize="15"
                                   FontAttributes="Bold"
                                   TextColor="#7C2D12"/>
                            <Label x:Name="EditRegistrationHintLabel"
                                   Text="Có gợi ý địa chỉ, xem trước map và lưu ảnh chính."
                                   FontSize="11"
                                   TextColor="#9A3412"/>
                        </VerticalStackLayout>

                        <Button x:Name="RefreshButton"
                                Text="Tải lại"
                                Clicked="OnRefreshClicked"
                                HeightRequest="42"
                                CornerRadius="12"
                                BackgroundColor="#FEE7D3"
                                TextColor="#9A3412"
                                FontAttributes="Bold"
                                HorizontalOptions="Fill"/>
                    </VerticalStackLayout>
                </Border>

                <Label x:Name="StatusLabel"
                       FontSize="12"
                       TextColor="#B91C1C"/>

                <Border StrokeThickness="1"
                        Stroke="#E4EAF1"
                        BackgroundColor="#FFFFFF"
                        StrokeShape="RoundRectangle 22"
                        Padding="14">
                    <VerticalStackLayout Spacing="10">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="10">
                            <VerticalStackLayout Spacing="3">
                                <Label x:Name="RegistrationsTitleLabel"
                                       Text="Danh sách đăng ký"
                                       FontSize="17"
                                       FontAttributes="Bold"
                                       TextColor="#0F172A"/>
                                <Label x:Name="RegistrationsSubtitleLabel"
                                       Text="Bấm Chỉnh sửa ở từng quán để mở form cập nhật."
                                       FontSize="12"
                                       TextColor="#64748B"/>
                            </VerticalStackLayout>

                            <Border Grid.Column="1"
                                    BackgroundColor="#EFF6FF"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 999"
                                    Padding="10,6"
                                    VerticalOptions="Center">
                                <Label x:Name="SelectOneBadgeLabel"
                                       Text="Chọn 1"
                                       VerticalTextAlignment="Center"
                                       FontSize="11"
                                       FontAttributes="Bold"
                                       TextColor="#1D4ED8"/>
                            </Border>
                        </Grid>

                        <CollectionView x:Name="RegistrationsCollection"
                                        SelectionMode="None"
                                        HeightRequest="218">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Vertical"
                                                   ItemSpacing="10"/>
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border StrokeThickness="1"
                                            Stroke="#E5ECF3"
                                            StrokeShape="RoundRectangle 16"
                                            Padding="12,10"
                                            BackgroundColor="#FBFCFE">
                                        <Grid ColumnDefinitions="6,*,Auto"
                                              ColumnSpacing="10">
                                            <BoxView Color="#FDBA74"
                                                     WidthRequest="6"
                                                     CornerRadius="3"/>
                                            <VerticalStackLayout Grid.Column="1"
                                                                 Spacing="3">
                                                <Label Text="{Binding StoreName}"
                                                       FontSize="14"
                                                       FontAttributes="Bold"
                                                       TextColor="#0F172A"/>
                                                <Label Text="{Binding Address}"
                                                       FontSize="12"
                                                       TextColor="#475569"
                                                       LineBreakMode="TailTruncation"
                                                       MaxLines="2"/>
                                                <Label Text="{Binding SubmittedAtUtc, StringFormat='UTC: {0:yyyy-MM-dd HH:mm}'}"
                                                       FontSize="11"
                                                       TextColor="#94A3B8"/>
                                            </VerticalStackLayout>

                                            <VerticalStackLayout Grid.Column="2"
                                                                 Spacing="6"
                                                                 VerticalOptions="Start">
                                                <Border BackgroundColor="#FFF4EC"
                                                        StrokeThickness="0"
                                                        StrokeShape="RoundRectangle 999"
                                                        Padding="10,6"
                                                        HorizontalOptions="End">
                                                    <Label Text="{Binding Source={x:Reference ManagementPage}, Path=MyStoreBadgeText}"
                                                           FontSize="10"
                                                           FontAttributes="Bold"
                                                           TextColor="{StaticResource PrimaryDark}"/>
                                                </Border>

                                                <Button Text="Chỉnh sửa"
                                                        FontSize="11"
                                                        HeightRequest="32"
                                                        CornerRadius="11"
                                                        Padding="10,2"
                                                        BackgroundColor="#EEF2FF"
                                                        TextColor="#1E40AF"
                                                        Clicked="OnEditStoreClicked"
                                                        CommandParameter="{Binding .}"/>
                                            </VerticalStackLayout>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <Border x:Name="EmptyStateCard"
                                IsVisible="False"
                                StrokeThickness="1"
                                Stroke="#E5ECF3"
                                BackgroundColor="#FBFCFE"
                                StrokeShape="RoundRectangle 16"
                                Padding="16,14">
                            <VerticalStackLayout Spacing="6"
                                                 HorizontalOptions="Center"
                                                 VerticalOptions="Center">
                                <Border WidthRequest="44"
                                        HeightRequest="44"
                                        BackgroundColor="#EEF2FF"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 14"
                                        HorizontalOptions="Center">
                                    <Label Text="🏪"
                                           FontSize="20"
                                           HorizontalTextAlignment="Center"
                                           VerticalTextAlignment="Center"/>
                                </Border>
                                <Label x:Name="EmptyStateTitleLabel"
                                       Text="Bạn chưa có quán nào để quản lý"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       TextColor="#0F172A"
                                       HorizontalTextAlignment="Center"/>
                                <Label x:Name="EmptyStateSubtitleLabel"
                                       Text="Hãy gửi đăng ký quán mới hoặc tải lại sau khi quán được duyệt."
                                       FontSize="11"
                                       TextColor="#64748B"
                                       HorizontalTextAlignment="Center"/>
                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <Grid x:Name="StoreEditorOverlay"
              IsVisible="False"
              Opacity="0"
              BackgroundColor="#660F172A"
              Padding="14,20,14,20"
              ZIndex="20">
            <BoxView Color="Transparent">
                <BoxView.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnEditorBackdropTapped"/>
                </BoxView.GestureRecognizers>
            </BoxView>

            <Border x:Name="StoreEditorPanel"
                    StrokeThickness="1"
                    Stroke="#E3EAF2"
                    BackgroundColor="#FFFFFF"
                    StrokeShape="RoundRectangle 24"
                    Padding="16"
                    Opacity="0"
                    TranslationY="20"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    MaximumWidthRequest="680">
                <ScrollView MaximumHeightRequest="760">
                    <VerticalStackLayout Spacing="12">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="10">
                            <VerticalStackLayout Spacing="3">
                                <Label x:Name="StoreInfoTitleLabel"
                                       Text="Thông tin cửa hàng"
                                       FontSize="17"
                                       FontAttributes="Bold"
                                       TextColor="#0F172A"/>
                                <Label x:Name="StoreInfoSubtitleLabel"
                                       Text="Tách rõ thông tin, địa chỉ, ảnh và xem trước bản đồ."
                                       FontSize="12"
                                       TextColor="#64748B"/>
                            </VerticalStackLayout>

                            <Border Grid.Column="1"
                                    BackgroundColor="#F1F5F9"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 999"
                                    Padding="10,6"
                                    VerticalOptions="Start">
                                <Label Text="Đóng"
                                       FontSize="11"
                                       FontAttributes="Bold"
                                       TextColor="#334155">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnCloseEditorTapped"/>
                                    </Label.GestureRecognizers>
                                </Label>
                            </Border>
                        </Grid>

                        <Border StrokeThickness="1"
                                Stroke="#DCE3EC"
                                BackgroundColor="#FFFFFF"
                                StrokeShape="RoundRectangle 16"
                                Padding="12,10">
                            <Entry x:Name="StoreNameEntry"
                                   Placeholder="Tên cửa hàng"
                                   TextColor="#0F172A"
                                   PlaceholderColor="#64748B"/>
                        </Border>

                        <Grid RowDefinitions="Auto,Auto"
                              RowSpacing="10">
                            <Border StrokeThickness="1"
                                    Stroke="#DCE3EC"
                                    BackgroundColor="#FFFFFF"
                                    StrokeShape="RoundRectangle 14"
                                    Padding="12,10">
                                <Entry x:Name="PhoneEntry"
                                       Placeholder="Số điện thoại"
                                       Keyboard="Telephone"
                                       TextColor="#0F172A"
                                       PlaceholderColor="#64748B"/>
                            </Border>

                            <Border Grid.Row="1"
                                    StrokeThickness="1"
                                    Stroke="#DCE3EC"
                                    BackgroundColor="#FFFFFF"
                                    StrokeShape="RoundRectangle 14"
                                    Padding="12,10">
                                <Entry x:Name="CategoryEntry"
                                       Placeholder="Loại hình"
                                       TextColor="#0F172A"
                                       PlaceholderColor="#64748B"/>
                            </Border>
                        </Grid>

                        <Border StrokeThickness="1"
                                Stroke="#DCE3EC"
                                BackgroundColor="#FFFFFF"
                                StrokeShape="RoundRectangle 14"
                                Padding="12,10">
                            <VerticalStackLayout Spacing="8">
                                <Label Text="Địa chỉ"
                                       x:Name="AddressLabel"
                                       FontSize="11"
                                       FontAttributes="Bold"
                                       TextColor="#475569"/>
                                <Entry x:Name="AddressEntry"
                                       Placeholder="Nhập địa chỉ để được gợi ý"
                                       TextColor="#0F172A"
                                       PlaceholderColor="#64748B"/>
                            </VerticalStackLayout>
                        </Border>

                        <CollectionView x:Name="AddressSuggestionsCollectionView"
                                        IsVisible="False"
                                        SelectionMode="Single"
                                        SelectionChanged="OnAddressSuggestionSelected"
                                        HeightRequest="160">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Vertical"
                                                   ItemSpacing="6"/>
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border StrokeThickness="1"
                                            Stroke="#E4EAF1"
                                            BackgroundColor="#FFFFFF"
                                            StrokeShape="RoundRectangle 12"
                                            Padding="10,8">
                                        <Label Text="{Binding DisplayName}"
                                               FontSize="12"
                                               TextColor="#0F172A"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="2"/>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <Border x:Name="AddressMapPreviewContainer"
                                IsVisible="False"
                                StrokeThickness="0"
                                BackgroundColor="#F7FAFC"
                                StrokeShape="RoundRectangle 18"
                                Padding="8">
                            <VerticalStackLayout Spacing="6">
                                <Grid ColumnDefinitions="*,Auto">
                                    <VerticalStackLayout Spacing="2">
                                        <Label x:Name="AddressMapPreviewLabel"
                                               Text="Xem trước địa chỉ"
                                               FontSize="12"
                                               FontAttributes="Bold"
                                               TextColor="#0F172A"/>
                                        <Label x:Name="AddressPreviewHintLabel"
                                               Text="Bản đồ xem trước sẽ bám theo địa chỉ đã chọn."
                                               FontSize="11"
                                               TextColor="#64748B"/>
                                    </VerticalStackLayout>
                                    <Border Grid.Column="1"
                                            BackgroundColor="#EEF2F7"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 999"
                                            Padding="8,5"
                                            VerticalOptions="Start">
                                        <Label x:Name="PreviewBadgeLabel"
                                               Text="Preview"
                                               FontSize="10"
                                               FontAttributes="Bold"
                                               TextColor="#334155"/>
                                    </Border>
                                </Grid>
                                <Border StrokeThickness="1"
                                        Stroke="#E4EAF1"
                                        StrokeShape="RoundRectangle 14"
                                        BackgroundColor="#FFFFFF"
                                        Padding="4">
                                    <WebView x:Name="AddressMapPreview"
                                             HeightRequest="156"/>
                                </Border>
                            </VerticalStackLayout>
                        </Border>

                        <Border StrokeThickness="1"
                                Stroke="#DCE3EC"
                                BackgroundColor="#FFFFFF"
                                StrokeShape="RoundRectangle 14"
                                Padding="12,10">
                            <Editor x:Name="DescriptionEditor"
                                    Placeholder="Mô tả ngắn"
                                    AutoSize="TextChanges"
                                    HeightRequest="96"
                                    TextColor="#0F172A"
                                    PlaceholderColor="#64748B"/>
                        </Border>

                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="10">
                            <Button Grid.Column="0"
                                    x:Name="AddImageButton"
                                    Text="Chọn ảnh từ máy"
                                    Clicked="OnAddImageUrlClicked"
                                    HeightRequest="42"
                                    CornerRadius="12"
                                    BackgroundColor="#334155"
                                    TextColor="White"
                                    FontAttributes="Bold"/>
                            <Label Grid.Column="1"
                                   x:Name="AddImageHintLabel"
                                   Text="Không nhập link tay, chỉ chọn ảnh trực tiếp."
                                   FontSize="10"
                                   TextColor="#94A3B8"
                                   VerticalTextAlignment="Center"/>
                        </Grid>

                        <Border StrokeThickness="0"
                                BackgroundColor="#F7FAFC"
                                StrokeShape="RoundRectangle 18"
                                Padding="8">
                            <VerticalStackLayout Spacing="6">
                                <Grid ColumnDefinitions="*,Auto">
                                    <VerticalStackLayout Spacing="2">
                                        <Label x:Name="AlbumPreviewTitleLabel"
                                               Text="Xem trước album"
                                               FontSize="12"
                                               FontAttributes="Bold"
                                               TextColor="#0F172A"/>
                                        <Label x:Name="AlbumPreviewHintLabel"
                                               Text="Các ảnh hợp lệ sẽ hiện ở đây để chọn nhanh ảnh chính."
                                               FontSize="11"
                                               TextColor="#64748B"/>
                                    </VerticalStackLayout>
                                    <Border Grid.Column="1"
                                            BackgroundColor="#FFF1E8"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 999"
                                            Padding="8,5"
                                            VerticalOptions="Start">
                                        <Label x:Name="AlbumBadgeLabel"
                                               Text="Ảnh đẹp hơn"
                                               FontSize="10"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource PrimaryDark}"/>
                                    </Border>
                                </Grid>

                                <CollectionView x:Name="StoreImagePreviewCollection"
                                                SelectionMode="None"
                                                HeightRequest="148">
                                    <CollectionView.ItemsLayout>
                                        <LinearItemsLayout Orientation="Horizontal"
                                                           ItemSpacing="10"/>
                                    </CollectionView.ItemsLayout>
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate>
                                            <Border WidthRequest="108"
                                                    HeightRequest="156"
                                                    StrokeThickness="1"
                                                    Stroke="#E4EAF1"
                                                    StrokeShape="RoundRectangle 16"
                                                    BackgroundColor="#FFFFFF"
                                                    Padding="6">
                                                <Grid RowDefinitions="Auto,*,Auto"
                                                      RowSpacing="4">
                                                    <Border HeightRequest="24"
                                                            BackgroundColor="#FFE8DD"
                                                            StrokeThickness="0"
                                                            StrokeShape="RoundRectangle 999"
                                                            HorizontalOptions="Start"
                                                            IsVisible="{Binding IsPrimary}">
                                                        <Label Text="{Binding PrimaryBadgeText}"
                                                               FontSize="10"
                                                               FontAttributes="Bold"
                                                               TextColor="{StaticResource PrimaryDark}"
                                                               HorizontalTextAlignment="Center"
                                                               VerticalTextAlignment="Center"
                                                               Padding="10,0"/>
                                                    </Border>

                                                    <Image Grid.Row="1"
                                                           Source="{Binding Source}"
                                                           Aspect="AspectFill"/>

                                                    <Grid Grid.Row="2"
                                                          ColumnDefinitions="*,*"
                                                          ColumnSpacing="4">
                                                        <Button Grid.Column="0"
                                                                Text="Chính"
                                                                FontSize="10"
                                                                HeightRequest="28"
                                                                CornerRadius="9"
                                                                BackgroundColor="#E2E8F0"
                                                                TextColor="#0F172A"
                                                                Clicked="OnSetImageUrlPrimaryClicked"
                                                                CommandParameter="{Binding .}"/>
                                                        <Button Grid.Column="1"
                                                                Text="Xóa"
                                                                FontSize="10"
                                                                HeightRequest="28"
                                                                CornerRadius="9"
                                                                BackgroundColor="#FEE2E2"
                                                                TextColor="#991B1B"
                                                                Clicked="OnRemoveImageUrlClicked"
                                                                CommandParameter="{Binding .}"/>
                                                    </Grid>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </VerticalStackLayout>
                        </Border>

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="10"
                              Margin="0,4,0,0">
                            <Button Grid.Column="0"
                                    x:Name="UpdateButton"
                                    Text="Cập nhật"
                                    Clicked="OnUpdateClicked"
                                    HeightRequest="48"
                                    CornerRadius="14"
                                    BackgroundColor="{StaticResource Primary}"
                                    TextColor="White"
                                    FontAttributes="Bold"/>
                            <Button Grid.Column="1"
                                    x:Name="DeleteButton"
                                    Text="Xóa"
                                    Clicked="OnDeleteClicked"
                                    HeightRequest="48"
                                    CornerRadius="14"
                                    BackgroundColor="#FFE4E6"
                                    TextColor="#9F1239"
                                    FontAttributes="Bold"/>
                        </Grid>
                    </VerticalStackLayout>
                </ScrollView>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
