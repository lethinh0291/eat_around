<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ZesTour.Views.SettingsPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource AppBackground}">
    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="16,34,16,20"
                                 Spacing="12">
                <Grid ColumnDefinitions="Auto,*"
                      ColumnSpacing="10">
                    <Border WidthRequest="42"
                            HeightRequest="42"
                            StrokeThickness="0"
                            BackgroundColor="#FFFFFF"
                            StrokeShape="RoundRectangle 14">
                        <Label Text="←"
                               FontSize="18"
                               TextColor="{StaticResource TextPrimary}"
                               HorizontalTextAlignment="Center"
                               VerticalTextAlignment="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnBackTapped"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>
                    <VerticalStackLayout Grid.Column="1"
                                         Spacing="2"
                                         VerticalOptions="Center">
                           <Label x:Name="TitleLabel"
                               Text="Cài đặt"
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}"/>
                           <Label x:Name="SubtitleLabel"
                               Text="Tùy chỉnh trải nghiệm sử dụng"
                               FontSize="11"
                               TextColor="{StaticResource TextSecondary}"/>
                    </VerticalStackLayout>
                </Grid>

                <Border StrokeThickness="0"
                        BackgroundColor="{StaticResource PrimaryDark}"
                        StrokeShape="RoundRectangle 18"
                        Padding="12,10">
                      <Label x:Name="StorageHintLabel"
                          Text="Các lựa chọn dưới đây được lưu cục bộ trên thiết bị của bạn."
                           FontSize="11"
                           TextColor="#FFF1E8"/>
                </Border>

                <Border StrokeThickness="1"
                        Stroke="#E8D6CA"
                        BackgroundColor="#FFFFFF"
                        StrokeShape="RoundRectangle 18"
                        Padding="12">
                    <VerticalStackLayout Spacing="10">
                           <Label x:Name="SystemOptionsLabel"
                               Text="Tuỳ chọn hệ thống"
                               FontSize="15"
                               FontAttributes="Bold"
                               TextColor="{StaticResource PrimaryDark}"/>

                        <Border StrokeThickness="1"
                                Stroke="#E8D6CA"
                                BackgroundColor="#FFF9F6"
                                StrokeShape="RoundRectangle 14"
                                Padding="10,8">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label x:Name="AutoPlayLabel"
                                    Text="Bật tự động phát"
                                       TextColor="{StaticResource TextPrimary}"
                                       VerticalTextAlignment="Center"/>
                                <Switch Grid.Column="1"
                                        x:Name="AutoPlaySwitch"/>
                            </Grid>
                        </Border>

                        <Border StrokeThickness="1"
                                Stroke="#E8D6CA"
                                BackgroundColor="#FFF9F6"
                                StrokeShape="RoundRectangle 14"
                                Padding="10,8">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label x:Name="BatteryLabel"
                                    Text="Tối ưu pin"
                                       TextColor="{StaticResource TextPrimary}"
                                       VerticalTextAlignment="Center"/>
                                <Switch Grid.Column="1"
                                        x:Name="BatterySwitch"/>
                            </Grid>
                        </Border>

                        <Border StrokeThickness="1"
                                Stroke="#E8D6CA"
                                BackgroundColor="#FFF9F6"
                                StrokeShape="RoundRectangle 14"
                                Padding="10,8">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label x:Name="NotificationLabel"
                                    Text="Nhận thông báo"
                                       TextColor="{StaticResource TextPrimary}"
                                       VerticalTextAlignment="Center"/>
                                <Switch Grid.Column="1"
                                        x:Name="NotificationSwitch"/>
                            </Grid>
                        </Border>

                        <Border StrokeThickness="1"
                                Stroke="#E8D6CA"
                                BackgroundColor="#FFF9F6"
                                StrokeShape="RoundRectangle 14"
                                Padding="10,8">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label x:Name="StoreNarrationLabel"
                                       Text="Đọc mô tả quán ăn"
                                       TextColor="{StaticResource TextPrimary}"
                                       VerticalTextAlignment="Center"/>
                                <Switch Grid.Column="1"
                                        x:Name="StoreNarrationSwitch"/>
                            </Grid>
                        </Border>

                        <Border StrokeThickness="1"
                                Stroke="#E8D6CA"
                                BackgroundColor="#FFF9F6"
                                StrokeShape="RoundRectangle 14"
                                Padding="10,8">
                            <VerticalStackLayout Spacing="6">
                                <Label x:Name="InterfaceLanguageLabel"
                                       Text="Ngôn ngữ giao diện"
                                       TextColor="{StaticResource TextPrimary}"/>
                                <Picker x:Name="InterfaceLanguagePicker"
                                        Title="Chọn ngôn ngữ"
                                        TextColor="{StaticResource TextPrimary}"/>
                            </VerticalStackLayout>
                        </Border>

                        <Border StrokeThickness="1"
                                Stroke="#E8D6CA"
                                BackgroundColor="#FFF9F6"
                                StrokeShape="RoundRectangle 14"
                                Padding="10,8">
                            <VerticalStackLayout Spacing="6">
                                <Label x:Name="NarrationLanguageLabel"
                                       Text="Ngôn ngữ đọc"
                                       TextColor="{StaticResource TextPrimary}"/>
                                <Picker x:Name="NarrationLanguagePicker"
                                        Title="Chọn ngôn ngữ"
                                        TextColor="{StaticResource TextPrimary}"/>
                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>
                </Border>

                <Button x:Name="SaveButton"
                        Text="Lưu cài đặt"
                        Clicked="OnSaveClicked"
                        HeightRequest="46"
                        CornerRadius="14"
                        BackgroundColor="{StaticResource PrimaryDark}"
                        TextColor="White"
                        FontAttributes="Bold"/>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>


