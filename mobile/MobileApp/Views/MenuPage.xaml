<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ZesTour.Views.MenuPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource AppBackground}">
    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="16,32,16,14"
                                 Spacing="14">
                <Border StrokeThickness="0"
                        x:Name="WelcomeCardBorder"
                        BackgroundColor="{StaticResource Primary}"
                        StrokeShape="RoundRectangle 24"
                        Padding="14">
                    <Grid>
                        <Image x:Name="WelcomeCardImage"
                               Aspect="AspectFill"
                               Opacity="0.4"
                               IsVisible="False"/>
                        <BoxView x:Name="WelcomeCardOverlay"
                                 BackgroundColor="#441F2937"
                                 IsVisible="False"/>

                        <VerticalStackLayout Spacing="12">
                            <Grid ColumnDefinitions="Auto,*"
                                  ColumnSpacing="10">
                                <Border WidthRequest="48"
                                        HeightRequest="48"
                                        StrokeThickness="0"
                                        BackgroundColor="#FFF1E8"
                                        StrokeShape="RoundRectangle 16">
                                    <Grid>
                                        <Image x:Name="AvatarImage"
                                               Aspect="AspectFill"
                                               IsVisible="False"/>
                                        <Label x:Name="AvatarInitialsLabel"
                                               Text="U"
                                               FontSize="18"
                                               FontAttributes="Bold"
                                               HorizontalTextAlignment="Center"
                                               VerticalTextAlignment="Center"
                                               TextColor="{StaticResource PrimaryDark}"/>
                                    </Grid>
                                </Border>

                                <VerticalStackLayout Grid.Column="1"
                                                     Spacing="2"
                                                     VerticalOptions="Center">
                                    <Label x:Name="HelloLabel"
                                           Text="Xin chào"
                                           FontSize="11"
                                           TextColor="#FFF7F1"/>
                                    <Label Text="{Binding User.Name}"
                                           FontSize="20"
                                           FontAttributes="Bold"
                                           TextColor="White"/>
                                    <Border x:Name="RoleBadgeBorder"
                                            StrokeThickness="0"
                                            BackgroundColor="#FFF1E8"
                                            StrokeShape="RoundRectangle 999"
                                            Padding="8,3"
                                            HorizontalOptions="Start"
                                            Margin="0,3,0,0">
                                        <Label x:Name="RoleBadgeLabel"
                                               Text="Khách hàng"
                                               FontSize="10"
                                               FontAttributes="Bold"
                                               TextColor="#8E2F18"/>
                                    </Border>
                                </VerticalStackLayout>
                            </Grid>

                            <Border StrokeThickness="0"
                                    BackgroundColor="#B74424"
                                    StrokeShape="RoundRectangle 14"
                                    Padding="12,8">
                                <Entry x:Name="SearchEntry"
                                       Placeholder="Tìm tính năng: bản đồ, cài đặt, cửa hàng..."
                                       PlaceholderColor="#FFE4D6"
                                       TextColor="White"
                                       BackgroundColor="Transparent"
                                       FontSize="12"
                                       Completed="OnSearchCompleted"/>
                            </Border>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <Border StrokeThickness="1"
                        Stroke="#D6E1E9"
                        BackgroundColor="#FFFFFF"
                        StrokeShape="RoundRectangle 20"
                        Padding="12">
                    <VerticalStackLayout Spacing="8">
                        <Label x:Name="ExploreSectionLabel"
                               Text="Khám phá"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="#0F172A"/>

                        <Border x:Name="BannerSection"
                                IsVisible="False"
                                StrokeThickness="1"
                                Stroke="#D6E1E9"
                                BackgroundColor="#FFFFFF"
                                StrokeShape="RoundRectangle 14"
                                Padding="8"
                                Margin="0,2,0,4">
                            <VerticalStackLayout Spacing="8">
                                <CarouselView x:Name="BannerCarousel"
                                              HeightRequest="146"
                                              IndicatorView="BannerIndicator"
                                              PeekAreaInsets="6">
                                    <CarouselView.ItemTemplate>
                                        <DataTemplate>
                                            <Border StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 12"
                                                    Margin="2,0">
                                                <Image Source="{Binding ImageUrl}"
                                                       Aspect="AspectFill"
                                                       HeightRequest="146"/>
                                            </Border>
                                        </DataTemplate>
                                    </CarouselView.ItemTemplate>
                                </CarouselView>
                                <IndicatorView x:Name="BannerIndicator"
                                               HorizontalOptions="Center"
                                               IndicatorColor="#CFD9E3"
                                               SelectedIndicatorColor="{StaticResource Primary}"/>
                            </VerticalStackLayout>
                        </Border>

                        <Border StrokeThickness="1"
                                Stroke="#D6E1E9"
                                BackgroundColor="#F7FAFC"
                                StrokeShape="RoundRectangle 14"
                                Padding="12,10">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnOpenMapTapped"/>
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="10">
                                <VerticalStackLayout Grid.Column="0"
                                                     Spacing="1">
                                    <Label x:Name="DiscoverTitleLabel"
                                           Text="Khám phá điểm đến"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           TextColor="#0F172A"/>
                                    <Label x:Name="DiscoverSubtitleLabel"
                                           Text="Bản đồ, chỉ đường và phát mô tả tự động"
                                           FontSize="11"
                                           TextColor="#64748B"/>
                                </VerticalStackLayout>
                                <Label Grid.Column="1"
                                       Text="›"
                                       FontSize="20"
                                       TextColor="{StaticResource Primary}"
                                       VerticalTextAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border StrokeThickness="1"
                                Stroke="#D6E1E9"
                                BackgroundColor="#F7FAFC"
                                StrokeShape="RoundRectangle 14"
                                Padding="12,10">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnMyTripsTapped"/>
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="10">
                                <VerticalStackLayout Grid.Column="0"
                                                     Spacing="1">
                                    <Label x:Name="MyTripsTitleLabel"
                                           Text="Hành trình của tôi"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           TextColor="#0F172A"/>
                                    <Label x:Name="MyTripsSubtitleLabel"
                                           Text="Xem lại các điểm bạn đã chọn"
                                           FontSize="11"
                                           TextColor="#64748B"/>
                                </VerticalStackLayout>
                                <Label Grid.Column="1"
                                       Text="›"
                                       FontSize="20"
                                       TextColor="{StaticResource Primary}"
                                       VerticalTextAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border StrokeThickness="1"
                                Stroke="#D6E1E9"
                                BackgroundColor="#F7FAFC"
                                StrokeShape="RoundRectangle 14"
                                Padding="12,10">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnQrTriggerTapped"/>
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="10">
                                <VerticalStackLayout Grid.Column="0"
                                                     Spacing="1">
                                    <Label x:Name="QrTriggerTitleLabel"
                                           Text="Kích hoạt thuyết minh bằng QR"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           TextColor="#0F172A"/>
                                    <Label x:Name="QrTriggerSubtitleLabel"
                                           Text="Quét mã QR để mở nội dung thuyết minh phù hợp"
                                           FontSize="11"
                                           TextColor="#64748B"/>
                                </VerticalStackLayout>
                                <Label Grid.Column="1"
                                       Text="›"
                                       FontSize="20"
                                       TextColor="{StaticResource Primary}"
                                       VerticalTextAlignment="Center"/>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>
                </Border>

                <Border StrokeThickness="1"
                        Stroke="#D6E1E9"
                        BackgroundColor="#FFFFFF"
                        StrokeShape="RoundRectangle 20"
                        Padding="12">
                    <VerticalStackLayout Spacing="8">
                        <Label x:Name="AccountSectionLabel"
                               Text="Tài khoản"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="#0F172A"/>

                        <Border StrokeThickness="1"
                                Stroke="#D6E1E9"
                                BackgroundColor="#F7FAFC"
                                StrokeShape="RoundRectangle 14"
                                Padding="12,10">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnAccountTapped"/>
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="10">
                                <Label Grid.Column="0"
                                       x:Name="AccountPaymentLabel"
                                       Text="Tài khoản và thanh toán"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="#0F172A"
                                       VerticalTextAlignment="Center"/>
                                <Label Grid.Column="1"
                                       Text="›"
                                       FontSize="20"
                                       TextColor="{StaticResource Primary}"
                                       VerticalTextAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border StrokeThickness="1"
                                Stroke="#D6E1E9"
                                BackgroundColor="#F7FAFC"
                                StrokeShape="RoundRectangle 14"
                                Padding="12,10">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnSettingsTapped"/>
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="10">
                                <Label Grid.Column="0"
                                       x:Name="SettingsMenuLabel"
                                       Text="Cài đặt"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="#0F172A"
                                       VerticalTextAlignment="Center"/>
                                <Label Grid.Column="1"
                                       Text="›"
                                       FontSize="20"
                                       TextColor="{StaticResource Primary}"
                                       VerticalTextAlignment="Center"/>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>
                </Border>

                <Border StrokeThickness="1"
                        Stroke="#D6E1E9"
                        x:Name="StoreManagementCard"
                        BackgroundColor="#FFFFFF"
                        StrokeShape="RoundRectangle 20"
                        Padding="12">
                    <VerticalStackLayout Spacing="8">
                        <Label x:Name="SellerSectionLabel"
                               Text="Dành cho người bán"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="#0F172A"/>

                        <Border StrokeThickness="1"
                                Stroke="#D6E1E9"
                                BackgroundColor="#F7FAFC"
                                StrokeShape="RoundRectangle 14"
                                Padding="12,10">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnStoreManagementTapped"/>
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="10">
                                <Label Grid.Column="0"
                                       x:Name="StoreManagementLabel"
                                       Text="Quản lý cửa hàng của tôi"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="#0F172A"
                                       VerticalTextAlignment="Center"/>
                                <Label Grid.Column="1"
                                       Text="›"
                                       FontSize="20"
                                       TextColor="{StaticResource Primary}"
                                       VerticalTextAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border StrokeThickness="1"
                                Stroke="#D6E1E9"
                                x:Name="StoreRegistrationCard"
                                BackgroundColor="#F7FAFC"
                                StrokeShape="RoundRectangle 14"
                                Padding="12,10">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnStoreRegistrationTapped"/>
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="10">
                                <Label Grid.Column="0"
                                       x:Name="StoreRegistrationLabel"
                                       Text="Gửi đăng ký cửa hàng"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="#0F172A"
                                       VerticalTextAlignment="Center"/>
                                <Label Grid.Column="1"
                                       Text="›"
                                       FontSize="20"
                                       TextColor="{StaticResource Primary}"
                                       VerticalTextAlignment="Center"/>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>
                </Border>

                <Border StrokeThickness="1"
                        Stroke="#D6E1E9"
                        BackgroundColor="#FFFFFF"
                        StrokeShape="RoundRectangle 20"
                        Padding="12">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSupportTapped"/>
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="10">
                        <VerticalStackLayout Grid.Column="0"
                                             Spacing="1">
                            <Label x:Name="SupportTitleLabel"
                                   Text="Trợ giúp và phản hồi"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#0F172A"/>
                            <Label x:Name="SupportSubtitleLabel"
                                   Text="Báo lỗi hoặc góp ý để cải thiện ứng dụng"
                                   FontSize="11"
                                   TextColor="#64748B"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="1"
                               Text="›"
                               FontSize="20"
                               TextColor="{StaticResource Primary}"
                               VerticalTextAlignment="Center"/>
                    </Grid>
                </Border>
            </VerticalStackLayout>
        </ScrollView>

        <Border x:Name="SidebarFab"
                WidthRequest="58"
                HeightRequest="58"
                Margin="0,0,16,16"
                HorizontalOptions="End"
                VerticalOptions="End"
                StrokeThickness="0"
                BackgroundColor="{StaticResource Primary}"
                StrokeShape="RoundRectangle 18">
            <Label Text="☰"
                   FontSize="22"
                   TextColor="White"
                   HorizontalTextAlignment="Center"
                   VerticalTextAlignment="Center">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnOpenSidebarTapped"/>
                </Label.GestureRecognizers>
            </Label>
        </Border>

        <Grid x:Name="SidebarBackdrop"
              IsVisible="False"
              Opacity="0"
              InputTransparent="True"
              BackgroundColor="#40000000">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnSidebarBackdropTapped"/>
            </Grid.GestureRecognizers>
        </Grid>

        <Border x:Name="SidebarPanel"
                HorizontalOptions="End"
                VerticalOptions="Fill"
                WidthRequest="286"
                Margin="0,12,12,12"
                Padding="16,18"
                TranslationX="320"
                StrokeThickness="1"
                Stroke="#E8D6CA"
                BackgroundColor="#FFFFFF"
                StrokeShape="RoundRectangle 24">
            <VerticalStackLayout Spacing="12">
                <Grid ColumnDefinitions="*,Auto">
                    <Label x:Name="QuickActionsTitleLabel"
                           Text="Chức năng nhanh"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}"/>

                    <Border Grid.Column="1"
                            WidthRequest="34"
                            HeightRequest="34"
                            StrokeThickness="1"
                            Stroke="#E8D6CA"
                            BackgroundColor="#FFFFFF"
                            StrokeShape="RoundRectangle 12">
                        <Label Text="✕"
                               FontSize="13"
                               TextColor="{StaticResource TextPrimary}"
                               HorizontalTextAlignment="Center"
                               VerticalTextAlignment="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnSidebarBackdropTapped"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>
                </Grid>

                <Label x:Name="QuickActionsSubtitleLabel"
                       Text="Truy cập các thao tác chính mà không cần kéo xuống cuối trang."
                       FontSize="12"
                       TextColor="{StaticResource TextSecondary}"/>

                <Button x:Name="SidebarHomeButton"
                        Text="Trang chính"
                        Clicked="OnSidebarHomeTapped"
                        BackgroundColor="{StaticResource Secondary}"
                        TextColor="{StaticResource PrimaryDark}"
                        CornerRadius="14"
                        HeightRequest="46"
                        FontAttributes="Bold"/>

                <Button x:Name="SidebarProfileButton"
                        Text="Hồ sơ người dùng"
                        Clicked="OnSidebarProfileTapped"
                        BackgroundColor="{StaticResource Secondary}"
                        TextColor="{StaticResource PrimaryDark}"
                        CornerRadius="14"
                        HeightRequest="46"
                        FontAttributes="Bold"/>

                <Button x:Name="SidebarSettingsButton"
                        Text="Cài đặt"
                        Clicked="OnSidebarSettingsTapped"
                        BackgroundColor="{StaticResource Secondary}"
                        TextColor="{StaticResource PrimaryDark}"
                        CornerRadius="14"
                        HeightRequest="46"
                        FontAttributes="Bold"/>

                <Button x:Name="SidebarSupportButton"
                        Text="Trợ giúp và phản hồi"
                        Clicked="OnSidebarSupportTapped"
                        BackgroundColor="{StaticResource Secondary}"
                        TextColor="{StaticResource PrimaryDark}"
                        CornerRadius="14"
                        HeightRequest="46"
                        FontAttributes="Bold"/>

                <Button x:Name="SidebarLogoutButton"
                        Text="Đăng xuất"
                        Clicked="OnSidebarLogoutTapped"
                        BackgroundColor="#FEE2E2"
                        TextColor="#B91C1C"
                        CornerRadius="14"
                        HeightRequest="46"
                        FontAttributes="Bold"/>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>


