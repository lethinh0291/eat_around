<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ZesTour.Views.MenuPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#F7F5F1">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0"
                                 EndPoint="1,1">
                <GradientStop Color="#FCFBF8"
                              Offset="0"/>
                <GradientStop Color="#F4F0EA"
                              Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <BoxView Color="#F5E7DD"
                 Opacity="0.28"
                 HeightRequest="220"
                 WidthRequest="220"
                 CornerRadius="110"
                 TranslationX="-92"
                 TranslationY="-40"/>
        <BoxView Color="#DDE7E3"
                 Opacity="0.28"
                 HeightRequest="260"
                 WidthRequest="260"
                 CornerRadius="130"
                 TranslationX="240"
                 TranslationY="680"/>

        <ScrollView>
            <VerticalStackLayout Padding="16,28,16,20"
                                 Spacing="14">
                <Border StrokeThickness="0"
                        x:Name="WelcomeCardBorder"
                        BackgroundColor="#B97148"
                        StrokeShape="RoundRectangle 28"
                        HeightRequest="220"
                        Padding="0">
                    <Grid x:Name="WelcomeCardHost"
                          IsClippedToBounds="True">
                        <BoxView x:Name="WelcomeCardFallbackTint">
                            <BoxView.Background>
                                <LinearGradientBrush StartPoint="0,0"
                                                     EndPoint="1,1">
                                    <GradientStop Color="#EFE4D8"
                                                  Offset="0"/>
                                    <GradientStop Color="#E6D4C5"
                                                  Offset="0.55"/>
                                    <GradientStop Color="#D8C0AF"
                                                  Offset="1"/>
                                </LinearGradientBrush>
                            </BoxView.Background>
                        </BoxView>
                        <Image x:Name="WelcomeCardImage"
                               Aspect="AspectFill"
                               Opacity="1"
                               Scale="1.08"
                               HorizontalOptions="Fill"
                               VerticalOptions="Fill"
                               InputTransparent="True"
                               IsVisible="False"/>
                        <BoxView x:Name="WelcomeCardOverlay"
                                 BackgroundColor="#0A000000"
                                 IsVisible="False"/>

                        <VerticalStackLayout Spacing="12"
                                             Padding="16">
                            <Grid ColumnDefinitions="Auto,*,Auto"
                                  ColumnSpacing="10">
                                <Border WidthRequest="52"
                                        HeightRequest="52"
                                        StrokeThickness="0"
                                        BackgroundColor="#FFF5EC"
                                        StrokeShape="RoundRectangle 18">
                                    <Grid>
                                        <Image x:Name="AvatarImage"
                                               Aspect="AspectFill"
                                               IsVisible="False"/>
                                        <Label x:Name="AvatarInitialsLabel"
                                               Text="U"
                                               FontSize="19"
                                               FontAttributes="Bold"
                                               HorizontalTextAlignment="Center"
                                               VerticalTextAlignment="Center"
                                               TextColor="#9A3412"/>
                                    </Grid>
                                </Border>

                                <VerticalStackLayout Grid.Column="1"
                                                     Spacing="2"
                                                     VerticalOptions="Center">
                                    <Label x:Name="HelloLabel"
                                           Text="Xin chào"
                                           FontSize="11"
                                           TextColor="#FFF4EC"/>
                                    <Label Text="{Binding User.Name}"
                                           FontSize="22"
                                           FontAttributes="Bold"
                                           TextColor="#FFFDF9"/>
                                </VerticalStackLayout>

                                <Border Grid.Column="2"
                                        x:Name="RoleBadgeBorder"
                                        StrokeThickness="0"
                                        BackgroundColor="#FFF1E8"
                                        StrokeShape="RoundRectangle 999"
                                        Padding="10,5"
                                        HorizontalOptions="End"
                                        VerticalOptions="Start">
                                    <Label x:Name="RoleBadgeLabel"
                                           Text="Khách hàng"
                                           FontSize="10"
                                           FontAttributes="Bold"
                                           TextColor="#7A3F28"/>
                                </Border>
                            </Grid>

                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <Border StrokeThickness="0"
                        BackgroundColor="#FBFAF7"
                        StrokeShape="RoundRectangle 22"
                        Padding="12">
                    <VerticalStackLayout Spacing="10">
                        <Label x:Name="ExploreSectionLabel"
                               Text="Khám phá"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="#2F2A25"/>

                        <Border x:Name="BannerSection"
                                IsVisible="False"
                                StrokeThickness="1"
                                Stroke="#E7E0D7"
                                BackgroundColor="#FCFBF8"
                                StrokeShape="RoundRectangle 16"
                                Padding="8"
                                Margin="0,0,0,2">
                            <VerticalStackLayout Spacing="8">
                                <CarouselView x:Name="BannerCarousel"
                                              HeightRequest="150"
                                              IndicatorView="BannerIndicator"
                                              PeekAreaInsets="6">
                                    <CarouselView.ItemTemplate>
                                        <DataTemplate>
                                            <Border StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 14"
                                                    Margin="2,0">
                                                <Image Source="{Binding ImageUrl}"
                                                       Aspect="AspectFill"
                                                       HeightRequest="150"/>
                                            </Border>
                                        </DataTemplate>
                                    </CarouselView.ItemTemplate>
                                </CarouselView>
                                <IndicatorView x:Name="BannerIndicator"
                                               HorizontalOptions="Center"
                                               IndicatorColor="#D5CABC"
                                               SelectedIndicatorColor="#B66B46"/>
                            </VerticalStackLayout>
                        </Border>

                        <Border StrokeThickness="0"
                                BackgroundColor="#F4E8DD"
                                StrokeShape="RoundRectangle 18"
                                Padding="14,12">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnOpenMapTapped"/>
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="10">
                                <VerticalStackLayout Grid.Column="0"
                                                     Spacing="2"
                                                     VerticalOptions="Center">
                                    <Label x:Name="DiscoverTitleLabel"
                                           Text="Khám phá điểm đến"
                                           FontSize="15"
                                           FontAttributes="Bold"
                                           TextColor="#8A5A42"/>
                                    <Label x:Name="DiscoverSubtitleLabel"
                                           Text="Bản đồ, chỉ đường và phát mô tả tự động"
                                           FontSize="11"
                                           TextColor="#7B6A60"/>
                                </VerticalStackLayout>
                                <Label Grid.Column="1"
                                       Text="›"
                                       FontSize="24"
                                       TextColor="#B66B46"
                                       VerticalTextAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="8">
                            <Border Grid.Column="0"
                                    StrokeThickness="0"
                                    BackgroundColor="#EEF0F4"
                                    StrokeShape="RoundRectangle 16"
                                    Padding="10,10">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnMyTripsTapped"/>
                                </Border.GestureRecognizers>
                                <VerticalStackLayout Spacing="4">
                                    <Label x:Name="MyTripsTitleLabel"
                                           Text="Hành trình của tôi"
                                           FontSize="13"
                                           FontAttributes="Bold"
                                           TextColor="#475569"/>
                                    <Label x:Name="MyTripsSubtitleLabel"
                                           Text="Xem lại các điểm bạn đã chọn"
                                           FontSize="10"
                                           TextColor="#64748B"
                                           MaxLines="2"
                                           LineBreakMode="TailTruncation"/>
                                </VerticalStackLayout>
                            </Border>

                            <Border Grid.Column="1"
                                    StrokeThickness="0"
                                    BackgroundColor="#EEF6F3"
                                    StrokeShape="RoundRectangle 16"
                                    Padding="10,10">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnQrTriggerTapped"/>
                                </Border.GestureRecognizers>
                                <VerticalStackLayout Spacing="4">
                                    <Label x:Name="QrTriggerTitleLabel"
                                           Text="Kích hoạt thuyết minh bằng QR"
                                           FontSize="13"
                                           FontAttributes="Bold"
                                           TextColor="#3D6461"
                                           MaxLines="2"
                                           LineBreakMode="TailTruncation"/>
                                    <Label x:Name="QrTriggerSubtitleLabel"
                                           Text="Quét mã QR để mở nội dung thuyết minh phù hợp"
                                           FontSize="10"
                                           TextColor="#64748B"
                                           MaxLines="2"
                                           LineBreakMode="TailTruncation"/>
                                </VerticalStackLayout>
                            </Border>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Border StrokeThickness="0"
                        BackgroundColor="#FBFAF7"
                        StrokeShape="RoundRectangle 22"
                        Padding="12">
                    <VerticalStackLayout Spacing="8">
                        <Label x:Name="AccountSectionLabel"
                               Text="Tài khoản"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="#2F2A25"/>

                        <Border StrokeThickness="1"
                                Stroke="#E6DED5"
                                BackgroundColor="#FCFBF8"
                                StrokeShape="RoundRectangle 16"
                                Padding="12,10">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnAccountTapped"/>
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="10">
                                <Label Grid.Column="0"
                                       x:Name="AccountPaymentLabel"
                                       Text="Tài khoản và thanh toán"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="#3E352F"
                                       VerticalTextAlignment="Center"/>
                                <Label Grid.Column="1"
                                       Text="›"
                                       FontSize="20"
                                       TextColor="#B66B46"
                                       VerticalTextAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border StrokeThickness="1"
                                Stroke="#E6DED5"
                                BackgroundColor="#FCFBF8"
                                StrokeShape="RoundRectangle 16"
                                Padding="12,10">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnSettingsTapped"/>
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="10">
                                <Label Grid.Column="0"
                                       x:Name="SettingsMenuLabel"
                                       Text="Cài đặt"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="#3E352F"
                                       VerticalTextAlignment="Center"/>
                                <Label Grid.Column="1"
                                       Text="›"
                                       FontSize="20"
                                       TextColor="#B66B46"
                                       VerticalTextAlignment="Center"/>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>
                </Border>

                <Border x:Name="StoreManagementCard"
                        StrokeThickness="0"
                        BackgroundColor="#FBFAF7"
                        StrokeShape="RoundRectangle 22"
                        Padding="12">
                    <VerticalStackLayout Spacing="8">
                        <Label x:Name="SellerSectionLabel"
                               Text="Dành cho người bán"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="#2F2A25"/>

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="8">
                            <Border Grid.Column="0"
                                    StrokeThickness="0"
                                    BackgroundColor="#F4E8DD"
                                    StrokeShape="RoundRectangle 16"
                                    Padding="10,10">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnStoreManagementTapped"/>
                                </Border.GestureRecognizers>
                                <VerticalStackLayout Spacing="4">
                                    <Label x:Name="StoreManagementLabel"
                                           Text="Quản lý cửa hàng của tôi"
                                           FontSize="13"
                                           FontAttributes="Bold"
                                           TextColor="#8A5A42"
                                           MaxLines="2"
                                           LineBreakMode="TailTruncation"/>
                                </VerticalStackLayout>
                            </Border>

                            <Border Grid.Column="1"
                                    x:Name="StoreRegistrationCard"
                                    StrokeThickness="0"
                                    BackgroundColor="#EEF2F8"
                                    StrokeShape="RoundRectangle 16"
                                    Padding="10,10">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnStoreRegistrationTapped"/>
                                </Border.GestureRecognizers>
                                <VerticalStackLayout Spacing="4">
                                    <Label x:Name="StoreRegistrationLabel"
                                           Text="Gửi đăng ký cửa hàng"
                                           FontSize="13"
                                           FontAttributes="Bold"
                                           TextColor="#5B6273"
                                           MaxLines="2"
                                           LineBreakMode="TailTruncation"/>
                                </VerticalStackLayout>
                            </Border>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Border StrokeThickness="0"
                        BackgroundColor="#FBFAF7"
                        StrokeShape="RoundRectangle 22"
                        Padding="12">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSupportTapped"/>
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="10">
                        <VerticalStackLayout Grid.Column="0"
                                             Spacing="1">
                            <Label x:Name="SupportTitleLabel"
                                   Text="Trợ giúp và phản hồi"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#2F2A25"/>
                            <Label x:Name="SupportSubtitleLabel"
                                   Text="Báo lỗi hoặc góp ý để cải thiện ứng dụng"
                                   FontSize="11"
                                   TextColor="#64748B"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="1"
                               Text="›"
                               FontSize="20"
                               TextColor="#B66B46"
                               VerticalTextAlignment="Center"/>
                    </Grid>
                </Border>
            </VerticalStackLayout>
        </ScrollView>

        <Border x:Name="SidebarFab"
                WidthRequest="58"
                HeightRequest="58"
                Margin="0,0,16,16"
                HorizontalOptions="End"
                VerticalOptions="End"
                StrokeThickness="0"
                BackgroundColor="#B66B46"
                StrokeShape="RoundRectangle 18">
            <Label Text="Menu"
                   FontSize="12"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalTextAlignment="Center"
                   VerticalTextAlignment="Center">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnOpenSidebarTapped"/>
                </Label.GestureRecognizers>
            </Label>
        </Border>

        <Grid x:Name="SidebarBackdrop"
              IsVisible="False"
              Opacity="0"
              InputTransparent="True"
              BackgroundColor="#40000000">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnSidebarBackdropTapped"/>
            </Grid.GestureRecognizers>
        </Grid>

        <Border x:Name="SidebarPanel"
                HorizontalOptions="End"
                VerticalOptions="Fill"
                WidthRequest="286"
                Margin="0,12,12,12"
                Padding="16,18"
                TranslationX="320"
                StrokeThickness="1"
                Stroke="#E6DED5"
                BackgroundColor="#FCFBF8"
                StrokeShape="RoundRectangle 24">
            <VerticalStackLayout Spacing="12">
                <Grid ColumnDefinitions="*,Auto">
                    <Label x:Name="QuickActionsTitleLabel"
                           Text="Chức năng nhanh"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="#2F2A25"/>

                    <Border Grid.Column="1"
                            WidthRequest="34"
                            HeightRequest="34"
                            StrokeThickness="1"
                            Stroke="#E6DED5"
                            BackgroundColor="#F9F7F4"
                            StrokeShape="RoundRectangle 12">
                        <Label Text="✕"
                               FontSize="13"
                               TextColor="#3E352F"
                               HorizontalTextAlignment="Center"
                               VerticalTextAlignment="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnSidebarBackdropTapped"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>
                </Grid>

                <Label x:Name="QuickActionsSubtitleLabel"
                       Text="Truy cập các thao tác chính mà không cần kéo xuống cuối trang."
                       FontSize="12"
                       TextColor="{StaticResource TextSecondary}"/>

                <Button x:Name="SidebarHomeButton"
                        Text="Trang chính"
                        Clicked="OnSidebarHomeTapped"
                        BackgroundColor="#F3ECE5"
                        TextColor="#5A4B41"
                        CornerRadius="14"
                        HeightRequest="46"
                        FontAttributes="Bold"/>

                <Button x:Name="SidebarProfileButton"
                        Text="Hồ sơ người dùng"
                        Clicked="OnSidebarProfileTapped"
                        BackgroundColor="#F3ECE5"
                        TextColor="#5A4B41"
                        CornerRadius="14"
                        HeightRequest="46"
                        FontAttributes="Bold"/>

                <Button x:Name="SidebarSettingsButton"
                        Text="Cài đặt"
                        Clicked="OnSidebarSettingsTapped"
                        BackgroundColor="#F3ECE5"
                        TextColor="#5A4B41"
                        CornerRadius="14"
                        HeightRequest="46"
                        FontAttributes="Bold"/>

                <Button x:Name="SidebarSupportButton"
                        Text="Trợ giúp và phản hồi"
                        Clicked="OnSidebarSupportTapped"
                        BackgroundColor="#F3ECE5"
                        TextColor="#5A4B41"
                        CornerRadius="14"
                        HeightRequest="46"
                        FontAttributes="Bold"/>

                <Button x:Name="SidebarLogoutButton"
                        Text="Đăng xuất"
                        Clicked="OnSidebarLogoutTapped"
                        BackgroundColor="#FEE2E2"
                        TextColor="#B91C1C"
                        CornerRadius="14"
                        HeightRequest="46"
                        FontAttributes="Bold"/>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>


