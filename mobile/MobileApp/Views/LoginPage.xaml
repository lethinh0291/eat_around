<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ZesTour.Views.LoginPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource AppBackground}">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0"
                                 EndPoint="1,1">
                <GradientStop Color="#F4F8FA"
                              Offset="0"/>
                <GradientStop Color="#EDF3F6"
                              Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <ScrollView>
            <VerticalStackLayout Padding="22,54,22,24"
                                 Spacing="16">
                <Border StrokeThickness="0"
                        BackgroundColor="{StaticResource Primary}"
                        StrokeShape="RoundRectangle 26"
                        Padding="18">
                    <Grid ColumnDefinitions="Auto,*"
                          ColumnSpacing="12">
                        <Border WidthRequest="56"
                                HeightRequest="56"
                                StrokeThickness="0"
                                BackgroundColor="#FFF1E8"
                                StrokeShape="RoundRectangle 18">
                            <Image Source="loading_logo.svg"
                                   WidthRequest="34"
                                   HeightRequest="34"
                                   Aspect="AspectFit"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Border>

                        <VerticalStackLayout Grid.Column="1"
                                             Spacing="4"
                                             VerticalOptions="Center">
                            <Label Text="ZesTour"
                                   FontSize="12"
                                   TextColor="#FFF7F1"/>
                            <Label x:Name="WelcomeLabel"
                                Text="Chào mừng quay lại"
                                   FontSize="23"
                                   FontAttributes="Bold"
                                   TextColor="White"/>
                            <Label x:Name="ContinueDescriptionLabel"
                                Text="Đăng nhập để tiếp tục bản đồ, hành trình và cửa hàng của bạn"
                                   FontSize="12"
                                   TextColor="#FFF7F1"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <Border StrokeThickness="1"
                        Stroke="#D6E1E9"
                        BackgroundColor="#FFFFFF"
                        StrokeShape="RoundRectangle 22"
                        Padding="16">
                    <VerticalStackLayout Spacing="12">
                           <Label x:Name="AccountInfoLabel"
                               Text="Thông tin tài khoản"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="#0F172A"/>

                        <Border StrokeThickness="1"
                                Stroke="#D6E1E9"
                                BackgroundColor="#F7FAFC"
                                StrokeShape="RoundRectangle 14"
                                Padding="12,10">
                            <VerticalStackLayout Spacing="3">
                                <Label x:Name="IdentifierLabel"
                                    Text="Email hoặc tên đăng nhập"
                                       FontSize="11"
                                       TextColor="#475569"/>
                                <Entry x:Name="IdentifierEntry"
                                       Placeholder="vd: minh@zestour.vn"
                                       TextColor="#0F172A"
                                       PlaceholderColor="#64748B"
                                       BackgroundColor="Transparent"
                                       ClearButtonVisibility="WhileEditing"
                                       Keyboard="Email"/>
                            </VerticalStackLayout>
                        </Border>

                        <Border StrokeThickness="1"
                                Stroke="#D6E1E9"
                                BackgroundColor="#F7FAFC"
                                StrokeShape="RoundRectangle 14"
                                Padding="12,10">
                            <VerticalStackLayout Spacing="3">
                                <Label x:Name="PasswordLabel"
                                    Text="Mật khẩu"
                                       FontSize="11"
                                       TextColor="#475569"/>
                                <Entry x:Name="PasswordEntry"
                                       Placeholder="Nhập mật khẩu"
                                       IsPassword="True"
                                       TextColor="#0F172A"
                                       PlaceholderColor="#64748B"
                                       BackgroundColor="Transparent"/>
                            </VerticalStackLayout>
                        </Border>

                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="8">
                            <CheckBox x:Name="RememberCheckBox"
                                      IsChecked="True"
                                      Color="{StaticResource Primary}"/>
                            <Label Grid.Column="1"
                                   x:Name="RememberLabel"
                                   Text="Ghi nhớ đăng nhập trên thiết bị này"
                                   FontSize="12"
                                   TextColor="#475569"
                                   VerticalTextAlignment="Center"/>
                        </Grid>

                            <Button x:Name="LoginButton"
                                Text="Đăng nhập"
                                Clicked="OnLoginClicked"
                                BackgroundColor="{StaticResource Primary}"
                                TextColor="White"
                                CornerRadius="14"
                                HeightRequest="50"
                                FontAttributes="Bold"/>

                        <Label x:Name="MessageLabel"
                               Text=""
                               FontSize="12"
                               TextColor="#DC2626"/>

                        <Button x:Name="CreateAccountButton"
                            Text="Tạo tài khoản mới"
                                Clicked="OnRegisterClicked"
                                BackgroundColor="{StaticResource Secondary}"
                                TextColor="{StaticResource PrimaryDark}"
                                BorderColor="#F5D0BF"
                                BorderWidth="1"
                                CornerRadius="14"
                                HeightRequest="46"
                                FontAttributes="Bold"/>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>


