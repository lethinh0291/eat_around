<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ZesTour.Views.LoginPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource AppBackground}">
    <Grid>
        <Grid.Background>
            <RadialGradientBrush Center="0.24,0.14"
                                 Radius="1">
                <GradientStop Color="#FFF9F2"
                              Offset="0"/>
                <GradientStop Color="#FFF2E5"
                              Offset="0.62"/>
                <GradientStop Color="#FFE8D2"
                              Offset="1"/>
            </RadialGradientBrush>
        </Grid.Background>

        <Ellipse Fill="#24F97316"
                 WidthRequest="280"
                 HeightRequest="280"
                 HorizontalOptions="Start"
                 VerticalOptions="Start"
                 Margin="-120,-110,0,0"/>

        <Ellipse Fill="#1CF97316"
                 WidthRequest="220"
                 HeightRequest="220"
                 HorizontalOptions="End"
                 VerticalOptions="End"
                 Margin="0,0,-90,-70"/>

        <ScrollView>
            <VerticalStackLayout Padding="24,54,24,28"
                                 Spacing="18">
                <Border StrokeThickness="0"
                        BackgroundColor="#FFFFFF"
                        StrokeShape="RoundRectangle 32"
                        Padding="20">
                    <VerticalStackLayout Spacing="16">
                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="14">
                            <Border WidthRequest="62"
                                    HeightRequest="62"
                                    StrokeThickness="0"
                                    BackgroundColor="#FFF7ED"
                                    StrokeShape="RoundRectangle 22">
                                <Image Source="loading_logo.svg"
                                       WidthRequest="38"
                                       HeightRequest="38"
                                       Aspect="AspectFit"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>

                            <VerticalStackLayout Grid.Column="1"
                                                 Spacing="4"
                                                 VerticalOptions="Center">
                                <Label Text="Chào mừng trở lại"
                                       FontSize="12"
                                       TextColor="{StaticResource TextSecondary}"/>
                                <Label Text="Đăng nhập để tiếp tục chuyến đi"
                                       FontSize="26"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}"/>
                                <Label Text="Lưu vị trí, xem lộ trình và mở hồ sơ cá nhân của bạn"
                                       FontSize="12"
                                       TextColor="{StaticResource TextSecondary}"/>
                            </VerticalStackLayout>
                        </Grid>

                        <Grid ColumnDefinitions="Auto,Auto,Auto"
                              ColumnSpacing="8">
                            <Border StrokeThickness="0"
                                    BackgroundColor="#FFF4EA"
                                    Padding="10,6"
                                    StrokeShape="RoundRectangle 999">
                                <Label Text="Bản đồ"
                                       TextColor="{StaticResource TextPrimary}"
                                       FontSize="11"/>
                            </Border>
                            <Border Grid.Column="1"
                                    StrokeThickness="0"
                                    BackgroundColor="#FFF4EA"
                                    Padding="10,6"
                                    StrokeShape="RoundRectangle 999">
                                <Label Text="Đăng ký"
                                       TextColor="{StaticResource TextPrimary}"
                                       FontSize="11"/>
                            </Border>
                            <Border Grid.Column="2"
                                    StrokeThickness="0"
                                    BackgroundColor="#FFF4EA"
                                    Padding="10,6"
                                    StrokeShape="RoundRectangle 999">
                                <Label Text="Hồ sơ"
                                       TextColor="{StaticResource TextPrimary}"
                                       FontSize="11"/>
                            </Border>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Border StrokeThickness="1"
                        Stroke="{StaticResource BorderSoftBrush}"
                        BackgroundColor="#FFFFFF"
                        StrokeShape="RoundRectangle 28"
                        Padding="18">
                    <VerticalStackLayout Spacing="14">
                        <Label Text="Đăng nhập"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}"/>

                        <VerticalStackLayout Spacing="8">
                            <Label Text="Email hoặc tên đăng nhập"
                                   FontSize="12"
                                   TextColor="{StaticResource TextSecondary}"/>
                            <Entry x:Name="IdentifierEntry"
                                   Placeholder="vd: minh@zestour.vn"
                                   TextColor="{StaticResource TextPrimary}"
                                   PlaceholderColor="{StaticResource Gray500}"
                                   BackgroundColor="#FFF7ED"
                                   Margin="0"
                                   ClearButtonVisibility="WhileEditing"
                                   Keyboard="Email"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="8">
                            <Label Text="Mật khẩu"
                                   FontSize="12"
                                   TextColor="{StaticResource TextSecondary}"/>
                            <Entry x:Name="PasswordEntry"
                                   Placeholder="Nhập mật khẩu"
                                   IsPassword="True"
                                   TextColor="{StaticResource TextPrimary}"
                                   PlaceholderColor="{StaticResource Gray500}"
                                   BackgroundColor="#FFF7ED"
                                   Margin="0"/>
                        </VerticalStackLayout>

                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="10">
                            <CheckBox x:Name="RememberCheckBox"
                                      IsChecked="True"
                                      Color="{StaticResource Primary}"/>
                            <VerticalStackLayout Grid.Column="1"
                                                 Spacing="2"
                                                 VerticalOptions="Center">
                                <Label Text="Ghi nhớ đăng nhập"
                                       FontSize="12"
                                       TextColor="{StaticResource TextPrimary}"/>
                                <Label Text="Bật để quay lại thẳng bản đồ sau lần mở tiếp theo"
                                       FontSize="11"
                                       TextColor="{StaticResource TextSecondary}"/>
                            </VerticalStackLayout>
                        </Grid>

                        <Button Text="Đăng nhập"
                                Clicked="OnLoginClicked"
                                BackgroundColor="{StaticResource Primary}"
                                TextColor="White"
                                CornerRadius="18"
                                HeightRequest="52"/>

                        <Label x:Name="MessageLabel"
                               Text=""
                               FontSize="12"
                               TextColor="#FCA5A5"/>

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="12">
                            <Button Text="Đăng ký"
                                    Clicked="OnRegisterClicked"
                                    BackgroundColor="#FFFFFF"
                                    TextColor="{StaticResource TextPrimary}"
                                    BorderColor="{StaticResource BorderSoftBrush}"
                                    BorderWidth="1"
                                    CornerRadius="18"
                                    HeightRequest="48"/>

                            <Border Grid.Column="1"
                                    BackgroundColor="#FFFFFF"
                                    StrokeThickness="1"
                                    Stroke="{StaticResource BorderSoftBrush}"
                                    StrokeShape="RoundRectangle 18"
                                    HeightRequest="48">
                                <Label Text="Hồ sơ sẽ xuất hiện sau khi đăng nhập"
                                       FontSize="11"
                                       TextColor="{StaticResource TextSecondary}"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center"/>
                            </Border>
                        </Grid>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>