<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ZesTour.Views.StoreRegistrationPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource AppBackground}">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0"
                                 EndPoint="1,1">
                <GradientStop Color="#FFFDFB"
                              Offset="0"/>
                <GradientStop Color="#FFF5EE"
                              Offset="0.55"/>
                <GradientStop Color="#FFF0E6"
                              Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <ScrollView>
            <VerticalStackLayout Padding="20,48,20,24"
                                 Spacing="14">
                <Grid ColumnDefinitions="Auto,*"
                      ColumnSpacing="10">
                    <Border WidthRequest="42"
                            HeightRequest="42"
                            StrokeThickness="1"
                            Stroke="#E8D6CA"
                            BackgroundColor="#FFFFFF"
                            StrokeShape="RoundRectangle 14">
                        <Label Text="←"
                               FontSize="18"
                               TextColor="{StaticResource TextPrimary}"
                               HorizontalTextAlignment="Center"
                               VerticalTextAlignment="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnBackTapped"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>

                    <VerticalStackLayout Grid.Column="1"
                                         Spacing="2"
                                         VerticalOptions="Center">
                           <Label x:Name="StoreRegistrationTitleLabel"
                               Text="Đăng ký cửa hàng"
                               FontSize="22"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}"/>
                           <Label x:Name="StoreRegistrationSubtitleLabel"
                               Text="Gửi thông tin để xét duyệt xuất hiện trên ứng dụng"
                               FontSize="11"
                               TextColor="{StaticResource TextSecondary}"/>
                    </VerticalStackLayout>
                </Grid>

                <Border StrokeThickness="1"
                        Stroke="#E8D6CA"
                        BackgroundColor="#FFFFFF"
                        StrokeShape="RoundRectangle 22"
                        Padding="14">
                    <VerticalStackLayout Spacing="10">
                        <Entry x:Name="StoreNameEntry"
                               Placeholder="Tên cửa hàng"
                               TextColor="#0F172A"
                               PlaceholderColor="#64748B"/>
                        <Entry x:Name="OwnerNameEntry"
                               Placeholder="Tên chủ cửa hàng"
                               TextColor="#0F172A"
                               PlaceholderColor="#64748B"/>
                        <Entry x:Name="PhoneEntry"
                               Placeholder="Số điện thoại"
                               Keyboard="Telephone"
                               TextColor="#0F172A"
                               PlaceholderColor="#64748B"/>
                        <Entry x:Name="AddressEntry"
                               Placeholder="Địa chỉ"
                               TextColor="#0F172A"
                               PlaceholderColor="#64748B"/>

                        <CollectionView x:Name="AddressSuggestionsCollectionView"
                                        IsVisible="False"
                                        SelectionMode="Single"
                                        SelectionChanged="OnAddressSuggestionSelected"
                                        HeightRequest="160">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border StrokeThickness="1"
                                            Stroke="#E8D6CA"
                                            BackgroundColor="#FFFFFF"
                                            StrokeShape="RoundRectangle 12"
                                            Padding="10"
                                            Margin="0,0,0,6">
                                        <Label Text="{Binding DisplayName}"
                                               FontSize="12"
                                               TextColor="#1F2937"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="2"/>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <Border StrokeThickness="1"
                                Stroke="#E5E7EB"
                                BackgroundColor="#FFFFFF"
                                StrokeShape="RoundRectangle 12"
                                Padding="6"
                                IsVisible="False"
                                x:Name="AddressMapPreviewContainer">
                            <VerticalStackLayout Spacing="4">
                                <Label x:Name="AddressMapPreviewLabel"
                                       Text="Vị trí địa chỉ"
                                       FontSize="11"
                                       TextColor="#7C2D12"/>
                                <WebView x:Name="AddressMapPreview"
                                         HeightRequest="170"/>
                            </VerticalStackLayout>
                        </Border>

                        <Entry x:Name="CategoryEntry"
                               Placeholder="Loại hình (ăn uống, cafe,...)"
                               TextColor="#0F172A"
                               PlaceholderColor="#64748B"/>
                        <Editor x:Name="DescriptionEditor"
                                Placeholder="Mô tả ngắn về cửa hàng"
                                AutoSize="TextChanges"
                                HeightRequest="110"
                                TextColor="#0F172A"
                                PlaceholderColor="#64748B"/>

                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="10">
                            <Button x:Name="PickImageButton"
                                Grid.Column="0"
                                    Text="Thêm ảnh"
                                    Clicked="OnPickImageClicked"
                                    HeightRequest="44"
                                    CornerRadius="12"
                                    BackgroundColor="{StaticResource Secondary}"
                                    TextColor="{StaticResource PrimaryDark}"/>
                            <VerticalStackLayout Grid.Column="1"
                                                 Spacing="2"
                                                 VerticalOptions="Center">
                                <Label x:Name="SelectedImageLabel"
                                       Text="Chưa chọn ảnh"
                                       FontSize="12"
                                       TextColor="{StaticResource PrimaryDark}"/>
                                    <Label x:Name="SelectedImageHintLabel"
                                        Text="Kéo thả để sắp xếp, bấm Đặt chính để chọn ảnh đại diện."
                                       FontSize="10"
                                       TextColor="#64748B"/>
                            </VerticalStackLayout>
                        </Grid>

                        <CollectionView x:Name="SelectedImagesCollectionView"
                                        IsVisible="False"
                                        SelectionMode="None"
                                        HeightRequest="176">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Horizontal"
                                                   ItemSpacing="10"/>
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border WidthRequest="120"
                                            HeightRequest="162"
                                            StrokeThickness="1"
                                            Stroke="#D6E1E9"
                                            StrokeShape="RoundRectangle 16"
                                            BackgroundColor="#F7FAFC"
                                            Padding="6">
                                        <Border.GestureRecognizers>
                                            <DragGestureRecognizer DragStarting="OnSelectedImageDragStarting"/>
                                            <DropGestureRecognizer DragOver="OnSelectedImageDragOver"
                                                                   Drop="OnSelectedImageDrop"/>
                                        </Border.GestureRecognizers>

                                        <Grid RowDefinitions="Auto,*,Auto"
                                              RowSpacing="6">
                                            <Grid ColumnDefinitions="*,Auto"
                                                  VerticalOptions="Start">
                                                                                                <Label Text="{Binding PrimaryBadgeText}"
                                                       FontSize="10"
                                                       TextColor="White"
                                                       BackgroundColor="{StaticResource PrimaryDark}"
                                                       Padding="8,2"
                                                       IsVisible="{Binding IsPrimary}"/>
                                                <Label Grid.Column="1"
                                                       Text="⇅"
                                                       FontSize="14"
                                                       TextColor="#64748B"
                                                       HorizontalTextAlignment="End"/>
                                            </Grid>

                                            <Image Grid.Row="1"
                                                   Source="{Binding PreviewSource}"
                                                   Aspect="AspectFill"
                                                   HeightRequest="92"/>

                                            <Grid Grid.Row="2"
                                                  ColumnDefinitions="*,*"
                                                  ColumnSpacing="6">
                                                <Button Grid.Column="0"
                                                    Text="{Binding SetPrimaryText}"
                                                        FontSize="11"
                                                        HeightRequest="28"
                                                        CornerRadius="10"
                                                        BackgroundColor="{StaticResource Secondary}"
                                                        TextColor="{StaticResource PrimaryDark}"
                                                        Clicked="OnSetSelectedImagePrimaryClicked"
                                                        CommandParameter="{Binding .}"/>
                                                <Button Grid.Column="1"
                                                    Text="{Binding DeleteText}"
                                                        FontSize="11"
                                                        HeightRequest="28"
                                                        CornerRadius="10"
                                                        BackgroundColor="#FFF1E8"
                                                        TextColor="{StaticResource PrimaryDark}"
                                                        Clicked="OnRemoveSelectedImageClicked"
                                                        CommandParameter="{Binding .}"/>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <Label x:Name="MessageLabel"
                               FontSize="12"
                               TextColor="#B91C1C"/>

                        <Button x:Name="SubmitRegistrationButton"
                            Text="Gửi đăng ký"
                                Clicked="OnSubmitClicked"
                                HeightRequest="52"
                                CornerRadius="16"
                                BackgroundColor="{StaticResource Primary}"
                                TextColor="White"/>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>


