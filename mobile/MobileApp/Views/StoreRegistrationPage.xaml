<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ZesTour.Views.StoreRegistrationPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource AppBackground}">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0"
                                 EndPoint="1,1">
                <GradientStop Color="#ffffff"
                              Offset="0"/>
                <GradientStop Color="#ffffff"
                              Offset="0.55"/>
                <GradientStop Color="#ffffff"
                              Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <ScrollView>
            <VerticalStackLayout Padding="20,48,20,24"
                                 Spacing="14">
                <Grid ColumnDefinitions="Auto,*"
                      ColumnSpacing="10">
                    <Border WidthRequest="42"
                            HeightRequest="42"
                            StrokeThickness="0"
                            BackgroundColor="#ffffff"
                            StrokeShape="RoundRectangle 14">
                        <Label Text="←"
                               FontSize="18"
                               TextColor="{StaticResource TextPrimary}"
                               HorizontalTextAlignment="Center"
                               VerticalTextAlignment="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnBackTapped"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>

                    <VerticalStackLayout Grid.Column="1"
                                         Spacing="2"
                                         VerticalOptions="Center">
                        <Label Text="Đăng ký cửa hàng"
                               FontSize="22"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}"/>
                        <Label Text="Gửi thông tin để xét duyệt xuất hiện trên ứng dụng"
                               FontSize="11"
                               TextColor="#334155"/>
                    </VerticalStackLayout>
                </Grid>

                <Border StrokeThickness="1"
                        Stroke="{StaticResource BorderSoftBrush}"
                        BackgroundColor="#FFFFFF"
                        StrokeShape="RoundRectangle 22"
                        Padding="14">
                    <VerticalStackLayout Spacing="10">
                        <Entry x:Name="StoreNameEntry"
                               Placeholder="Tên cửa hàng"
                               TextColor="#111827"
                               PlaceholderColor="#6B7280"/>
                        <Entry x:Name="OwnerNameEntry"
                               Placeholder="Tên chủ cửa hàng"
                               TextColor="#111827"
                               PlaceholderColor="#6B7280"/>
                        <Entry x:Name="PhoneEntry"
                               Placeholder="Số điện thoại"
                               Keyboard="Telephone"
                               TextColor="#111827"
                               PlaceholderColor="#6B7280"/>
                        <Entry x:Name="AddressEntry"
                               Placeholder="Địa chỉ"
                               TextColor="#111827"
                               PlaceholderColor="#6B7280"/>
                        <Entry x:Name="CategoryEntry"
                               Placeholder="Loại hình (ăn uống, cafe,...)"
                               TextColor="#111827"
                               PlaceholderColor="#6B7280"/>
                        <Editor x:Name="DescriptionEditor"
                                Placeholder="Mô tả ngắn về cửa hàng"
                                AutoSize="TextChanges"
                                HeightRequest="110"
                                TextColor="#111827"
                                PlaceholderColor="#6B7280"/>

                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="10">
                            <Button Grid.Column="0"
                                Text="Chọn ảnh"
                                Clicked="OnPickImageClicked"
                                HeightRequest="44"
                                CornerRadius="12"
                                BackgroundColor="#E2E8F0"
                                TextColor="#0F172A"/>
                            <Label Grid.Column="1"
                               x:Name="SelectedImageLabel"
                               Text="Chưa chọn ảnh"
                               FontSize="12"
                               TextColor="#64748B"
                               VerticalTextAlignment="Center"/>
                        </Grid>

                        <Image x:Name="StoreImagePreview"
                               HeightRequest="140"
                               Aspect="AspectFill"
                               IsVisible="False"/>

                        <Label x:Name="MessageLabel"
                               FontSize="12"
                               TextColor="#B91C1C"/>

                        <Button Text="Gửi đăng ký"
                                Clicked="OnSubmitClicked"
                                HeightRequest="52"
                                CornerRadius="16"
                                BackgroundColor="{StaticResource Primary}"
                                TextColor="White"/>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
