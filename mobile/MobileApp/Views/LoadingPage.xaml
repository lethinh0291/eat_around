<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ZesTour.Views.LoadingPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource AppBackground}">
    <Grid>
        <Grid.Background>
            <RadialGradientBrush Center="0.28,0.12"
                                 Radius="0.95">
                <GradientStop Color="#FFF9F2"
                              Offset="0"/>
                <GradientStop Color="#FFF2E5"
                              Offset="0.6"/>
                <GradientStop Color="#FFE8D2"
                              Offset="1"/>
            </RadialGradientBrush>
        </Grid.Background>

        <Ellipse Fill="#26F97316"
                 WidthRequest="300"
                 HeightRequest="300"
                 HorizontalOptions="Start"
                 VerticalOptions="Start"
                 Margin="-110,-100,0,0"/>

        <Ellipse Fill="#1CF97316"
                 WidthRequest="260"
                 HeightRequest="260"
                 HorizontalOptions="End"
                 VerticalOptions="End"
                 Margin="0,0,-120,-90"/>

        <VerticalStackLayout Padding="28"
                             Spacing="22"
                             VerticalOptions="Center">
            <Border StrokeThickness="0"
                    BackgroundColor="#FFFFFF"
                    StrokeShape="RoundRectangle 34"
                    HorizontalOptions="Center"
                    WidthRequest="180"
                    HeightRequest="180">
                <Border.Shadow>
                    <Shadow Brush="#33000000"
                            Offset="0,14"
                            Radius="28"
                            Opacity="0.85"/>
                </Border.Shadow>

                <Grid>
                    <Image Source="loading_logo.svg"
                           WidthRequest="120"
                           HeightRequest="120"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>

                    <Border BackgroundColor="{StaticResource Primary}"
                            StrokeThickness="0"
                            HorizontalOptions="End"
                            VerticalOptions="End"
                            Margin="0,0,18,18"
                            Padding="10,5"
                            StrokeShape="RoundRectangle 999">
                        <Label Text="ZESTOUR"
                               FontSize="11"
                               FontAttributes="Bold"
                               TextColor="White"/>
                    </Border>
                </Grid>
            </Border>

            <VerticalStackLayout Spacing="8"
                                 HorizontalOptions="Center">
                <Label Text="ZESTOUR"
                       FontSize="38"
                       FontAttributes="Bold"
                       FontFamily="OpenSansRegular"
                       TextColor="{StaticResource TextPrimary}"
                       HorizontalTextAlignment="Center"/>

                <Label Text="Định vị, khám phá và chỉ đường đẹp mắt hơn"
                       FontSize="15"
                       TextColor="{StaticResource TextSecondary}"
                       HorizontalTextAlignment="Center"/>
            </VerticalStackLayout>

            <Border StrokeThickness="1"
                    Stroke="{StaticResource BorderSoftBrush}"
                    BackgroundColor="#FFFFFF"
                    StrokeShape="RoundRectangle 26"
                    Padding="18">
                <Grid ColumnDefinitions="Auto,*"
                      ColumnSpacing="14"
                      VerticalOptions="Center">
                    <Border WidthRequest="48"
                            HeightRequest="48"
                            StrokeThickness="0"
                            BackgroundColor="#FFF7ED"
                            StrokeShape="RoundRectangle 24">
                        <ActivityIndicator IsRunning="True"
                                           Color="{StaticResource Primary}"
                                           WidthRequest="28"
                                           HeightRequest="28"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                    </Border>

                    <VerticalStackLayout Grid.Column="1"
                                         Spacing="4"
                                         VerticalOptions="Center">
                        <Label Text="Đang tải bản đồ và dữ liệu chuyến đi"
                               FontSize="15"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}"/>
                        <Label Text="Vui lòng chờ trong giây lát"
                               FontSize="12"
                               TextColor="{StaticResource TextSecondary}"/>
                    </VerticalStackLayout>
                </Grid>
            </Border>
        </VerticalStackLayout>
    </Grid>
</ContentPage>