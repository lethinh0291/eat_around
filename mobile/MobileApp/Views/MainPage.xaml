<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ZesTour.Views.MainPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource AppBackground}">

       <Grid RowDefinitions="Auto,*">
              <Grid Padding="18,22,18,12"
                    ColumnDefinitions="Auto,*,Auto"
                    ColumnSpacing="12">
                     <Border WidthRequest="50"
                             HeightRequest="50"
                             StrokeThickness="1"
                             Stroke="#D6E1E9"
                             BackgroundColor="#FFFFFF"
                             StrokeShape="RoundRectangle 16"
                             VerticalOptions="Center">
                            <Label Text="Menu"
                                   x:Name="MenuLabel"
                                   FontSize="11"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center">
                                   <Label.GestureRecognizers>
                                          <TapGestureRecognizer Tapped="OnMenuTapped"/>
                                   </Label.GestureRecognizers>
                            </Label>
                     </Border>

                     <VerticalStackLayout Grid.Column="1"
                                          VerticalOptions="Center"
                                          Spacing="2">
                            <Label Text="Bản đồ khám phá"
                                   x:Name="MapTitleLabel"
                                   FontSize="19"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}"/>
                            <Label Text="Chạm vào điểm trên bản đồ để nghe mô tả"
                                   x:Name="MapSubtitleLabel"
                                   FontSize="12"
                                   TextColor="{StaticResource TextSecondary}"/>
                     </VerticalStackLayout>

                     <Border Grid.Column="2"
                             WidthRequest="50"
                             HeightRequest="50"
                             StrokeThickness="1"
                             Stroke="#D6E1E9"
                             BackgroundColor="#FFFFFF"
                             StrokeShape="RoundRectangle 16"
                             VerticalOptions="Center">
                            <Label Text="Hồ sơ"
                                   x:Name="ProfileLabel"
                                   FontSize="11"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center">
                                   <Label.GestureRecognizers>
                                          <TapGestureRecognizer Tapped="OnProfileTapped"/>
                                   </Label.GestureRecognizers>
                            </Label>
                     </Border>
              </Grid>

              <Grid Grid.Row="1"
                    Padding="14,0,14,14">
                     <Border StrokeThickness="1"
                             Stroke="#E8D6CA"
                             BackgroundColor="#FFFFFF"
                             StrokeShape="RoundRectangle 28">
                            <Grid RowDefinitions="*,Auto">
                                   <Grid>
                                          <WebView x:Name="LeafletMapView"
                                                   Navigating="OnMapNavigating"
                                                   BackgroundColor="Transparent"
                                                   HorizontalOptions="Fill"
                                                   VerticalOptions="Fill"/>

                                          <VerticalStackLayout HorizontalOptions="End"
                                                               VerticalOptions="Start"
                                                               Margin="0,14,12,0"
                                                               Spacing="10">
                                                 <Border BackgroundColor="#FFFFFF"
                                                         StrokeThickness="1"
                                                         Stroke="#E8D6CA"
                                                         WidthRequest="44"
                                                         HeightRequest="44"
                                                         StrokeShape="RoundRectangle 14">
                                                        <Label Text="◎"
                                                               FontSize="18"
                                                               TextColor="{StaticResource TextPrimary}"
                                                               HorizontalTextAlignment="Center"
                                                               VerticalTextAlignment="Center">
                                                               <Label.GestureRecognizers>
                                                                      <TapGestureRecognizer Tapped="OnRecenterTapped"/>
                                                               </Label.GestureRecognizers>
                                                        </Label>
                                                 </Border>

                                                 <Border BackgroundColor="#FFFFFF"
                                                         StrokeThickness="1"
                                                         Stroke="#E8D6CA"
                                                         WidthRequest="44"
                                                         HeightRequest="44"
                                                         StrokeShape="RoundRectangle 14">
                                                        <Label x:Name="QrTriggerMapButtonLabel"
                                                               Text="QR"
                                                               FontSize="12"
                                                               FontAttributes="Bold"
                                                               TextColor="{StaticResource TextPrimary}"
                                                               HorizontalTextAlignment="Center"
                                                               VerticalTextAlignment="Center">
                                                               <Label.GestureRecognizers>
                                                                      <TapGestureRecognizer Tapped="OnQrTriggerTapped"/>
                                                               </Label.GestureRecognizers>
                                                        </Label>
                                                 </Border>
                                          </VerticalStackLayout>
                                   </Grid>

                                   <Border Grid.Row="1"
                                           StrokeThickness="0"
                                           BackgroundColor="#FFF9F6"
                                           StrokeShape="RoundRectangle 26,26,28,28"
                                           Padding="16,14,16,16">
                                          <VerticalStackLayout Spacing="12">
                                                 <Grid ColumnDefinitions="Auto,*"
                                                       ColumnSpacing="10">
                                                        <Border StrokeThickness="0"
                                                                BackgroundColor="#FFF1E8"
                                                                Padding="12,7"
                                                                StrokeShape="RoundRectangle 14">
                                                               <Label x:Name="PoiBadgeLabel"
                                                                      Text="ĐỊA ĐIỂM"
                                                                      FontAttributes="Bold"
                                                                      TextColor="#8E2F18"
                                                                      FontSize="11"/>
                                                        </Border>

                                                        <VerticalStackLayout Grid.Column="1"
                                                                             Spacing="2"
                                                                             VerticalOptions="Center">
                                                               <Label x:Name="LocationTitleLabel"
                                                                      Text="Địa điểm trên bản đồ"
                                                                      FontSize="12"
                                                                      TextColor="{StaticResource TextSecondary}"/>
                                                               <Label x:Name="NowPlayingLabel"
                                                                      Text="Chạm vào bản đồ để chọn địa điểm"
                                                                      FontSize="16"
                                                                      FontAttributes="Bold"
                                                                      TextColor="{StaticResource TextPrimary}"/>
                                                               <Label x:Name="AddressLabel"
                                                                      Text="Số nhà, đường: Chưa có thông tin"
                                                                      FontSize="12"
                                                                      TextColor="{StaticResource TextSecondary}"/>
                                                        </VerticalStackLayout>
                                                 </Grid>

                                                 <Grid ColumnDefinitions="*,*"
                                                       ColumnSpacing="10">
                                                        <Border StrokeThickness="1"
                                                                Stroke="#E8D6CA"
                                                                BackgroundColor="#FFFFFF"
                                                                Padding="10"
                                                                StrokeShape="RoundRectangle 16">
                                                               <Grid ColumnDefinitions="*,Auto"
                                                                     ColumnSpacing="8">
                                                                      <Label Text="Tự động phát"
                                                                             x:Name="AutoPlayLabel"
                                                                             FontSize="12"
                                                                             TextColor="{StaticResource TextPrimary}"
                                                                             VerticalTextAlignment="Center"/>
                                                                      <Switch Grid.Column="1"
                                                                              IsToggled="True"
                                                                              Toggled="OnAutoPlayToggled"/>
                                                               </Grid>
                                                        </Border>

                                                        <Border Grid.Column="1"
                                                                StrokeThickness="1"
                                                                Stroke="#E8D6CA"
                                                                BackgroundColor="#FFFFFF"
                                                                Padding="10"
                                                                StrokeShape="RoundRectangle 16">
                                                               <Grid ColumnDefinitions="*,Auto"
                                                                     ColumnSpacing="8">
                                                                      <Label Text="Tiết kiệm pin"
                                                                             x:Name="BatterySaverLabel"
                                                                             FontSize="12"
                                                                             TextColor="{StaticResource TextPrimary}"
                                                                             VerticalTextAlignment="Center"/>
                                                                      <Switch Grid.Column="1"
                                                                              IsToggled="False"
                                                                              Toggled="OnBatteryOptimizedToggled"/>
                                                               </Grid>
                                                        </Border>
                                                 </Grid>
                                          </VerticalStackLayout>
                                   </Border>
                            </Grid>
                     </Border>
              </Grid>

              <Grid x:Name="SidebarBackdrop"
                    Grid.RowSpan="2"
                    IsVisible="False"
                    Opacity="0"
                    InputTransparent="True"
                    BackgroundColor="#40000000">
                     <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnSidebarBackdropTapped"/>
                     </Grid.GestureRecognizers>
              </Grid>

              <Border x:Name="SidebarPanel"
                      Grid.RowSpan="2"
                      HorizontalOptions="Start"
                      VerticalOptions="Fill"
                      WidthRequest="292"
                      Margin="14,12,0,12"
                      Padding="16,18"
                      TranslationX="-340"
                      StrokeThickness="1"
                      Stroke="#E8D6CA"
                      BackgroundColor="#FFFFFF"
                      StrokeShape="RoundRectangle 24">
                     <VerticalStackLayout Spacing="14">
                            <Grid ColumnDefinitions="*,Auto"
                                  VerticalOptions="Center">
                                   <Label Text="Bảng điều hướng"
                                          x:Name="SidebarTitleLabel"
                                          FontSize="18"
                                          FontAttributes="Bold"
                                          TextColor="{StaticResource TextPrimary}"/>

                                   <Border Grid.Column="1"
                                           WidthRequest="34"
                                           HeightRequest="34"
                                           StrokeThickness="1"
                                           Stroke="#D6E1E9"
                                           BackgroundColor="#FFFFFF"
                                           StrokeShape="RoundRectangle 12">
                                          <Label Text="✕"
                                                 FontSize="13"
                                                 TextColor="{StaticResource TextPrimary}"
                                                 HorizontalTextAlignment="Center"
                                                 VerticalTextAlignment="Center">
                                                 <Label.GestureRecognizers>
                                                        <TapGestureRecognizer Tapped="OnCloseSidebarTapped"/>
                                                 </Label.GestureRecognizers>
                                          </Label>
                                   </Border>
                            </Grid>

                            <Label Text="Truy cập nhanh các chức năng chính để thao tác ít bước hơn."
                                      x:Name="SidebarSubtitleLabel"
                                   FontSize="12"
                                   TextColor="{StaticResource TextSecondary}"/>

                            <Button Text="Trang bản đồ"
                                       x:Name="SidebarMapButton"
                                    Clicked="OnSidebarHomeClicked"
                                    BackgroundColor="{StaticResource Secondary}"
                                    TextColor="{StaticResource PrimaryDark}"
                                    CornerRadius="14"
                                    HeightRequest="46"/>

                            <Button Text="Về trang chính"
                                       x:Name="SidebarHomeButton"
                                    Clicked="OnSidebarMenuClicked"
                                    BackgroundColor="{StaticResource Secondary}"
                                    TextColor="{StaticResource PrimaryDark}"
                                    CornerRadius="14"
                                    HeightRequest="46"/>

                            <Button Text="Hồ sơ người dùng"
                                       x:Name="SidebarProfileButton"
                                    Clicked="OnSidebarProfileClicked"
                                    BackgroundColor="{StaticResource Secondary}"
                                    TextColor="{StaticResource PrimaryDark}"
                                    CornerRadius="14"
                                    HeightRequest="46"/>

                            <Button Text="Định vị lại"
                                       x:Name="SidebarRecenterButton"
                                    Clicked="OnSidebarRecenterClicked"
                                    BackgroundColor="{StaticResource Secondary}"
                                    TextColor="{StaticResource PrimaryDark}"
                                    CornerRadius="14"
                                    HeightRequest="46"/>
                     </VerticalStackLayout>
              </Border>
       </Grid>
</ContentPage>

