<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ZesTour.Views.MainPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource AppBackground}">

       <Grid RowDefinitions="Auto,*">
              <Grid Padding="18,20,18,12"
                    ColumnDefinitions="Auto,*,Auto"
                    ColumnSpacing="12">
                     <Border WidthRequest="52"
                             HeightRequest="52"
                             StrokeThickness="0"
                             BackgroundColor="{StaticResource SurfaceSoft}"
                             StrokeShape="RoundRectangle 18"
                             VerticalOptions="Center">
                            <Label Text="MENU"
                                   FontSize="10"
                                   TextColor="{StaticResource TextPrimary}"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center">
                                   <Label.GestureRecognizers>
                                          <TapGestureRecognizer Tapped="OnMenuTapped"/>
                                   </Label.GestureRecognizers>
                            </Label>
                     </Border>



                     <Border Grid.Column="2"
                             WidthRequest="52"
                             HeightRequest="52"
                             StrokeThickness="0"
                             BackgroundColor="White"
                             StrokeShape="RoundRectangle 18"
                             VerticalOptions="Center">
                            <Label Text="PROFILE"
                                   FontSize="10"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center">
                                   <Label.GestureRecognizers>
                                          <TapGestureRecognizer Tapped="OnProfileTapped"/>
                                   </Label.GestureRecognizers>
                            </Label>
                     </Border>

              </Grid>

              <Grid Grid.Row="1"
                    Padding="14,0,14,14">
                     <Border StrokeThickness="0"
                             BackgroundColor="{StaticResource Surface}"
                             StrokeShape="RoundRectangle 30">
                            <Grid RowDefinitions="*,Auto">
                                   <Grid>
                                          <WebView x:Name="LeafletMapView"
                                                   Navigating="OnMapNavigating"
                                                   BackgroundColor="Transparent"
                                                   HorizontalOptions="Fill"
                                                   VerticalOptions="Fill"/>

                                          <VerticalStackLayout HorizontalOptions="End"
                                                               VerticalOptions="Start"
                                                               Margin="0,16,14,0"
                                                               Spacing="10">
                                                 <Border BackgroundColor="#F8FAFC"
                                                         StrokeThickness="0"
                                                         WidthRequest="42"
                                                         HeightRequest="42"
                                                         StrokeShape="RoundRectangle 14">
                                                        <Label Text="i"
                                                               FontSize="16"
                                                               FontAttributes="Bold"
                                                               TextColor="{StaticResource TextDark}"
                                                               HorizontalTextAlignment="Center"
                                                               VerticalTextAlignment="Center">
                                                               <Label.GestureRecognizers>
                                                                      <TapGestureRecognizer Tapped="OnInfoTapped"/>
                                                               </Label.GestureRecognizers>
                                                        </Label>
                                                 </Border>

                                                 <Border BackgroundColor="#F8FAFC"
                                                         StrokeThickness="0"
                                                         WidthRequest="42"
                                                         HeightRequest="42"
                                                         StrokeShape="RoundRectangle 14">
                                                        <Label Text="⌖"
                                                               FontSize="16"
                                                               TextColor="{StaticResource TextDark}"
                                                               HorizontalTextAlignment="Center"
                                                               VerticalTextAlignment="Center">
                                                               <Label.GestureRecognizers>
                                                                      <TapGestureRecognizer Tapped="OnRecenterTapped"/>
                                                               </Label.GestureRecognizers>
                                                        </Label>
                                                 </Border>
                                          </VerticalStackLayout>
                                   </Grid>

                                   <Border Grid.Row="1"
                                           StrokeThickness="0"
                                           BackgroundColor="#ffffff"
                                           StrokeShape="RoundRectangle 28,28,30,30"
                                           Margin="0,0,0,0"
                                           Padding="16,14,16,16">
                                          <VerticalStackLayout Spacing="14">
                                                 <Grid ColumnDefinitions="Auto,*"
                                                       ColumnSpacing="12">
                                                        <Border StrokeThickness="0"
                                                                BackgroundColor="#ffffff"
                                                                Padding="12,8"
                                                                StrokeShape="RoundRectangle 16">
                                                               <Label x:Name="PoiBadgeLabel"
                                                                      Text="VỊ TRÍ"
                                                                      FontAttributes="Bold"
                                                                      TextColor="#7A4718"
                                                                      FontSize="11"/>
                                                        </Border>

                                                        <VerticalStackLayout Grid.Column="1"
                                                                             Spacing="2"
                                                                             VerticalOptions="Center">
                                                               <Label x:Name="LocationTitleLabel"
                                                                      Text="Địa điểm trên bản đồ"
                                                                      FontSize="12"
                                                                      TextColor="{StaticResource TextSecondary}"/>
                                                               <Label x:Name="NowPlayingLabel"
                                                                      Text="Chạm vào bản đồ để chọn địa điểm"
                                                                      FontSize="16"
                                                                      FontAttributes="Bold"
                                                                      TextColor="{StaticResource TextPrimary}"/>
                                                               <Label x:Name="AddressLabel"
                                                                      Text="Số nhà, đường: Chưa có thông tin"
                                                                      FontSize="12"
                                                                      TextColor="{StaticResource TextSecondary}"/>
                                                        </VerticalStackLayout>
                                                 </Grid>

                                                 <Grid ColumnDefinitions="*,*"
                                                       ColumnSpacing="12">
                                                        <Border StrokeThickness="0"
                                                                BackgroundColor="#ffffff"
                                                                Padding="12"
                                                                StrokeShape="RoundRectangle 18">
                                                               <Grid ColumnDefinitions="*,Auto"
                                                                     ColumnSpacing="10">
                                                                      <Label Text="Tự Động Phát"
                                                                             FontSize="12"
                                                                             TextColor="{StaticResource TextPrimary}"
                                                                             VerticalTextAlignment="Center"/>
                                                                      <Switch Grid.Column="1"
                                                                              IsToggled="True"
                                                                              Toggled="OnAutoPlayToggled"/>
                                                               </Grid>
                                                        </Border>

                                                        <Border Grid.Column="1"
                                                                StrokeThickness="0"
                                                                BackgroundColor="#ffffff"
                                                                Padding="12"
                                                                StrokeShape="RoundRectangle 18">
                                                               <Grid ColumnDefinitions="*,Auto"
                                                                     ColumnSpacing="10">
                                                                      <Label Text="Tối Ưu Pin"
                                                                             FontSize="12"
                                                                             TextColor="{StaticResource TextPrimary}"
                                                                             VerticalTextAlignment="Center"/>
                                                                      <Switch Grid.Column="1"
                                                                              IsToggled="False"
                                                                              Toggled="OnBatteryOptimizedToggled"/>
                                                               </Grid>
                                                        </Border>
                                                 </Grid>
                                          </VerticalStackLayout>
                                   </Border>
                            </Grid>
                     </Border>
              </Grid>

              <Grid x:Name="SidebarBackdrop"
                    Grid.RowSpan="2"
                    IsVisible="False"
                    Opacity="0"
                    InputTransparent="True"
                    BackgroundColor="#ffffff00">
                     <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnSidebarBackdropTapped"/>
                     </Grid.GestureRecognizers>
              </Grid>

              <Border x:Name="SidebarPanel"
                      Grid.RowSpan="2"
                      HorizontalOptions="Start"
                      VerticalOptions="Fill"
                      WidthRequest="290"
                      Margin="14,12,0,12"
                      Padding="16,18"
                      TranslationX="-340"
                      StrokeThickness="1"
                      Stroke="{StaticResource BorderSoftBrush}"
                      BackgroundColor="#ffffff"
                      StrokeShape="RoundRectangle 24">
                     <VerticalStackLayout Spacing="14">
                            <Grid ColumnDefinitions="*,Auto"
                                  VerticalOptions="Center">
                                   <Label Text="Bảng điều hướng"
                                          FontSize="18"
                                          FontAttributes="Bold"
                                          TextColor="{StaticResource TextPrimary}"/>

                                   <Border Grid.Column="1"
                                           WidthRequest="34"
                                           HeightRequest="34"
                                           StrokeThickness="0"
                                           BackgroundColor="White"
                                           StrokeShape="RoundRectangle 12">
                                          <Label Text="✕"
                                                 FontSize="14"
                                                 TextColor="{StaticResource TextPrimary}"
                                                 HorizontalTextAlignment="Center"
                                                 VerticalTextAlignment="Center">
                                                 <Label.GestureRecognizers>
                                                        <TapGestureRecognizer Tapped="OnCloseSidebarTapped"/>
                                                 </Label.GestureRecognizers>
                                          </Label>
                                   </Border>
                            </Grid>

                            <Label Text="Truy cập nhanh các tính năng chính để thao tác ít bước hơn."
                                   FontSize="12"
                                   TextColor="{StaticResource TextSecondary}"/>

                            <Button Text="Trang bản đồ"
                                    Clicked="OnSidebarHomeClicked"
                                    BackgroundColor="White"
                                    TextColor="{StaticResource TextPrimary}"
                                    CornerRadius="14"
                                    HeightRequest="46"/>

                            <Button Text="Hồ sơ người dùng"
                                    Clicked="OnSidebarProfileClicked"
                                    BackgroundColor="White"
                                    TextColor="{StaticResource TextPrimary}"
                                    CornerRadius="14"
                                    HeightRequest="46"/>

                            <Button Text="Định vị lại"
                                    Clicked="OnSidebarRecenterClicked"
                                    BackgroundColor="White"
                                    TextColor="{StaticResource TextPrimary}"
                                    CornerRadius="14"
                                    HeightRequest="46"/>

                            <BoxView HeightRequest="1"
                                     BackgroundColor="#ffffff"
                                     Margin="0,6,0,0"/>

                            <Label Text="Mẹo: chạm vùng bên ngoài để đóng nhanh thanh này."
                                   FontSize="11"
                                   TextColor="{StaticResource TextSecondary}"/>
                     </VerticalStackLayout>
              </Border>
       </Grid>
</ContentPage>