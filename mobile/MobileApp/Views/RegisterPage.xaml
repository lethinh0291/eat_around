<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ZesTour.Views.RegisterPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource AppBackground}">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0"
                                 EndPoint="1,1">
                <GradientStop Color="#F4F8FA"
                              Offset="0"/>
                <GradientStop Color="#EDF3F6"
                              Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <ScrollView>
            <VerticalStackLayout Padding="22,44,22,24"
                                 Spacing="14">
                <Border StrokeThickness="0"
                        BackgroundColor="{StaticResource Primary}"
                        StrokeShape="RoundRectangle 24"
                        Padding="16">
                    <VerticalStackLayout Spacing="6">
                       <Label x:Name="RegisterTitleLabel"
                           Text="Tạo tài khoản mới"
                               FontSize="24"
                               FontAttributes="Bold"
                               TextColor="White"/>
                       <Label x:Name="RegisterSubtitleLabel"
                           Text="Đăng ký nhanh để lưu hành trình, khám phá và mở cửa hàng"
                               FontSize="12"
                               TextColor="#FFF7F1"/>
                    </VerticalStackLayout>
                </Border>

                <Border StrokeThickness="1"
                        Stroke="#D6E1E9"
                        BackgroundColor="#FFFFFF"
                        StrokeShape="RoundRectangle 22"
                        Padding="14">
                    <VerticalStackLayout Spacing="10">
                        <Border StrokeThickness="1"
                                Stroke="#D6E1E9"
                                BackgroundColor="#F7FAFC"
                                StrokeShape="RoundRectangle 14"
                                Padding="12,10">
                            <VerticalStackLayout Spacing="3">
                                <Label x:Name="NameTitleLabel"
                                    Text="Họ và tên"
                                       FontSize="11"
                                       TextColor="#475569"/>
                                <Entry x:Name="NameEntry"
                                       Placeholder="vd: Nguyễn Văn A"
                                       TextColor="#0F172A"
                                       PlaceholderColor="#64748B"
                                       BackgroundColor="Transparent"/>
                            </VerticalStackLayout>
                        </Border>

                        <Border StrokeThickness="1"
                                Stroke="#D6E1E9"
                                BackgroundColor="#F7FAFC"
                                StrokeShape="RoundRectangle 14"
                                Padding="12,10">
                            <VerticalStackLayout Spacing="3">
                                <Label x:Name="UsernameTitleLabel"
                                    Text="Tên đăng nhập"
                                       FontSize="11"
                                       TextColor="#475569"/>
                                <Entry x:Name="UsernameEntry"
                                       Placeholder="vd: nguyenvana"
                                       TextColor="#0F172A"
                                       PlaceholderColor="#64748B"
                                       BackgroundColor="Transparent"/>
                            </VerticalStackLayout>
                        </Border>

                        <Border StrokeThickness="1"
                                Stroke="#D6E1E9"
                                BackgroundColor="#F7FAFC"
                                StrokeShape="RoundRectangle 14"
                                Padding="12,10">
                            <VerticalStackLayout Spacing="3">
                                <Label x:Name="EmailTitleLabel"
                                    Text="Email"
                                       FontSize="11"
                                       TextColor="#475569"/>
                                <Entry x:Name="EmailEntry"
                                       Placeholder="vd: a@zestour.vn"
                                       Keyboard="Email"
                                       TextColor="#0F172A"
                                       PlaceholderColor="#64748B"
                                       BackgroundColor="Transparent"/>
                            </VerticalStackLayout>
                        </Border>

                        <Border StrokeThickness="1"
                                Stroke="#D6E1E9"
                                BackgroundColor="#F7FAFC"
                                StrokeShape="RoundRectangle 14"
                                Padding="12,10">
                            <VerticalStackLayout Spacing="3">
                                <Label x:Name="PasswordTitleLabel"
                                    Text="Mật khẩu"
                                       FontSize="11"
                                       TextColor="#475569"/>
                                <Entry x:Name="PasswordEntry"
                                       Placeholder="Nhập mật khẩu"
                                       IsPassword="True"
                                       TextColor="#0F172A"
                                       PlaceholderColor="#64748B"
                                       BackgroundColor="Transparent"/>
                            </VerticalStackLayout>
                        </Border>

                        <Border StrokeThickness="1"
                                Stroke="#D6E1E9"
                                BackgroundColor="#F7FAFC"
                                StrokeShape="RoundRectangle 14"
                                Padding="12,10">
                            <VerticalStackLayout Spacing="3">
                                <Label x:Name="ConfirmPasswordTitleLabel"
                                    Text="Xác nhận mật khẩu"
                                       FontSize="11"
                                       TextColor="#475569"/>
                                <Entry x:Name="ConfirmPasswordEntry"
                                       Placeholder="Nhập lại mật khẩu"
                                       IsPassword="True"
                                       TextColor="#0F172A"
                                       PlaceholderColor="#64748B"
                                       BackgroundColor="Transparent"/>
                            </VerticalStackLayout>
                        </Border>

                        <Border StrokeThickness="1"
                                Stroke="#D6E1E9"
                                BackgroundColor="#F7FAFC"
                                StrokeShape="RoundRectangle 14"
                                Padding="12,10">
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="10">
                                <VerticalStackLayout Spacing="2">
                                     <Label x:Name="SellerAccountTitleLabel"
                                         Text="Tạo tài khoản người bán"
                                           FontSize="13"
                                           FontAttributes="Bold"
                                           TextColor="#0F172A"/>
                                     <Label x:Name="SellerAccountHintLabel"
                                         Text="Bật nếu bạn muốn đăng ký và quản lý cửa hàng"
                                           FontSize="11"
                                           TextColor="#64748B"/>
                                </VerticalStackLayout>

                                <Switch Grid.Column="1"
                                        x:Name="SellerSwitch"
                                        IsToggled="False"
                                        Toggled="OnSellerSwitchToggled"
                                        VerticalOptions="Center"/>
                            </Grid>
                        </Border>

                        <Label x:Name="SelectedRoleLabel"
                               Text="Vai trò sẽ tạo: Khách hàng"
                               FontSize="12"
                               TextColor="#475569"/>

                        <Button x:Name="RegisterButton"
                            Text="Tạo tài khoản"
                                Clicked="OnRegisterClicked"
                                BackgroundColor="{StaticResource Primary}"
                                TextColor="White"
                                CornerRadius="14"
                                HeightRequest="48"
                                FontAttributes="Bold"/>

                        <Label x:Name="MessageLabel"
                               Text=""
                               FontSize="12"
                               TextColor="#DC2626"/>

                        <Button x:Name="BackToLoginButton"
                            Text="Quay lại đăng nhập"
                                Clicked="OnBackToLoginClicked"
                                BackgroundColor="{StaticResource Secondary}"
                                TextColor="{StaticResource PrimaryDark}"
                                BorderColor="#F5D0BF"
                                BorderWidth="1"
                                CornerRadius="14"
                                HeightRequest="46"
                                FontAttributes="Bold"/>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>


