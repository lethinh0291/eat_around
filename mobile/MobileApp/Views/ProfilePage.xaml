<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ZesTour.Views.ProfilePage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource AppBackground}">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0"
                                 EndPoint="1,1">
                <GradientStop Color="#FFFDFB"
                              Offset="0"/>
                <GradientStop Color="#FFF4EC"
                              Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <ScrollView>
            <VerticalStackLayout Padding="22,50,22,24"
                                 Spacing="16">
                <Grid ColumnDefinitions="Auto,*"
                      ColumnSpacing="12">
                    <Border WidthRequest="46"
                            HeightRequest="46"
                            StrokeThickness="1"
                            Stroke="#E8D6CA"
                            BackgroundColor="#FFFFFF"
                            StrokeShape="RoundRectangle 15">
                        <Label Text="←"
                               FontSize="18"
                               TextColor="{StaticResource TextPrimary}"
                               HorizontalTextAlignment="Center"
                               VerticalTextAlignment="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnBackTapped"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>

                    <VerticalStackLayout Grid.Column="1"
                                         Spacing="2"
                                         VerticalOptions="Center">
                           <Label x:Name="ProfileTitleLabel"
                               Text="Hồ sơ người dùng"
                               FontSize="12"
                               TextColor="{StaticResource TextSecondary}"/>
                           <Label x:Name="ProfileSubtitleLabel"
                               Text="Tài khoản và ảnh đại diện"
                               FontSize="24"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}"/>
                    </VerticalStackLayout>
                </Grid>

                <Border StrokeThickness="1"
                        Stroke="#E8D6CA"
                        BackgroundColor="#FFFFFF"
                        StrokeShape="RoundRectangle 28"
                        Padding="18">
                    <VerticalStackLayout Spacing="14">
                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="14">
                            <Border WidthRequest="84"
                                    HeightRequest="84"
                                    StrokeThickness="1"
                                    Stroke="#E8D6CA"
                                    BackgroundColor="#FFF1E8"
                                    StrokeShape="RoundRectangle 28">
                                <Grid>
                                    <Image x:Name="AvatarImage"
                                           Aspect="AspectFill"
                                           IsVisible="False"/>
                                    <Label x:Name="AvatarInitialsLabel"
                                           Text="U"
                                           FontSize="28"
                                           FontAttributes="Bold"
                                           TextColor="#8E2F18"
                                           HorizontalTextAlignment="Center"
                                           VerticalTextAlignment="Center"/>
                                </Grid>
                            </Border>

                            <VerticalStackLayout Grid.Column="1"
                                                 Spacing="4"
                                                 VerticalOptions="Center">
                                <Label x:Name="NameLabel"
                                       Text="Người dùng"
                                       FontSize="20"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}"/>
                                <Label x:Name="EmailLabel"
                                       Text="user@zestour.vn"
                                       FontSize="12"
                                       TextColor="{StaticResource TextSecondary}"/>
                                <Label x:Name="StatusLabel"
                                       Text="Đang đăng nhập"
                                       FontSize="11"
                                       TextColor="#D94827"/>
                            </VerticalStackLayout>
                        </Grid>

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="12">
                            <Border StrokeThickness="1"
                                    Stroke="#E8D6CA"
                                    BackgroundColor="#F7FAFC"
                                    StrokeShape="RoundRectangle 18"
                                    Padding="12">
                                <VerticalStackLayout Spacing="4">
                                     <Label x:Name="UsernameTitleLabel"
                                         Text="Tên đăng nhập"
                                           FontSize="11"
                                           TextColor="{StaticResource TextSecondary}"/>
                                    <Label x:Name="UsernameLabel"
                                           Text="username"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource TextPrimary}"/>
                                </VerticalStackLayout>
                            </Border>

                            <Border Grid.Column="1"
                                    StrokeThickness="1"
                                    Stroke="#E8D6CA"
                                    BackgroundColor="#F7FAFC"
                                    StrokeShape="RoundRectangle 18"
                                    Padding="12">
                                <VerticalStackLayout Spacing="4">
                                     <Label x:Name="AccountNumberTitleLabel"
                                         Text="Số tài khoản"
                                           FontSize="11"
                                           TextColor="{StaticResource TextSecondary}"/>
                                    <Label x:Name="UserIdLabel"
                                           Text="#0001"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource TextPrimary}"/>
                                </VerticalStackLayout>
                            </Border>
                        </Grid>

                        <Border StrokeThickness="1"
                                Stroke="#E8D6CA"
                                BackgroundColor="#F7FAFC"
                                StrokeShape="RoundRectangle 18"
                                Padding="12,10">
                            <VerticalStackLayout Spacing="4">
                                <Label x:Name="AvatarTitleLabel"
                                    Text="Ảnh đại diện"
                                       FontSize="11"
                                       TextColor="{StaticResource TextSecondary}"/>
                                <Label x:Name="AvatarHintLabel"
                                    Text="Chọn từ máy và lưu lên Cloudinary để dùng cho hồ sơ của bạn"
                                       FontSize="12"
                                       TextColor="{StaticResource TextPrimary}"/>
                            </VerticalStackLayout>
                        </Border>

                           <Button x:Name="ChangeAvatarButton"
                                Text="Đổi ảnh đại diện"
                                Clicked="OnChangeAvatarClicked"
                                BackgroundColor="{StaticResource Primary}"
                                TextColor="White"
                                CornerRadius="14"
                                HeightRequest="48"
                                FontAttributes="Bold"/>

                        <Label x:Name="MessageLabel"
                               Text=""
                               FontSize="12"
                               TextColor="#B91C1C"/>
                    </VerticalStackLayout>
                </Border>

                <Border StrokeThickness="1"
                        Stroke="#E8D6CA"
                        BackgroundColor="#FFFFFF"
                        StrokeShape="RoundRectangle 28"
                        Padding="18">
                    <VerticalStackLayout Spacing="14">
                           <Label x:Name="QuickActionsTitleLabel"
                               Text="Hành động nhanh"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}"/>

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="12">
                            <Border StrokeThickness="1"
                                    Stroke="#E8D6CA"
                                    BackgroundColor="#F7FAFC"
                                    StrokeShape="RoundRectangle 18"
                                    Padding="14">
                                <VerticalStackLayout Spacing="4">
                                     <Label x:Name="MapTitleLabel"
                                         Text="Bản đồ"
                                           FontSize="12"
                                           TextColor="{StaticResource TextSecondary}"/>
                                     <Label x:Name="BackToHomeLabel"
                                         Text="Quay lại trang chính"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource TextPrimary}"/>
                                </VerticalStackLayout>
                            </Border>

                            <Border Grid.Column="1"
                                    StrokeThickness="1"
                                    Stroke="#E8D6CA"
                                    BackgroundColor="#F7FAFC"
                                    StrokeShape="RoundRectangle 18"
                                    Padding="14">
                                <VerticalStackLayout Spacing="4">
                                     <Label x:Name="StatusTitleLabel"
                                         Text="Trạng thái"
                                           FontSize="12"
                                           TextColor="{StaticResource TextSecondary}"/>
                                     <Label x:Name="LocalSyncLabel"
                                         Text="Đồng bộ cục bộ"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource TextPrimary}"/>
                                </VerticalStackLayout>
                            </Border>
                        </Grid>

                               <Button x:Name="SignOutButton"
                                    Text="Đăng xuất"
                                Clicked="OnSignOutClicked"
                                BackgroundColor="#FEE2E2"
                                TextColor="#B91C1C"
                                CornerRadius="18"
                                HeightRequest="52"/>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>

