<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ZesTour.Views.ProfilePage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource AppBackground}">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0"
                                 EndPoint="1,1">
                <GradientStop Color="#FFFDFB"
                              Offset="0"/>
                <GradientStop Color="#FFF4EC"
                              Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <ScrollView>
            <VerticalStackLayout Padding="22,50,22,24"
                                 Spacing="16">
                <Grid ColumnDefinitions="Auto,*"
                      ColumnSpacing="12">
                    <Border WidthRequest="46"
                            HeightRequest="46"
                            StrokeThickness="1"
                            Stroke="#E8D6CA"
                            BackgroundColor="#FFFFFF"
                            StrokeShape="RoundRectangle 15">
                        <Label Text="←"
                               FontSize="18"
                               TextColor="{StaticResource TextPrimary}"
                               HorizontalTextAlignment="Center"
                               VerticalTextAlignment="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnBackTapped"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>

                    <VerticalStackLayout Grid.Column="1"
                                         Spacing="2"
                                         VerticalOptions="Center">
                        <Label x:Name="ProfileTitleLabel"
                               Text="Hồ sơ người dùng"
                               FontSize="12"
                               TextColor="{StaticResource TextSecondary}"/>
                        <Label x:Name="ProfileSubtitleLabel"
                               Text="Tài khoản và ảnh đại diện"
                               FontSize="24"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}"/>
                    </VerticalStackLayout>
                </Grid>

                <Border StrokeThickness="1"
                        Stroke="#E8D6CA"
                        BackgroundColor="#FFFFFF"
                        StrokeShape="RoundRectangle 28"
                        Padding="18">
                    <VerticalStackLayout Spacing="14">
                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="14">
                            <Border WidthRequest="84"
                                    HeightRequest="84"
                                    StrokeThickness="1"
                                    Stroke="#E8D6CA"
                                    BackgroundColor="#FFF1E8"
                                    StrokeShape="RoundRectangle 28">
                                <Grid>
                                    <Image x:Name="AvatarImage"
                                           Aspect="AspectFill"
                                           IsVisible="False"/>
                                    <Label x:Name="AvatarInitialsLabel"
                                           Text="U"
                                           FontSize="28"
                                           FontAttributes="Bold"
                                           TextColor="#8E2F18"
                                           HorizontalTextAlignment="Center"
                                           VerticalTextAlignment="Center"/>
                                </Grid>
                            </Border>

                            <VerticalStackLayout Grid.Column="1"
                                                 Spacing="4"
                                                 VerticalOptions="Center">
                                <Label x:Name="NameLabel"
                                       Text="Người dùng"
                                       FontSize="20"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}"/>
                                <Label x:Name="EmailLabel"
                                       Text="user@zestour.vn"
                                       FontSize="12"
                                       TextColor="{StaticResource TextSecondary}"/>
                                <Label x:Name="StatusLabel"
                                       Text="Đang đăng nhập"
                                       FontSize="11"
                                       TextColor="#D94827"/>
                            </VerticalStackLayout>
                        </Grid>

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="12">
                            <Border StrokeThickness="1"
                                    Stroke="#E8D6CA"
                                    BackgroundColor="#F7FAFC"
                                    StrokeShape="RoundRectangle 18"
                                    Padding="12">
                                <VerticalStackLayout Spacing="4">
                                    <Label x:Name="UsernameTitleLabel"
                                           Text="Tên đăng nhập"
                                           FontSize="11"
                                           TextColor="{StaticResource TextSecondary}"/>
                                    <Label x:Name="UsernameLabel"
                                           Text="username"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource TextPrimary}"/>
                                </VerticalStackLayout>
                            </Border>

                            <Border Grid.Column="1"
                                    StrokeThickness="1"
                                    Stroke="#E8D6CA"
                                    BackgroundColor="#F7FAFC"
                                    StrokeShape="RoundRectangle 18"
                                    Padding="12">
                                <VerticalStackLayout Spacing="4">
                                    <Label x:Name="AccountNumberTitleLabel"
                                           Text="Số tài khoản"
                                           FontSize="11"
                                           TextColor="{StaticResource TextSecondary}"/>
                                    <Label x:Name="UserIdLabel"
                                           Text="#0001"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource TextPrimary}"/>
                                </VerticalStackLayout>
                            </Border>
                        </Grid>

                        <Border StrokeThickness="1"
                                Stroke="#E8D6CA"
                                BackgroundColor="#F7FAFC"
                                StrokeShape="RoundRectangle 18"
                                Padding="12,10">
                            <VerticalStackLayout Spacing="4">
                                <Label x:Name="AvatarTitleLabel"
                                       Text="Ảnh đại diện"
                                       FontSize="11"
                                       TextColor="{StaticResource TextSecondary}"/>
                                <Label x:Name="AvatarHintLabel"
                                       Text="Chọn từ máy và lưu lên Cloudinary để dùng cho hồ sơ của bạn"
                                       FontSize="12"
                                       TextColor="{StaticResource TextPrimary}"/>
                            </VerticalStackLayout>
                        </Border>

                        <Button x:Name="ChangeAvatarButton"
                                Text="Đổi ảnh đại diện"
                                Clicked="OnChangeAvatarClicked"
                                BackgroundColor="{StaticResource Primary}"
                                TextColor="White"
                                CornerRadius="14"
                                HeightRequest="48"
                                FontAttributes="Bold"/>

                        <Button x:Name="ResetMenuWelcomeImageButton"
                                Text="Trả về nền cam"
                                Clicked="OnResetMenuWelcomeImageClicked"
                                BackgroundColor="#FFF7ED"
                                TextColor="#9A3412"
                                CornerRadius="14"
                                HeightRequest="44"
                                FontAttributes="Bold"/>

                        <Border x:Name="WelcomeBackgroundEditorBorder"
                                IsVisible="False"
                                StrokeThickness="1"
                                Stroke="#F2D3B8"
                                BackgroundColor="#FFF7ED"
                                StrokeShape="RoundRectangle 18"
                                Padding="12"
                                Margin="0,2,0,0">
                            <VerticalStackLayout Spacing="10">
                                <Label x:Name="WelcomeEditorTitleLabel"
                                       Text="Căn ảnh nền thẻ"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       TextColor="#9A3412"/>
                                <Label x:Name="WelcomeEditorHintLabel"
                                       Text="Kéo ảnh trong khung để chỉnh vùng hiển thị trên thẻ chào"
                                       FontSize="11"
                                       TextColor="#7C2D12"/>

                                <Border x:Name="WelcomePreviewHost"
                                        StrokeThickness="0"
                                        BackgroundColor="#EA580C"
                                        StrokeShape="RoundRectangle 18"
                                        HeightRequest="148"
                                        Padding="0">
                                    <Grid IsClippedToBounds="True">
                                        <Image x:Name="WelcomePreviewImage"
                                               Aspect="AspectFill"
                                               Scale="1.22"
                                               IsVisible="False">
                                            <Image.GestureRecognizers>
                                                <PanGestureRecognizer PanUpdated="OnWelcomePreviewPanUpdated"/>
                                            </Image.GestureRecognizers>
                                        </Image>
                                        <BoxView x:Name="WelcomePreviewOverlay"
                                                 IsVisible="False"
                                                 BackgroundColor="#29121B2A"/>
                                        <HorizontalStackLayout HorizontalOptions="End"
                                                               VerticalOptions="Start"
                                                               Margin="8"
                                                               Spacing="6">
                                            <Border StrokeThickness="0"
                                                    BackgroundColor="#E6FFFFFF"
                                                    StrokeShape="RoundRectangle 999"
                                                    Padding="10,4">
                                                <Label x:Name="WelcomeEditorTipLabel"
                                                       Text="Kéo ảnh"
                                                       FontSize="10"
                                                       TextColor="#7C2D12"
                                                       FontAttributes="Bold"/>
                                            </Border>
                                        </HorizontalStackLayout>
                                    </Grid>
                                </Border>

                                <Label x:Name="WelcomePresetLabel"
                                       Text="Mẫu nền hiện đại"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="#9A3412"/>

                                <Grid ColumnDefinitions="*,*"
                                      ColumnSpacing="8"
                                      RowDefinitions="Auto,Auto,Auto,Auto"
                                      RowSpacing="8">
                                    <Border Grid.Row="0"
                                            Grid.Column="0"
                                            StrokeThickness="1"
                                            Stroke="#F2D3B8"
                                            BackgroundColor="#FFFFFF"
                                            StrokeShape="RoundRectangle 14"
                                            Padding="4">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnApplyPresetAuroraTapped"/>
                                        </Border.GestureRecognizers>
                                        <Image Source="menu_welcome_bg_aurora.svg"
                                               HeightRequest="66"
                                               Aspect="AspectFill"/>
                                    </Border>

                                    <Border Grid.Row="0"
                                            Grid.Column="1"
                                            StrokeThickness="1"
                                            Stroke="#F2D3B8"
                                            BackgroundColor="#FFFFFF"
                                            StrokeShape="RoundRectangle 14"
                                            Padding="4">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnApplyPresetNeonGridTapped"/>
                                        </Border.GestureRecognizers>
                                        <Image Source="menu_welcome_bg_neon_grid.svg"
                                               HeightRequest="66"
                                               Aspect="AspectFill"/>
                                    </Border>

                                    <Border Grid.Row="1"
                                            Grid.Column="0"
                                            StrokeThickness="1"
                                            Stroke="#F2D3B8"
                                            BackgroundColor="#FFFFFF"
                                            StrokeShape="RoundRectangle 14"
                                            Padding="4">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnApplyPresetSunsetGlassTapped"/>
                                        </Border.GestureRecognizers>
                                        <Image Source="menu_welcome_bg_sunset_glass.svg"
                                               HeightRequest="66"
                                               Aspect="AspectFill"/>
                                    </Border>

                                    <Border Grid.Row="1"
                                            Grid.Column="1"
                                            StrokeThickness="1"
                                            Stroke="#F2D3B8"
                                            BackgroundColor="#FFFFFF"
                                            StrokeShape="RoundRectangle 14"
                                            Padding="4">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnApplyPresetSoftMeshTapped"/>
                                        </Border.GestureRecognizers>
                                        <Image Source="menu_welcome_bg_soft_mesh.svg"
                                               HeightRequest="66"
                                               Aspect="AspectFill"/>
                                    </Border>

                                    <Border Grid.Row="2"
                                            Grid.Column="0"
                                            StrokeThickness="1"
                                            Stroke="#F2D3B8"
                                            BackgroundColor="#FFFFFF"
                                            StrokeShape="RoundRectangle 14"
                                            Padding="4">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnApplyPresetOceanWaveTapped"/>
                                        </Border.GestureRecognizers>
                                        <Image Source="menu_welcome_bg_ocean_wave.svg"
                                               HeightRequest="66"
                                               Aspect="AspectFill"/>
                                    </Border>

                                    <Border Grid.Row="2"
                                            Grid.Column="1"
                                            StrokeThickness="1"
                                            Stroke="#F2D3B8"
                                            BackgroundColor="#FFFFFF"
                                            StrokeShape="RoundRectangle 14"
                                            Padding="4">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnApplyPresetUrbanNightTapped"/>
                                        </Border.GestureRecognizers>
                                        <Image Source="menu_welcome_bg_urban_night.svg"
                                               HeightRequest="66"
                                               Aspect="AspectFill"/>
                                    </Border>

                                    <Border Grid.Row="3"
                                            Grid.Column="0"
                                            StrokeThickness="1"
                                            Stroke="#F2D3B8"
                                            BackgroundColor="#FFFFFF"
                                            StrokeShape="RoundRectangle 14"
                                            Padding="4">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnApplyPresetMintFlowTapped"/>
                                        </Border.GestureRecognizers>
                                        <Image Source="menu_welcome_bg_mint_flow.svg"
                                               HeightRequest="66"
                                               Aspect="AspectFill"/>
                                    </Border>

                                    <Border Grid.Row="3"
                                            Grid.Column="1"
                                            StrokeThickness="1"
                                            Stroke="#F2D3B8"
                                            BackgroundColor="#FFFFFF"
                                            StrokeShape="RoundRectangle 14"
                                            Padding="4">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnApplyPresetRoseTechTapped"/>
                                        </Border.GestureRecognizers>
                                        <Image Source="menu_welcome_bg_rose_tech.svg"
                                               HeightRequest="66"
                                               Aspect="AspectFill"/>
                                    </Border>
                                </Grid>
                            </VerticalStackLayout>
                        </Border>

                        <Label x:Name="MessageLabel"
                               Text=""
                               FontSize="12"
                               TextColor="#B91C1C"/>
                    </VerticalStackLayout>
                </Border>

                <Border StrokeThickness="1"
                        Stroke="#E8D6CA"
                        BackgroundColor="#FFFFFF"
                        StrokeShape="RoundRectangle 28"
                        Padding="18">
                    <VerticalStackLayout Spacing="14">
                        <Label x:Name="QuickActionsTitleLabel"
                               Text="Hành động nhanh"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}"/>

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="12">
                            <Border StrokeThickness="1"
                                    Stroke="#E8D6CA"
                                    BackgroundColor="#F7FAFC"
                                    StrokeShape="RoundRectangle 18"
                                    Padding="14">
                                <VerticalStackLayout Spacing="4">
                                    <Label x:Name="MapTitleLabel"
                                           Text="Bản đồ"
                                           FontSize="12"
                                           TextColor="{StaticResource TextSecondary}"/>
                                    <Label x:Name="BackToHomeLabel"
                                           Text="Quay lại trang chính"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource TextPrimary}"/>
                                </VerticalStackLayout>
                            </Border>

                            <Border Grid.Column="1"
                                    StrokeThickness="1"
                                    Stroke="#E8D6CA"
                                    BackgroundColor="#F7FAFC"
                                    StrokeShape="RoundRectangle 18"
                                    Padding="14">
                                <VerticalStackLayout Spacing="4">
                                    <Label x:Name="StatusTitleLabel"
                                           Text="Trạng thái"
                                           FontSize="12"
                                           TextColor="{StaticResource TextSecondary}"/>
                                    <Label x:Name="LocalSyncLabel"
                                           Text="Đồng bộ cục bộ"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource TextPrimary}"/>
                                </VerticalStackLayout>
                            </Border>
                        </Grid>

                        <Button x:Name="SignOutButton"
                                Text="Đăng xuất"
                                Clicked="OnSignOutClicked"
                                BackgroundColor="#FEE2E2"
                                TextColor="#B91C1C"
                                CornerRadius="18"
                                HeightRequest="52"/>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>

